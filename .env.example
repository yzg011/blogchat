# Cloudflare API Token（用于上传向量到 Vectorize）
# 创建地址：https://dash.cloudflare.com/profile/api-tokens
# 权限：Account > Vectorize > Edit + Account > Workers AI > Use
CLOUDFLARE_API_TOKEN=your_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# 第三方 AI API（可选，三者齐备才启用，不填则使用 Cloudflare Workers AI 免费额度）
# AI_API_URL=https://api.example.com/v1
# AI_API_KEY=sk-your-api-key
# AI_EMBEDDING_MODEL=your-chat-model_EMBEDDING_MODEL
# AI_API_MODEL=your-chat-model

# 向量维度（需与索引一致，默认 1024）
# VECTORIZE_DIM=1024

# 构建脚本批处理大小（默认 500 和 50）
# BATCH_SIZE=500
# EMBED_BATCH_SIZE=50
