---
import Icon from "@components/common/Icon.astro";
import CategoryRose from "@components/widget/CategoryRose.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCategoryList } from "@/utils/content-utils";

const categories = await getCategoryList();
const title = i18n(I18nKey.categories);
---

<MainGridLayout title={title}>
  <div class="categories-page card-base z-10 px-4 py-6 md:px-9 relative w-full">
    <div class="categories-page__header flex items-center gap-3 mb-6">
      <Icon name="material-symbols:category" class="text-[1.875rem]" />
      <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        {title}
      </div>
    </div>
    <div class="categories-page__chart-container">
      <CategoryRose categories={categories} />
    </div>
  </div>
</MainGridLayout>
