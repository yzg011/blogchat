---
import CategoryFolders from "@components/widget/CategoryFolders.astro";
import CategoryRose from "@components/widget/CategoryRose.astro";
import TagGraph from "@components/widget/TagGraph.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import Icon from "@/components/common/Icon.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import { getCategoryTagGroups, getTagGraphData } from "@/utils/content-utils";

const categoryGroups = await getCategoryTagGroups();
const categories = categoryGroups.map(({ name, count, url }) => ({
	name,
	count,
	url,
}));
const tagGraph = await getTagGraphData();
const title = "分类标签";
---

<MainGridLayout title={title}>
  <div class="categories-page card-base z-10 px-4 py-6 md:px-9 relative w-full" data-taxonomy-view-root>
    <div class="categories-page__header">
      <PageTitle
        title={title}
        variant="stacked"
      />

      <div class="categories-page__view-switch" role="tablist" aria-label="分类标签视图">
        <button
          class="categories-page__view-button is-active"
          type="button"
          role="tab"
          id="taxonomy-view-folders"
          aria-controls="taxonomy-panel-folders"
          aria-selected="true"
          tabindex="0"
          data-taxonomy-view="folders"
        >
          <Icon name="material-symbols:folder-outline" aria-hidden="true" />
          <span>文件夹</span>
        </button>
        <button
          class="categories-page__view-button"
          type="button"
          role="tab"
          id="taxonomy-view-graph"
          aria-controls="taxonomy-panel-graph"
          aria-selected="false"
          tabindex="-1"
          data-taxonomy-view="graph"
        >
          <Icon name="material-symbols:bar-chart" aria-hidden="true" />
          <span>数据图</span>
        </button>
      </div>
    </div>

    <section
      id="taxonomy-panel-folders"
      class="categories-page__panel"
      role="tabpanel"
      aria-labelledby="taxonomy-view-folders"
      data-taxonomy-panel="folders"
    >
      <CategoryFolders groups={categoryGroups} />
    </section>

    <section
      id="taxonomy-panel-graph"
      class="categories-page__panel"
      role="tabpanel"
      aria-labelledby="taxonomy-view-graph"
      data-taxonomy-panel="graph"
      hidden
    >
      <CategoryRose categories={categories} />
      <div class="categories-page__divider"></div>
      <TagGraph graph={tagGraph} />
    </section>
  </div>
  <script is:inline>
  (function () {
    function resizeTaxonomyCharts() {
      requestAnimationFrame(() => {
        window.dispatchEvent(new Event("resize"));
      });
    }

    function selectTaxonomyView(root, view) {
      const buttons = root.querySelectorAll("[data-taxonomy-view]");
      const panels = root.querySelectorAll("[data-taxonomy-panel]");

      for (const button of buttons) {
        const isActive = button.dataset.taxonomyView === view;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", String(isActive));
        button.tabIndex = isActive ? 0 : -1;
      }

      for (const panel of panels) {
        panel.hidden = panel.dataset.taxonomyPanel !== view;
      }

      if (view === "graph") resizeTaxonomyCharts();
    }

    function initTaxonomyView() {
      const root = document.querySelector("[data-taxonomy-view-root]");
      if (!root || root.dataset.taxonomyViewBound === "true") return;
      root.dataset.taxonomyViewBound = "true";

      root.addEventListener("click", (event) => {
        const button = event.target.closest("[data-taxonomy-view]");
        if (!button || !root.contains(button)) return;
        selectTaxonomyView(root, button.dataset.taxonomyView || "folders");
      });

      root.addEventListener("keydown", (event) => {
        const button = event.target.closest("[data-taxonomy-view]");
        if (!button || !root.contains(button)) return;
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;

        const buttons = Array.from(root.querySelectorAll("[data-taxonomy-view]"));
        const currentIndex = buttons.indexOf(button);
        if (currentIndex < 0) return;

        event.preventDefault();
        let nextIndex = currentIndex;
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = buttons.length - 1;
        if (event.key === "ArrowLeft") {
          nextIndex = (currentIndex - 1 + buttons.length) % buttons.length;
        }
        if (event.key === "ArrowRight") {
          nextIndex = (currentIndex + 1) % buttons.length;
        }

        const nextButton = buttons[nextIndex];
        if (nextButton) {
          nextButton.focus();
          selectTaxonomyView(root, nextButton.dataset.taxonomyView || "folders");
        }
      });
    }

    initTaxonomyView();

    if (!window.__taxonomyViewPageLoadBound) {
      window.__taxonomyViewPageLoadBound = true;
      document.addEventListener("astro:page-load", initTaxonomyView);
    }
  })();
  </script>
</MainGridLayout>
