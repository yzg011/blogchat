---
import Icon from "@components/common/Icon.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import { collectionsApiConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.collections) {
	return Astro.redirect("/404/");
}

const title = collectionsApiConfig.title || i18n(I18nKey.collections);
const description =
	collectionsApiConfig.description || i18n(I18nKey.collectionsDescription);
const enabledApis = collectionsApiConfig.apis.filter((api) => api.enabled);

// 从列表顺序自动提取分类（保持首次出现顺序，去重）
const categories = [...new Set(enabledApis.map((api) => api.category))];

// 计算每个分类的数量
const categoryCounts: Record<string, number> = {};
for (const api of enabledApis) {
	categoryCounts[api.category] = (categoryCounts[api.category] || 0) + 1;
}
---

<MainGridLayout title={title} description={description}>

  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-8">
        <PageTitle title={title} eyebrow="Collections" variant="stacked" />
        {description && (
          <p class="text-base text-neutral-500 dark:text-neutral-400 leading-relaxed mt-3">
            {description}
          </p>
        )}
      </div>

      <!-- Tab 分类导航（椭圆胶囊 + 换行） -->
      {enabledApis.length > 0 && categories.length > 1 && (
        <div class="tools-tab-wrapper">
          <div class="tools-tab-pill" data-tools-tab-nav>
            <div class="tools-tab-indicator" data-tools-tab-indicator></div>
            <button data-tools-tab="all" class="tools-tab-btn tools-tab-btn-active">
              全部
              <span class="tools-tab-badge">{enabledApis.length}</span>
            </button>
            {categories.map((cat) => (
              <button data-tools-tab={cat} class="tools-tab-btn tools-tab-btn-inactive">
                {cat}
                <span class="tools-tab-badge">{categoryCounts[cat]}</span>
              </button>
            ))}
          </div>
        </div>
      )}

      <!-- 工具卡片内容 -->
      {enabledApis.length > 0 ? (
        <div>
          <!-- 全部：按分类分组显示 -->
          <div data-tools-section="all">
            {categories.map((cat) => {
              const catApis = enabledApis.filter((api) => api.category === cat);
              if (catApis.length === 0) return null;
              return (
                <div class="tools-category-group mt-8 first:mt-0">
                  <div class="flex items-center gap-3 mb-5">
                    <div class="flex items-center gap-2">
                      <Icon name="material-symbols:label-outline" class="text-lg text-neutral-900 dark:text-neutral-100" />
                      <span class="text-base font-bold text-neutral-900 dark:text-neutral-100">{cat}</span>
                    </div>
                    <span class="text-xs text-neutral-400 dark:text-neutral-500">{catApis.length}</span>
                    <div class="flex-1 h-[2px] bg-black dark:bg-white" />
                  </div>
                  <div class="tools-card-grid">
                    {catApis.map((api, index) => (
                      <a
                        href={api.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="tools-card group"
                        data-category={api.category}
                        style={`animation-delay: ${index * 60}ms`}
                      >
                        <div class="tools-card-jump-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M7 17L17 7" />
                            <path d="M7 7h10v10" />
                          </svg>
                        </div>
                        <div class="flex items-center gap-2 mb-3">
                          {api.icon ? (
                            api.icon.startsWith('http') ? (
                              <img src={api.icon} alt={api.name} class="w-6 h-6 rounded object-contain shrink-0" />
                            ) : (
                              <Icon name={api.icon} class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                            )
                          ) : (
                            <Icon name="material-symbols:api" class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                          )}
                          <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:translate-x-1 transition-transform duration-300 truncate">
                            {api.name}
                          </h3>
                        </div>
                        <p class="tools-card-desc">{api.description}</p>
                        <div class="tools-card-footer">
                          <span class="text-xs text-neutral-400 dark:text-neutral-500 truncate">
                            {new URL(api.url).hostname}
                          </span>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>

          <!-- 各分类独立 Tab 内容 -->
          {categories.map((cat) => {
            const catApis = enabledApis.filter((api) => api.category === cat);
            if (catApis.length === 0) return null;
            return (
              <div data-tools-section={cat} class="hidden">
                <div class="tools-card-grid">
                  {catApis.map((api, index) => (
                    <a
                      href={api.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="tools-card group"
                      data-category={api.category}
                      style={`animation-delay: ${index * 60}ms`}
                    >
                      <div class="tools-card-jump-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M7 17L17 7" />
                          <path d="M7 7h10v10" />
                        </svg>
                      </div>
                      <div class="flex items-center gap-2 mb-3">
                        {api.icon ? (
                          api.icon.startsWith('http') ? (
                            <img src={api.icon} alt={api.name} class="w-6 h-6 rounded object-contain shrink-0" />
                          ) : (
                            <Icon name={api.icon} class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                          )
                        ) : (
                          <Icon name="material-symbols:api" class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                        )}
                        <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:translate-x-1 transition-transform duration-300 truncate">
                          {api.name}
                        </h3>
                      </div>
                      <p class="tools-card-desc">{api.description}</p>
                      <div class="tools-card-footer">
                        <span class="text-xs text-neutral-400 dark:text-neutral-500 truncate">
                          {new URL(api.url).hostname}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <Icon name="material-symbols:bookmark-outline" class="text-5xl text-neutral-300 dark:text-neutral-600 mb-4" />
          <p class="text-neutral-500 dark:text-neutral-400">{i18n(I18nKey.collectionsEmpty)}</p>
        </div>
      )}
    </div>
  </div>

  <!-- 事件委托：document 级别，只注册一次，swup 导航后自动生效 -->
  <script is:inline>
    (function() {
      if (window.__collectionsReady) return;
      window.__collectionsReady = true;

      function updateIndicator(targetBtn) {
        if (!targetBtn) return;
        var nav = targetBtn.closest("[data-tools-tab-nav]");
        if (!nav) return;
        var indicator = nav.querySelector("[data-tools-tab-indicator]");
        if (!indicator) return;
        indicator.style.left = targetBtn.offsetLeft + "px";
        indicator.style.top = targetBtn.offsetTop + "px";
        indicator.style.width = targetBtn.offsetWidth + "px";
        indicator.style.height = targetBtn.offsetHeight + "px";
        indicator.style.opacity = "1";
      }

      function activateTab(targetTab) {
        if (!targetTab) return;
        var tabButtons = document.querySelectorAll("[data-tools-tab]");
        var sections = document.querySelectorAll("[data-tools-section]");
        var targetButton = null;
        tabButtons.forEach(function(btn) {
          if (btn.dataset.toolsTab === targetTab) targetButton = btn;
        });
        if (!targetButton) return;

        tabButtons.forEach(function(btn) {
          btn.classList.remove("tools-tab-btn-active");
          btn.classList.add("tools-tab-btn-inactive");
          btn.disabled = false;
        });
        targetButton.classList.remove("tools-tab-btn-inactive");
        targetButton.classList.add("tools-tab-btn-active");
        targetButton.disabled = true;

        requestAnimationFrame(function() { updateIndicator(targetButton); });

        sections.forEach(function(section) {
          if (section.dataset.toolsSection === targetTab) {
            section.classList.remove("hidden");
            var cards = section.querySelectorAll(".tools-card");
            cards.forEach(function(card) {
              card.style.animation = "none";
              card.offsetHeight;
              card.style.animation = "";
            });
          } else {
            section.classList.add("hidden");
          }
        });

        var nextHash = "#tools-" + encodeURIComponent(targetTab);
        if (window.location.hash !== nextHash) {
          window.history.replaceState(null, "", nextHash);
        }
      }

      // 事件委托：tools tab 点击
      document.addEventListener("click", function(e) {
        var btn = e.target.closest("[data-tools-tab]");
        if (btn) activateTab(btn.dataset.toolsTab);
      });

      // hashchange
      window.addEventListener("hashchange", function() {
        var hash = window.location.hash.replace(/^#tools-/, "");
        if (hash) {
          try { hash = decodeURIComponent(hash); } catch(e) { return; }
          activateTab(hash);
        }
      });

      // resize
      window.addEventListener("resize", function() {
        var activeBtn = document.querySelector(".tools-tab-btn-active");
        if (activeBtn) updateIndicator(activeBtn);
      });

      // 初始化
      function init() {
        var hash = window.location.hash.replace(/^#tools-/, "");
        if (hash) {
          try { hash = decodeURIComponent(hash); } catch(e) { hash = ""; }
          if (hash) { activateTab(hash); return; }
        }
        var activeBtn = document.querySelector(".tools-tab-btn-active");
        if (activeBtn) {
          requestAnimationFrame(function() { updateIndicator(activeBtn); });
        }
      }

      init();
      document.addEventListener("astro:page-load", init);
    })();
  </script>
</MainGridLayout>
