---
import { getEntry } from "astro:content";
import Comment from "@components/comment/index.astro";
import Icon from "@components/common/Icon.astro";
import FriendCard from "@components/features/FriendCard.astro";
import FriendRulesModal from "@components/features/FriendRulesModal.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import {
	commentConfig,
	friendsPageConfig,
	getEnabledFriends,
	siteConfig,
} from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

// 检查页面是否启用
if (!siteConfig.pages.friends) {
	return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("friends page content not found");
}

// 检查评论系统是否启用
const isCommentEnabled =
	commentConfig?.type &&
	commentConfig.type !== "none" &&
	friendsPageConfig.showComment !== false;

// 使用配置文件中的友链数据，按权重排序
const items = getEnabledFriends();
const allTags = [...new Set(items.flatMap((item) => item.tags || []))].sort();

// 页面标题和描述
const title = friendsPageConfig.title || i18n(I18nKey.friends);
const description =
	friendsPageConfig.description || i18n(I18nKey.friendsDescription);
---

<MainGridLayout title={title} description={description}>
  <div
    class="flex w-full rounded-(--radius-large) relative min-h-32"
  >
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题和描述 -->
      <div class="mb-4">
        <div class="flex items-start justify-between gap-4 mb-3">
          <PageTitle title={title} eyebrow="Friends" variant="stacked" />
          {
            friendsPageConfig.applyLink && (
              <button
                data-open-friend-rules
                class="px-4 py-2 rounded-lg border border-neutral-900 dark:border-neutral-100 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-900 hover:text-neutral-100 dark:hover:bg-neutral-100 dark:hover:text-neutral-900 transition-colors duration-200 text-sm font-medium flex items-center gap-2 cursor-pointer"
              >
                <Icon name="material-symbols:help-outline-rounded" class="text-base" />
                如何申请友链
              </button>
            )
          }
        </div>
        {
          description && (
            <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
              {description}
            </p>
          )
        }
      </div>

      <!-- 标签筛选 -->
      {
        items.length > 0 && (
          <div class="friend-filter-tabs flex flex-wrap gap-1 mb-6 p-1 rounded-full border border-neutral-900 dark:border-neutral-100" data-friend-filter>
            <button
              data-tag="all"
              class="friend-tab-btn relative z-10 px-4 py-1.5 rounded-full text-sm font-medium transition-colors duration-200 text-white dark:text-neutral-900"
            >
              {i18n(I18nKey.all)}
            </button>
            {allTags.map((tag) => (
              <button
                data-tag={tag}
                class="friend-tab-btn relative z-10 px-4 py-1.5 rounded-full text-sm font-medium transition-colors duration-200 text-neutral-900 dark:text-neutral-100"
              >
                {tag}
              </button>
            ))}
            <!-- 滑动指示器 -->
            <div class="friend-tab-indicator absolute top-1 bottom-1 bg-neutral-900 dark:bg-neutral-100 rounded-full transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] pointer-events-none" style="left: 4px; width: 0px;"></div>
          </div>
        )
      }

      <div class="friends-grid" data-friends-grid data-page-size="9">
        {
          items.map((item) => (
            <div class="friend-card" data-tags={item.tags?.join(",")} data-title={item.title}>
              <FriendCard
                title={item.title}
                href={item.siteurl}
                imgurl={item.imgurl}
                desc={item.desc}
                tags={item.tags}
              />
            </div>
          ))
        }
      </div>

      <!-- 分页控件（默认每页 9 个） -->
      <nav class="friends-pagination" data-friends-pagination hidden aria-label="友链分页">
        <button type="button" class="friends-page-btn" data-page-prev aria-label="上一页">
          <Icon name="material-symbols:chevron-left-rounded" class="text-lg" />
        </button>
        <div class="friends-page-nums" data-page-nums></div>
        <button type="button" class="friends-page-btn" data-page-next aria-label="下一页">
          <Icon name="material-symbols:chevron-right-rounded" class="text-lg" />
        </button>
      </nav>
    </div>
  </div>

  <!-- 评论区 -->
  {isCommentEnabled && (
    <div class="mt-4">
      <Comment post={friendsPost} customPath="/friends/" />
    </div>
  )}

  <!-- 友链申请指南弹窗 -->
  <FriendRulesModal applyLink={friendsPageConfig.applyLink} commentEnabled={isCommentEnabled} />

  <!-- 样式已迁移至 src/styles/pages/friends.css -->

  <!-- 事件委托：document 级别，只注册一次，swup 导航后自动生效 -->
  <script is:inline>
    (function() {
      if (window.__friendFilterReady) return;
      window.__friendFilterReady = true;

      // 每个 card-base 独立维护当前标签与页码
      var state = new WeakMap();

      function getState(root) {
        var s = state.get(root);
        if (!s) {
          s = { tag: "all", page: 1 };
          state.set(root, s);
        }
        return s;
      }

      function updateIndicator(container, button) {
        var indicator = container.querySelector(".friend-tab-indicator");
        if (!indicator || !button) return;
        var parentRect = container.getBoundingClientRect();
        var btnRect = button.getBoundingClientRect();
        indicator.style.left = (btnRect.left - parentRect.left) + "px";
        indicator.style.width = btnRect.width + "px";
        indicator.style.opacity = "1";
      }

      // 核心：按标签筛选 + 分页，统一渲染
      function render(root) {
        var grid = root.querySelector("[data-friends-grid]");
        if (!grid) return;
        var s = getState(root);
        var pageSize = parseInt(grid.dataset.pageSize, 10) || 9;

        var cards = Array.prototype.slice.call(grid.querySelectorAll(".friend-card"));
        // 命中当前标签的卡片
        var matched = cards.filter(function(card) {
          if (s.tag === "all") return true;
          var tags = (card.dataset.tags || "").split(",");
          return tags.indexOf(s.tag) !== -1;
        });

        var totalPages = Math.max(1, Math.ceil(matched.length / pageSize));
        if (s.page > totalPages) s.page = totalPages;
        if (s.page < 1) s.page = 1;

        var start = (s.page - 1) * pageSize;
        var end = start + pageSize;
        var matchedSet = new Set(matched);

        cards.forEach(function(card) {
          var idx = matched.indexOf(card);
          var visible = matchedSet.has(card) && idx >= start && idx < end;
          if (visible) {
            card.style.display = "block";
            card.classList.add("animate-fade-in-up");
            loadAvatar(card); // 卡片可见时才注入 src 开始加载头像
          } else {
            card.style.display = "none";
            card.classList.remove("animate-fade-in-up");
          }
        });

        renderPagination(root, s.page, totalPages);
      }

      function renderPagination(root, page, totalPages) {
        var nav = root.querySelector("[data-friends-pagination]");
        if (!nav) return;
        if (totalPages <= 1) {
          nav.hidden = true;
          return;
        }
        nav.hidden = false;

        var prev = nav.querySelector("[data-page-prev]");
        var next = nav.querySelector("[data-page-next]");
        if (prev) prev.disabled = page <= 1;
        if (next) next.disabled = page >= totalPages;

        var nums = nav.querySelector("[data-page-nums]");
        if (!nums) return;
        nums.innerHTML = "";
        for (var i = 1; i <= totalPages; i++) {
          var btn = document.createElement("button");
          btn.type = "button";
          btn.className = "friends-page-num" + (i === page ? " is-active" : "");
          btn.dataset.pageGo = String(i);
          btn.textContent = String(i);
          nums.appendChild(btn);
        }
      }

      // 事件委托：标签切换
      document.addEventListener("click", function(e) {
        var button = e.target.closest(".friend-tab-btn");
        if (!button) return;
        var container = button.closest("[data-friend-filter]");
        if (!container) return;
        var root = container.closest(".card-base");
        if (!root) return;

        var s = getState(root);
        s.tag = button.dataset.tag;
        s.page = 1; // 切换标签时重置到第一页

        updateIndicator(container, button);

        var filters = container.querySelectorAll(".friend-tab-btn");
        filters.forEach(function(f) {
          if (f === button) {
            f.classList.remove("text-neutral-900", "dark:text-neutral-100");
            f.classList.add("text-white", "dark:text-neutral-900");
          } else {
            f.classList.remove("text-white", "dark:text-neutral-900");
            f.classList.add("text-neutral-900", "dark:text-neutral-100");
          }
        });

        render(root);
      });

      // 事件委托：分页按钮
      document.addEventListener("click", function(e) {
        var nav = e.target.closest("[data-friends-pagination]");
        if (!nav) return;
        var root = nav.closest(".card-base");
        if (!root) return;
        var s = getState(root);

        var go = e.target.closest("[data-page-go]");
        if (go) {
          s.page = parseInt(go.dataset.pageGo, 10) || 1;
        } else if (e.target.closest("[data-page-prev]")) {
          s.page = Math.max(1, s.page - 1);
        } else if (e.target.closest("[data-page-next]")) {
          s.page = s.page + 1;
        } else {
          return;
        }

        render(root);
        // 滚动回卡片顶部
        root.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      // 初始化：指示器 + 首屏分页
      function init() {
        document.querySelectorAll(".card-base").forEach(function(root) {
          var container = root.querySelector("[data-friend-filter]");
          if (container) {
            var s = getState(root);
            var activeBtn = container.querySelector('[data-tag="' + s.tag + '"]')
              || container.querySelector('[data-tag="all"]');
            if (activeBtn) updateIndicator(container, activeBtn);
          }
          if (root.querySelector("[data-friends-grid]")) {
            render(root);
          }
        });
      }

      // 头像按需加载：卡片可见时才把 data-src 注入 src 触发请求。
      // 彻底摆脱 loading=lazy + display:none 在 Swup 导航后不加载的问题。
      // 加载成功淡入真实头像；失败或超时（5s）显示手绘涂鸦头像。
      function loadAvatar(card) {
        var img = card.querySelector(".friend-card-avatar__img");
        if (!img || img.dataset.avatarLoaded) return;
        img.dataset.avatarLoaded = "1";

        var wrap = img.parentElement;
        var src = img.dataset.src;
        if (!wrap || !src) return;

        var TIMEOUT = 5000;
        var timer = setTimeout(function() {
          if (!wrap.classList.contains("is-loaded")) {
            wrap.classList.add("is-error");
          }
        }, TIMEOUT);

        img.addEventListener("load", function() {
          clearTimeout(timer);
          wrap.classList.remove("is-error");
          wrap.classList.add("is-loaded");
        });
        img.addEventListener("error", function() {
          clearTimeout(timer);
          wrap.classList.add("is-error");
        });

        // 注入 src 开始加载；若命中缓存瞬时完成，load 事件可能不触发，手动兜底
        img.src = src;
        if (img.complete && img.naturalWidth > 0) {
          clearTimeout(timer);
          wrap.classList.remove("is-error");
          wrap.classList.add("is-loaded");
        }
      }

      init();
      document.addEventListener("astro:page-load", init);
    })();
  </script>
</MainGridLayout>
