---
import Icon from "@components/common/Icon.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import { siteConfig, sponsorConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";

// 检查页面是否启用
if (!siteConfig.pages.sponsor) {
	return Astro.redirect("/404/");
}

const title = sponsorConfig.title || i18n(I18nKey.sponsorTitle);
const description =
	sponsorConfig.description || i18n(I18nKey.sponsorDescription);
const enabledMethods = sponsorConfig.methods.filter((method) => method.enabled);
const sponsors = sponsorConfig.sponsors || [];
const showSponsorsList = sponsorConfig.showSponsorsList !== false;
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题和描述 -->
      <div class="mb-8">
        <PageTitle title={title} eyebrow="Sponsor" variant="stacked" />
        {description && (
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4 mt-3">
            {description}
          </p>
        )}
        {sponsorConfig.usage && (
          <div class="mb-8 p-4 rounded-lg bg-(--primary)/8 dark:bg-(--btn-regular-bg) border border-(--primary)/30 dark:border-none backdrop-blur-xs shadow-xs usage-info-box">
            <div class="flex items-start gap-2">
              <Icon name="material-symbols:info-outline" class="text-(--primary) text-lg shrink-0 mt-0.5" />
              <p class="text-sm text-neutral-700 dark:text-neutral-200 leading-relaxed">
                <span class="font-semibold text-(--primary)"></span>
                {sponsorConfig.usage}
              </p>
            </div>
          </div>
        )}
      </div>

      <!-- 赞助方式 -->
      {enabledMethods.length > 0 && (
        <div class="sponsor-qr-card__outer">
        <div class="sponsor-qr-card">
          <!-- 第一层：扫码赞助标题 -->
          <div class="sponsor-qr-card__header">
            <h3 class="sponsor-qr-card__title">{i18n(I18nKey.scanToSponsor)}</h3>
          </div>

          <!-- 第二层：选择支付方式 -->
          <p class="sponsor-qr-card__subtitle">选择你喜欢的支付方式</p>

          <!-- 第三层：Tabs 导航 -->
          <div class="sponsor-qr-card__tabs-wrapper">
            <div class="sponsor-qr-card__tabs-pill" data-sponsor-tab-nav>
              <div class="sponsor-qr-card__tabs-indicator" data-sponsor-tab-indicator></div>
              {enabledMethods.map((method, index) => (
                <button
                  class:list={[
                    "sponsor-qr-card__tab-btn",
                    {
                      "sponsor-qr-card__tab-btn--active": index === 0,
                      "sponsor-qr-card__tab-btn--inactive": index !== 0
                    }
                  ]}
                  data-sponsor-tab={index}
                  type="button"
                >
                  {method.icon && (
                    <Icon name={method.icon} class="text-[1rem]" />
                  )}
                  {method.name}
                </button>
              ))}
            </div>
          </div>

          <!-- 第四层：二维码图片 -->
          <div class="sponsor-qr-card__content">
            {enabledMethods.map((method, index) => (
              <div
                class:list={[
                  "sponsor-qr-card__panel",
                  { "hidden": index !== 0 }
                ]}
                data-sponsor-panel={index}
              >
                {method.qrCode ? (
                  <div class="sponsor-qr-card__image-wrapper">
                    <img
                      src={url(method.qrCode)}
                      alt={`${method.name} ${i18n(I18nKey.scanToSponsor)}`}
                      class="sponsor-qr-card__image"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="sponsor-qr-card__empty">
                    <Icon name="material-symbols:qr-code-scanner" class="text-[3rem] mb-2 opacity-40" />
                    <span class="sponsor-qr-card__empty-text">暂不开通</span>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
        </div>
      )}
    </div>
  </div>

  <!-- 赞助者列表 -->
  {showSponsorsList && (
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative mt-4">
      <div class="card-base z-10 px-9 py-6 relative w-full">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
              赞助名单
            </h2>
          </div>
        </div>
        {sponsors.length > 0 ? (
          <div class="sponsor-list">
            {sponsors.map((sponsor) => (
              <div class="sponsor-row group">
                {/* 头像 */}
                <div class="sponsor-avatar">
                  {sponsor.avatar ? (
                    <img
                      src={sponsor.avatar}
                      alt={sponsor.name}
                      class="sponsor-avatar__img"
                      loading="lazy"
                    />
                  ) : (
                    <span>{sponsor.name.charAt(0)}</span>
                  )}
                </div>

                {/* 信息 */}
                <div class="sponsor-info">
                  <span class="sponsor-name">
                    {sponsor.name}
                  </span>
                  {sponsor.date && (
                    <span class="sponsor-date">
                      {new Date(sponsor.date).toLocaleDateString()}
                    </span>
                  )}
                </div>
                {sponsor.amount && (
                  <span class="sponsor-amount">
                    {sponsor.amount}
                  </span>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-12 text-neutral-500 dark:text-neutral-500">
            <p>{i18n(I18nKey.sponsorEmpty)}</p>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- 样式已迁移至 src/styles/pages/sponsor.css -->

  <!-- Sponsor Tabs 交互脚本 -->
  <script is:inline>
    (function() {
      if (window.__sponsorTabsReady) return;
      window.__sponsorTabsReady = true;

      function updateSponsorIndicator(nav) {
        if (!nav) return;
        var indicator = nav.querySelector("[data-sponsor-tab-indicator]");
        if (!indicator) return;
        var activeBtn = nav.querySelector(".sponsor-qr-card__tab-btn--active");
        if (!activeBtn) return;
        var navRect = nav.getBoundingClientRect();
        var btnRect = activeBtn.getBoundingClientRect();
        indicator.style.left = (btnRect.left - navRect.left) + "px";
        indicator.style.top = (btnRect.top - navRect.top) + "px";
        indicator.style.width = btnRect.width + "px";
        indicator.style.height = btnRect.height + "px";
        indicator.style.opacity = "1";
      }

      function activateSponsorTab(tabIndex) {
        var tabIndexStr = String(tabIndex);
        var tabButtons = document.querySelectorAll("[data-sponsor-tab]");
        var panels = document.querySelectorAll("[data-sponsor-panel]");

        tabButtons.forEach(function(btn) {
          if (btn.dataset.sponsorTab === tabIndexStr) {
            btn.classList.remove("sponsor-qr-card__tab-btn--inactive");
            btn.classList.add("sponsor-qr-card__tab-btn--active");
          } else {
            btn.classList.remove("sponsor-qr-card__tab-btn--active");
            btn.classList.add("sponsor-qr-card__tab-btn--inactive");
          }
        });

        panels.forEach(function(panel) {
          if (panel.dataset.sponsorPanel === tabIndexStr) {
            panel.classList.remove("hidden");
          } else {
            panel.classList.add("hidden");
          }
        });

        var nav = document.querySelector("[data-sponsor-tab-nav]");
        if (nav) updateSponsorIndicator(nav);
      }

      // 事件委托：sponsor tab 点击
      document.addEventListener("click", function(e) {
        var btn = e.target.closest("[data-sponsor-tab]");
        if (!btn) return;
        activateSponsorTab(btn.dataset.sponsorTab);
      });

      // resize：更新指示器
      window.addEventListener("resize", function() {
        var nav = document.querySelector("[data-sponsor-tab-nav]");
        if (nav) updateSponsorIndicator(nav);
      });

      // 初始化 sponsor tab 指示器
      function initSponsorTabs() {
        var nav = document.querySelector("[data-sponsor-tab-nav]");
        if (nav) {
          requestAnimationFrame(function() {
            updateSponsorIndicator(nav);
          });
        }
      }

      initSponsorTabs();
      document.addEventListener("astro:page-load", initSponsorTabs);
    })();
  </script>
</MainGridLayout>
