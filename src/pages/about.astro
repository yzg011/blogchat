---

import { getEntry } from "astro:content";
import AboutCanvas from "@components/about/AboutCanvas.svelte";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import "@/styles/components/about-canvas.css";

const aboutPost = await getEntry("spec", "about");
if (!aboutPost) {
	throw new Error("About page content not found");
}

// 提取 Markdown 源文本传给客户端
const aboutText = aboutPost.body ?? "";
---

<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <div class="about-canvas-container">
        <AboutCanvas text={aboutText} client:only="svelte" />
    </div>
</MainGridLayout>
