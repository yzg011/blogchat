---
/**
 * 极简门户区：将原侧边栏中的"门户级信息"以纯文本垂直堆叠展示。
 * 每块仅用 [ LABEL ] 小标签 + 细线分隔，无卡片填充。
 *
 * 包含：Profile / Announcement / Stats / Categories / Tags
 * 重组件（Music / Calendar / Live2D / Spine）由右下浮动坞触达，不在此处。
 */
import Icon from "@components/common/Icon.astro";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import NumberTicker from "@/components/common/NumberTicker.svelte";
import TypewriterText from "@/components/features/TypewriterText.astro";
import { profileConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "@/utils/content-utils";
import { url } from "@/utils/url-utils";

const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();

let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		const text = post.body
			.replace(/```[\s\S]*?```/g, "")
			.replace(/`[^`]*`/g, "")
			.replace(/\s+/g, " ")
			.trim();
		const cn = text.match(/[一-龥]/g) || [];
		const en = text.match(/[a-zA-Z]/g) || [];
		totalWords += cn.length + en.length;
	}
}

const siteStartDate = siteConfig.siteStartDate || "2025-01-01";
const latestPost = posts[0];

// 计算运行天数（服务端计算）
const startDate = new Date(siteStartDate);
const today = new Date();
const diffTime = Math.abs(today.getTime() - startDate.getTime());
const runningDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

// 计算活跃天数
let lastUpdateDays = 0;
let isToday = false;
if (latestPost) {
	const lastPost = latestPost.data.published;
	const timeSinceLastPost = Math.abs(today.getTime() - lastPost.getTime());
	lastUpdateDays = Math.floor(timeSinceLastPost / (1000 * 60 * 60 * 24));
	isToday = lastUpdateDays === 0;
}

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
	},
	{
		icon: "material-symbols:folder-outline",
		label: i18n(I18nKey.siteStatsCategoryCount),
		value: categories.length,
	},
	{
		icon: "material-symbols:label-outline",
		label: i18n(I18nKey.siteStatsTagCount),
		value: tags.length,
	},
	{
		icon: "material-symbols:text-ad-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalWords),
		value: totalWords,
		formatted: true,
	},
	{
		icon: "material-symbols:calendar-clock-outline",
		label: i18n(I18nKey.siteStatsRunningDays),
		value: runningDays,
		suffix: i18n(I18nKey.siteStatsDays).replace("{days}", ""),
	},
	{
		icon: "mingcute:heartbeat-line",
		label: i18n(I18nKey.siteStatsLastUpdate),
		value: isToday ? 0 : lastUpdateDays,
		suffix: isToday
			? i18n(I18nKey.today)
			: i18n(I18nKey.siteStatsDaysAgo).replace("{days}", ""),
	},
];
---

<div class="home-portal">
	{/* PROFILE */}
	<section class="section onload-animation flex flex-col items-center gap-8 mt-8">
		<div class="avatar-ripple-wrapper" id="avatar-ripple-wrapper" data-work-start={siteConfig.workHours?.start ?? 9} data-work-end={siteConfig.workHours?.end ?? 18} data-work-days={JSON.stringify(siteConfig.workHours?.workDays ?? [1,2,3,4,5])}>
			<div class="ripple-ring ripple-ring-1"></div>
			<div class="ripple-ring ripple-ring-2"></div>
			<div class="ripple-ring ripple-ring-3"></div>
			<a href={url("/about/")} class="group block relative w-44 h-44 overflow-hidden rounded-full border border-(--line-divider) shrink-0 avatar-core">
				<ImageWrapper
					src={profileConfig.avatar || ""}
					alt="Profile Image of the Author"
					class="w-full h-full"
					loading="eager"
					fetchpriority="high"
					widths={[400]}
					sizes="400px"
				/>
			</a>
			<div class="avatar-status-btn" id="avatar-status-btn">
				<span class="status-dot"></span>
				<span class="status-text" id="status-text">下班</span>
			</div>
		</div>
		<div class="text-center w-full">
			<TypewriterText text={profileConfig.bio || ""} speed={80} pauseTime={3000} class="text-xl text-(--content-meta)" />
		</div>
	</section>

	{/* STATS */}
	<div class="onload-animation mt-4">
		<div class="flex flex-row flex-wrap justify-center gap-x-8 gap-y-4">
			{stats.map((stat) => (
				<div class="flex flex-col items-center gap-2">
					<div class="flex items-center gap-1.5">
						<Icon name={stat.icon} class="text-base text-neutral-600 dark:text-neutral-300" />
						<span class="text-xs text-neutral-600 dark:text-neutral-300 font-medium">
							{stat.label}
						</span>
					</div>
					<NumberTicker
						value={stat.value}
						formatted={stat.formatted || false}
						suffix={stat.suffix || ''}
						class="text-sm font-bold text-neutral-900 dark:text-neutral-100"
						client:visible
					/>
				</div>
			))}
		</div>
	</div>

	{/* SOCIAL */}
	<div class="home-divider text-center">- - - - -</div>
	<div class="flex items-center justify-center gap-2 flex-wrap">
		{profileConfig.links.map((item) => (
			<a
				rel="me"
				aria-label={item.name}
				href={item.url}
				target={item.url.startsWith("http") ? "_blank" : "_self"}
				class="social-link-btn"
			>
				<Icon name={item.icon} class="text-base" is:inline />
				<span>{item.name}</span>
			</a>
		))}
	</div>

	{/* CATEGORIES */}
	<div class="home-divider text-center">- - - - -</div>
	<section class="section onload-animation">
		<div class="flex flex-wrap justify-center gap-2 px-2 max-w-full overflow-x-auto">
			{categories.map((c) => (
				<a href={c.url} aria-label={`View all posts in ${c.name.trim()}`} class="cat-square-btn text-sm gap-2 shrink-0">
					<span>{c.name.trim()}</span>
					<span class="text-(--content-meta) text-xs">{c.count}</span>
				</a>
			))}
		</div>
	</section>
	<div class="home-divider text-center">- - - - -</div>

</div>

<style>
	.home-portal {
		padding-top: 1rem;
		padding-bottom: 0;
	}

	.home-divider {
		margin-top: 0.75rem;
		margin-bottom: 0.75rem;
		font-size: 0.75rem;
		letter-spacing: 0.25em;
		color: var(--content-meta);
	}

	/* === Avatar Ripple === */
	.avatar-ripple-wrapper {
		position: relative;
		width: 11rem;
		height: 11rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.avatar-core {
		position: relative;
		z-index: 2;
	}
	.ripple-ring {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 100%;
		height: 100%;
		border-radius: 9999px;
		transform: translate(-50%, -50%) scale(1);
		opacity: 0;
		pointer-events: none;
		will-change: transform, opacity;
	}

	/* 上班时间：粉红色涟漪 */
	[data-time-mode="work"] .ripple-ring {
		border: 4px solid oklch(0.65 0.2 350);
		box-shadow: 0 0 16px oklch(0.65 0.2 350 / 0.4);
	}
	[data-time-mode="work"] .ripple-ring-1 { animation: ripple-expand 3s ease-out infinite; }
	[data-time-mode="work"] .ripple-ring-2 { animation: ripple-expand 3s ease-out 1s infinite; }
	[data-time-mode="work"] .ripple-ring-3 { animation: ripple-expand 3s ease-out 2s infinite; }

	/* 下班时间：静态一圈 */
	[data-time-mode="off"] .ripple-ring {
		border: 4px solid #000;
		animation: none;
		opacity: 1;
		transform: translate(-50%, -50%) scale(1);
	}
	[data-time-mode="off"] .ripple-ring-2,
	[data-time-mode="off"] .ripple-ring-3 {
		display: none;
	}
	:root.dark [data-time-mode="off"] .ripple-ring {
		border-color: #fff;
	}

	@keyframes ripple-expand {
		0% {
			transform: translate(-50%, -50%) scale(0.8);
			opacity: 0.6;
		}
		100% {
			transform: translate(-50%, -50%) scale(1.5);
			opacity: 0;
		}
	}

	/* === Status Button === */
	.avatar-status-btn {
		position: absolute;
		bottom: -0.5rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 10;
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 500;
		white-space: nowrap;
		border: 2px solid #000;
		color: #000;
		background: #fff;
	}
	:root.dark .avatar-status-btn {
		border-color: #fff;
		color: #fff;
		background: #000;
	}
	/* 上班时间粉色 */
	[data-time-mode="work"] .avatar-status-btn {
		border-color: oklch(0.65 0.2 350);
		color: oklch(0.65 0.2 350);
		background: #fff;
	}
	:root.dark [data-time-mode="work"] .avatar-status-btn {
		border-color: oklch(0.65 0.2 350);
		color: oklch(0.65 0.2 350);
		background: #000;
	}

	.status-dot {
		width: 0.375rem;
		height: 0.375rem;
		border-radius: 9999px;
		background: #000;
		flex-shrink: 0;
	}
	:root.dark .status-dot {
		background: #fff;
	}
	[data-time-mode="work"] .status-dot {
		background: oklch(0.65 0.2 350);
		animation: status-pulse 1.5s ease-in-out infinite;
	}

	@keyframes status-pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.3; }
	}

	.social-link-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.875rem;
		border: 1px solid #000;
		color: #000;
		background: #fff;
		border-radius: 9999px;
		font-size: 0.8125rem;
		text-decoration: none;
		transition: color 150ms, background-color 150ms;
	}
	.social-link-btn:hover {
		background-color: #000;
		color: #fff;
	}
	:root.dark .social-link-btn {
		border-color: #fff;
		color: #fff;
		background: #000;
	}
	:root.dark .social-link-btn:hover {
		background-color: #fff;
		color: #000;
	}

	.cat-square-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.375rem 1rem;
		border: 1px solid black;
		color: black;
		background: #fff;
		border-radius: 9999px;
		transition: color 150ms, background-color 150ms;
	}
	.cat-square-btn:hover {
		background-color: black;
		color: white;
	}
	:root.dark .cat-square-btn {
		border-color: white;
		color: white;
		background: black;
	}
	:root.dark .cat-square-btn:hover {
		background-color: white;
		color: black;
	}
</style>

<script>
(function() {
	function setTimeMode() {
		var wrapper = document.getElementById('avatar-ripple-wrapper');
		var statusText = document.getElementById('status-text');
		if (!wrapper) return;
		var start = parseInt(wrapper.dataset.workStart || '9') || 9;
		var end = parseInt(wrapper.dataset.workEnd || '18') || 18;
		var workDays = [1,2,3,4,5];
		try { workDays = JSON.parse(wrapper.dataset.workDays || '[1,2,3,4,5]'); } catch(e) {}
		var now = new Date();
		var day = now.getDay();
		var hour = now.getHours();
		// 先判断是否工作日，再判断时间
		var isWorkDay = workDays.indexOf(day) !== -1;
		var isWork = isWorkDay && hour >= start && hour < end;
		wrapper.setAttribute('data-time-mode', isWork ? 'work' : 'off');
		if (statusText) statusText.textContent = isWork ? '上班中' : '下班';
	}
	setTimeMode();
	setInterval(setTimeMode, 60000);
	document.addEventListener('astro:page-load', setTimeMode);
})();
</script>
