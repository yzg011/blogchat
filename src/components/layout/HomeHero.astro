---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { homeConfig, siteConfig } from "@/config";

const workHours = siteConfig.workHours ?? {
	start: 9,
	end: 18,
	workDays: [1, 2, 3, 4, 5],
};

const imageFiles = import.meta.glob<ImageMetadata>(
	"../../assets/images/**/*.{png,jpg,jpeg,webp,avif,gif}",
	{
		import: "default",
	},
);

async function optimizeHeroImage(image: ImageMetadata) {
	const optimized = await getImage({
		src: image,
		format: "webp",
		widths: [320],
	});
	return optimized.src;
}

async function resolveHeroImage(src?: string) {
	if (!src) return "";
	if (
		src.startsWith("/") ||
		src.startsWith("http://") ||
		src.startsWith("https://") ||
		src.startsWith("data:")
	) {
		return src;
	}

	const normalizedPath = `../../${src}`.replace(/\\/g, "/");
	const loadImage = imageFiles[normalizedPath];
	if (!loadImage) {
		return `/${src}`;
	}

	const image = await loadImage();
	return optimizeHeroImage(image);
}

const avatarUrl =
	(await resolveHeroImage(homeConfig.avatarOnWork ?? "")) ||
	(await resolveHeroImage(homeConfig.avatar));
const avatarOffUrl = homeConfig.avatarOffWork
	? await resolveHeroImage(homeConfig.avatarOffWork)
	: avatarUrl;

// galgame 对话框配置（写死暗黑主题，内容由 config 驱动）
const dialogueRaw = homeConfig.hero.dialogue;
const dialogueEnabled = dialogueRaw?.enabled ?? false;
const dialogueConfig = {
	speakers: {
		host:
			dialogueRaw?.speakers?.host ||
			homeConfig.displayName ||
			homeConfig.name ||
			"",
		visitor: dialogueRaw?.speakers?.visitor || "访客",
	},
	menuTitle: dialogueRaw?.menuTitle || "想聊点什么？",
	typingSpeed: dialogueRaw?.typingSpeed ?? 45,
	autoDelay: dialogueRaw?.autoDelay ?? 1600,
	intro: dialogueRaw?.intro ?? [],
	topics: dialogueRaw?.topics ?? [],
};

const heroRightPanel = homeConfig.hero.rightPanel ?? {
	pill: "BLOG",
	title: "博客",
	diamond: "✦",
	microText: "システム起動完了",
};

// 将 displayName 拆成逐字 span，用于逐字入场动画与 cqw 缩放
const nameLetters = Array.from(homeConfig.displayName || "");

const mobileBackground =
	homeConfig.hero.backgroundImageMobile || homeConfig.hero.backgroundImage;

const rainConfig = {
	enabled: homeConfig.hero.rain?.enabled ?? true,
	intensity: homeConfig.hero.rain?.intensity ?? 0.6,
	color: homeConfig.hero.rain?.color ?? "",
};
---

<section class="home-hero home-hero--motion-pending" id="home-hero"
	data-avatar={avatarUrl}
	data-avatar-off={avatarOffUrl}
	data-work-hours={JSON.stringify(workHours)}
	data-hero-rain={JSON.stringify(rainConfig)}
>
	<!-- 背景层：移动端 / 桌面端通过 <picture> 服务端切换 -->
	<picture class="home-hero__video-picture">
		<source media="(max-width: 768px)" srcset={mobileBackground} />
		<img class="home-hero__video" src={homeConfig.hero.backgroundImage} alt="" />
	</picture>

	<!-- 全屏内容容器 -->
	<div class="home-hero__canvas-container" id="main-canvas">
		<!-- 外四角取景框 -->
		<div class="home-hero__viewfinder" aria-hidden="true">
			<div class="home-hero__viewfinder-corner home-hero__viewfinder-corner--tl"></div>
			<div class="home-hero__viewfinder-corner home-hero__viewfinder-corner--tr"></div>
			<div class="home-hero__viewfinder-corner home-hero__viewfinder-corner--bl"></div>
			<div class="home-hero__viewfinder-corner home-hero__viewfinder-corner--br"></div>
		</div>

		<!-- 拍摄参数面板 -->
		<div class="home-hero__camera-params" aria-hidden="true">
			<span>MNL</span>
			<span>1/125</span>
			<span>OPEN</span>
			<span>3dB</span>
		</div>

		<!-- 中心对焦框（相机效果） -->
		<div class="home-hero__focus-frame" aria-hidden="true">
			<div class="home-hero__focus-corner home-hero__focus-corner--tl"></div>
			<div class="home-hero__focus-corner home-hero__focus-corner--tr"></div>
			<div class="home-hero__focus-corner home-hero__focus-corner--bl"></div>
			<div class="home-hero__focus-corner home-hero__focus-corner--br"></div>
			<div class="home-hero__focus-dot"></div>
		</div>

		<!-- 左侧面板（吞并原中栏，87%） -->
		<section class="home-hero__left-panel">
			<div class="home-hero__profile">
				<div class="home-hero__identity-row">
					<!-- 头像（仅移动端展示；桌面端已去除大头照） -->
					<div class="home-hero__avatar-group">
						<div class="home-hero__avatar-wrapper">
							<img
								src={avatarUrl}
								alt="avatar"
								class="home-hero__avatar"
								id="hero-avatar"
								loading="eager"
							/>
						</div>
						<div class="home-hero__status-badge" id="work-status">
							<span class="home-hero__status-dot"></span>
							<span class="home-hero__status-text">上班中</span>
						</div>
					</div>

					<!-- 名字 + 职业 + 幽灵徽章 -->
					<div class="home-hero__name-group">
						{homeConfig.occupation && (
							<p class="home-hero__occupation">{homeConfig.occupation}</p>
						)}
						{homeConfig.displayName && (
							<h1 class="home-hero__name home-hero__name--rainbow">
								{nameLetters.map((letter, i) => (
									<span class="home-hero__name-letter" data-letter-index={i}>{letter}</span>
								))}
							</h1>
						)}
						<div class="home-hero__name-badge">{homeConfig.nameBadge || ""}</div>
					</div>
				</div>
			</div>
		</section>

		<!-- galgame 对话框（放大·视窗水平居中·打字机·话题菜单，写死暗黑主题） -->
		{dialogueEnabled && (
			<div
				class="home-hero__dialogue"
				id="hero-dialogue"
				aria-label="对话"
				data-dialogue={JSON.stringify(dialogueConfig)}
			>
				<div class="home-hero__dialogue-box" data-dialogue-box>
					<!-- 左上角名牌（随说话者切换） -->
					<div class="home-hero__dialogue-nameplate">
						<span class="home-hero__dialogue-name" data-dialogue-name>{dialogueConfig.speakers.host}</span>
						<span class="home-hero__dialogue-spark" aria-hidden="true">✨</span>
					</div>

					<!-- 右上角控制按钮 -->
					<div class="home-hero__dialogue-controls">
						<button type="button" class="home-hero__dialogue-btn" data-dialogue-action="back">
							<span class="home-hero__dialogue-btn-icon" aria-hidden="true">↩</span>
							<span>Back</span>
						</button>
						<button type="button" class="home-hero__dialogue-btn" data-dialogue-action="auto" aria-pressed="false">
							<span class="home-hero__dialogue-btn-icon" aria-hidden="true">▶</span>
							<span>Auto</span>
						</button>
						<button type="button" class="home-hero__dialogue-btn" data-dialogue-action="hide">
							<span class="home-hero__dialogue-btn-icon" aria-hidden="true">✕</span>
							<span>Hide</span>
						</button>
					</div>

					<!-- 正文：台词 + 话题菜单 -->
					<div class="home-hero__dialogue-body" data-dialogue-click>
						<p class="home-hero__dialogue-text" data-dialogue-text></p>
						<ul class="home-hero__dialogue-menu" data-dialogue-menu hidden></ul>
					</div>

					<!-- 底部推进指示 -->
					<div class="home-hero__dialogue-footer">
						<button type="button" class="home-hero__dialogue-advance" data-dialogue-advance>
							<span data-dialogue-advance-label>下一句</span>
							<span class="home-hero__dialogue-advance-caret" aria-hidden="true">▾</span>
						</button>
					</div>
				</div>
			</div>
		)}

		<!-- 右侧面板（比例与样式保持不变） -->
		<aside class="home-hero__right-panel">
			<div class="home-hero__pill">{heroRightPanel.pill}</div>
			<div class="home-hero__vertical-wrap">
				<span class="home-hero__v-title">{heroRightPanel.title}</span>
				<span class="home-hero__v-sub">{homeConfig.name || ""}</span>
				<span class="home-hero__diamond">{heroRightPanel.diamond}</span>
				<span class="home-hero__v-sub home-hero__v-status is-working" id="hero-work-status-vertical">WORKING</span>
			</div>
			<div class="home-hero__panel-footer">
				<div class="home-hero__footer-line"></div>
				<p class="home-hero__micro-text">{heroRightPanel.microText}</p>
			</div>
		</aside>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { VFX } from "@vfx-js/core";
	import { waitForPageLoaderHidden } from "@/utils/page-loader-controller.js";
	import { HatchEffect } from "@/utils/hatch-effect.ts";

	gsap.registerPlugin(ScrollTrigger);

	let workStatusTimer: number | null = null;
	let heroOpeningTimeline: ReturnType<typeof gsap.timeline> | null = null;
	let vfxInstance: VFX | null = null;
	let heroHatchEffect: HatchEffect | null = null;

	// 玻璃雨珠 + 撞击水花
	type RainDrop = { x: number; y: number; r: number; vy: number; len: number; alpha: number };
	type SplashParticle = { x: number; y: number; vx: number; vy: number; life: number; maxLife: number; r: number };
	type HitEdge = { x1: number; x2: number; y: number };
	let rainCanvas: HTMLCanvasElement | null = null;
	let rainCtx: CanvasRenderingContext2D | null = null;
	let rainRaf = 0;
	let rainDrops: RainDrop[] = [];
	let rainSplashes: SplashParticle[] = [];
	let rainEdges: HitEdge[] = [];
	let rainResizeHandler: (() => void) | null = null;
	let rainEdgeTimer = 0;
	let rainDpr = 1;
	let rainIntensity = 0.6;
	let rainColorRgb: string | null = null;

	function prefersReducedMotion() {
		return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	}

	function isMobile() {
		return window.matchMedia("(max-width: 768px)").matches;
	}

	function killHomeMotion() {
		if (heroOpeningTimeline) {
			heroOpeningTimeline.kill();
			heroOpeningTimeline = null;
		}
		ScrollTrigger.getAll().forEach((trigger) => {
			const id = String(trigger.vars.id || "");
			if (id.startsWith("home-motion-")) trigger.kill();
		});
	}

	// ============================================
	// galgame \u5BF9\u8BDD\u6846\u63A7\u5236\u5668\uFF08\u6253\u5B57\u673A + \u4E24\u7EA7\u8BDD\u9898\u5BFC\u822A\uFF09
	// ============================================
	type DialogueLine = { speaker?: "host" | "visitor"; text: string };
	type DialogueTopic = { title: string; lines: DialogueLine[] };
	type DialogueConfig = {
		speakers: { host: string; visitor: string };
		menuTitle: string;
		typingSpeed: number;
		autoDelay: number;
		intro: DialogueLine[];
		topics: DialogueTopic[];
	};

	type DialogueState = {
		root: HTMLElement;
		cfg: DialogueConfig;
		mode: "intro" | "topic" | "menu";
		topicIndex: number;
		lineIndex: number;
		lines: DialogueLine[];
		typing: boolean;
		auto: boolean;
		typeTimer: number | null;
		autoTimer: number | null;
		started: boolean;
		els: {
			box: HTMLElement;
			name: HTMLElement;
			text: HTMLElement;
			menu: HTMLElement;
			body: HTMLElement;
			footer: HTMLElement | null;
			advance: HTMLElement | null;
			advanceLabel: HTMLElement | null;
			autoBtn: HTMLElement | null;
			trigger: HTMLElement | null;
		};
	};

	let dialogue: DialogueState | null = null;

	function clearDialogueTimers(state: DialogueState) {
		if (state.typeTimer !== null) {
			window.clearTimeout(state.typeTimer);
			state.typeTimer = null;
		}
		if (state.autoTimer !== null) {
			window.clearTimeout(state.autoTimer);
			state.autoTimer = null;
		}
	}

	function setDialogueName(state: DialogueState, speaker?: "host" | "visitor") {
		const key = speaker === "visitor" ? "visitor" : "host";
		state.els.name.textContent = state.cfg.speakers[key] || "";
		state.els.box.dataset.speaker = key;
	}

	// \u9010\u5B57\u6253\u5B57\u673A\uFF1B\u6253\u5B8C\u56DE\u8C03
	function typeDialogueLine(state: DialogueState, line: DialogueLine) {
		clearDialogueTimers(state);
		setDialogueName(state, line.speaker);
		state.els.menu.hidden = true;
		state.els.text.hidden = false;
		state.els.text.textContent = "";
		state.typing = true;
		state.els.box.dataset.typing = "true";

		const chars = Array.from(line.text);
		let index = 0;
		const step = () => {
			if (!dialogue || dialogue !== state) return;
			if (index >= chars.length) {
				state.typing = false;
				state.els.box.dataset.typing = "false";
				state.typeTimer = null;
				onDialogueLineDone(state);
				return;
			}
			state.els.text.textContent += chars[index];
			index += 1;
			state.typeTimer = window.setTimeout(step, state.cfg.typingSpeed);
		};
		step();
	}

	// \u7ACB\u5373\u8865\u5168\u5F53\u524D\u53E5\uFF08\u6253\u5B57\u4E2D\u70B9\u51FB\uFF09
	function finishTyping(state: DialogueState) {
		if (!state.typing) return;
		clearDialogueTimers(state);
		state.els.text.textContent = state.lines[state.lineIndex]?.text ?? "";
		state.typing = false;
		state.els.box.dataset.typing = "false";
		onDialogueLineDone(state);
	}

	function onDialogueLineDone(state: DialogueState) {
		const isLast = state.lineIndex >= state.lines.length - 1;
		if (state.els.advanceLabel) {
			state.els.advanceLabel.textContent = isLast ? "\u9009\u62E9\u8BDD\u9898" : "\u4E0B\u4E00\u53E5";
		}
		if (state.els.footer) state.els.footer.dataset.end = isLast ? "true" : "false";
		if (state.auto) {
			state.autoTimer = window.setTimeout(() => {
				if (dialogue === state) advanceDialogue(state);
			}, state.cfg.autoDelay);
		}
	}

	// \u6E32\u67D3\u8BDD\u9898\u83DC\u5355
	function showDialogueMenu(state: DialogueState) {
		clearDialogueTimers(state);
		state.mode = "menu";
		state.typing = false;
		state.els.box.dataset.typing = "false";
		setDialogueName(state, "host");
		state.els.text.textContent = state.cfg.menuTitle;
		state.els.menu.innerHTML = "";
		state.cfg.topics.forEach((topic, i) => {
			const li = document.createElement("li");
			const btn = document.createElement("button");
			btn.type = "button";
			btn.className = "home-hero__dialogue-menu-item";
			btn.textContent = topic.title;
			btn.addEventListener("click", (event) => {
				event.stopPropagation();
				enterDialogueTopic(state, i);
			});
			li.appendChild(btn);
			state.els.menu.appendChild(li);
		});
		state.els.menu.hidden = state.cfg.topics.length === 0;
		if (state.els.advanceLabel) state.els.advanceLabel.textContent = "\u4E0B\u4E00\u53E5";
		if (state.els.footer) state.els.footer.dataset.end = "false";
	}

	function enterDialogueTopic(state: DialogueState, topicIndex: number) {
		const topic = state.cfg.topics[topicIndex];
		if (!topic) return;
		state.mode = "topic";
		state.topicIndex = topicIndex;
		state.lineIndex = 0;
		state.lines = topic.lines;
		state.els.menu.hidden = true;
		typeDialogueLine(state, state.lines[0]);
	}

	function playDialogueLine(state: DialogueState, index: number) {
		state.lineIndex = index;
		typeDialogueLine(state, state.lines[index]);
	}

	// \u63A8\u8FDB\uFF1A\u6253\u5B57\u4E2D\u2192\u8865\u5168\uFF1B\u5426\u5219\u2192\u4E0B\u4E00\u53E5/\u8FDB\u83DC\u5355
	function advanceDialogue(state: DialogueState) {
		if (state.mode === "menu") return;
		if (state.typing) {
			finishTyping(state);
			return;
		}
		if (state.lineIndex < state.lines.length - 1) {
			playDialogueLine(state, state.lineIndex + 1);
		} else {
			showDialogueMenu(state);
		}
	}

	// \u8FD4\u56DE\u4E0A\u4E00\u53E5\uFF1B\u9996\u53E5\u65F6\u56DE\u5230\u8BDD\u9898\u83DC\u5355
	function backDialogue(state: DialogueState) {
		if (state.mode === "menu") return;
		if (state.lineIndex > 0) {
			playDialogueLine(state, state.lineIndex - 1);
			return;
		}
		if (state.mode === "topic") {
			showDialogueMenu(state);
		} else {
			// intro \u9996\u53E5\uFF1A\u91CD\u65B0\u64AD\u653E\u5F53\u524D\u53E5
			playDialogueLine(state, 0);
		}
	}

	function toggleDialogueAuto(state: DialogueState) {
		state.auto = !state.auto;
		state.els.autoBtn?.setAttribute("aria-pressed", String(state.auto));
		state.els.box.dataset.auto = String(state.auto);
		if (state.auto && !state.typing && state.mode !== "menu") {
			onDialogueLineDone(state);
		} else if (!state.auto && state.autoTimer !== null) {
			window.clearTimeout(state.autoTimer);
			state.autoTimer = null;
		}
	}

	function setDialogueHidden(state: DialogueState, hidden: boolean) {
	state.root.dataset.hidden = String(hidden);
	// 名牌（B站徽章）作为收起后的唤出触发器
	if (state.els.trigger) {
		state.els.trigger.classList.toggle("home-hero__name-badge--dialogue-trigger", hidden);
		state.els.trigger.setAttribute("aria-expanded", String(!hidden));
	}
	if (hidden && state.autoTimer !== null) {
		window.clearTimeout(state.autoTimer);
		state.autoTimer = null;
	}
	// 立即同步雨滴撞击边缘，避免隐藏/展开后仍在旧位置溅水
	const hero = document.getElementById("home-hero");
	if (hero) collectRainEdges(hero);
}

	function startDialogue(state: DialogueState) {
		if (state.started) return;
		state.started = true;
		if (state.cfg.intro.length > 0) {
			state.mode = "intro";
			state.lines = state.cfg.intro;
			playDialogueLine(state, 0);
		} else {
			showDialogueMenu(state);
		}
	}

	function initDialogue() {
		const root = document.getElementById("hero-dialogue");
		if (!root) return;

		let cfg: DialogueConfig | null = null;
		try {
			if (root.dataset.dialogue) cfg = JSON.parse(root.dataset.dialogue) as DialogueConfig;
		} catch {
			cfg = null;
		}
		if (!cfg) return;

		const box = root.querySelector<HTMLElement>("[data-dialogue-box]");
		const name = root.querySelector<HTMLElement>("[data-dialogue-name]");
		const text = root.querySelector<HTMLElement>("[data-dialogue-text]");
		const menu = root.querySelector<HTMLElement>("[data-dialogue-menu]");
		const body = root.querySelector<HTMLElement>("[data-dialogue-click]");
		if (!box || !name || !text || !menu || !body) return;

		destroyDialogue();

		const state: DialogueState = {
			root,
			cfg,
			mode: "intro",
			topicIndex: 0,
			lineIndex: 0,
			lines: cfg.intro,
			typing: false,
			auto: false,
			typeTimer: null,
			autoTimer: null,
			started: false,
			els: {
				box,
				name,
				text,
				menu,
				body,
				footer: root.querySelector<HTMLElement>(".home-hero__dialogue-footer"),
				advance: root.querySelector<HTMLElement>("[data-dialogue-advance]"),
				advanceLabel: root.querySelector<HTMLElement>("[data-dialogue-advance-label]"),
				autoBtn: root.querySelector<HTMLElement>('[data-dialogue-action="auto"]'),
				trigger: document.querySelector<HTMLElement>(".home-hero__name-badge"),
			},
		};
		dialogue = state;

		// \u6B63\u6587\u533A\u57DF\u70B9\u51FB\u63A8\u8FDB\uFF08\u907F\u5F00\u83DC\u5355\u6309\u94AE\uFF09
		body.addEventListener("click", () => advanceDialogue(state));
		state.els.advance?.addEventListener("click", (event) => {
			event.stopPropagation();
			advanceDialogue(state);
		});
		root.querySelector('[data-dialogue-action="back"]')?.addEventListener("click", () => backDialogue(state));
		state.els.autoBtn?.addEventListener("click", () => toggleDialogueAuto(state));
		root.querySelector('[data-dialogue-action="hide"]')?.addEventListener("click", () => setDialogueHidden(state, true));
		// \u70B9\u51FB\u540D\u724C\uFF08B\u7AD9\u5FBD\u7AE0\uFF09\uFF1A\u4EC5\u5728\u5DF2\u6536\u8D77\u65F6\u5524\u51FA\u5BF9\u8BDD\u6846
		state.els.trigger?.addEventListener("click", () => {
			if (state.root.dataset.hidden === "true") setDialogueHidden(state, false);
		});

		setDialogueName(state, "host");
		setDialogueHidden(state, false);
	}

	function destroyDialogue() {
		if (dialogue) {
			clearDialogueTimers(dialogue);
			dialogue = null;
		}
	}

	// ============================================
	// 标题 Hatching Shader 效果
	// ============================================
	async function initHeroHatch(heroTitleReady: Promise<void>, token: number) {
		const nameEl = document.querySelector<HTMLElement>(".home-hero__name");
		if (!nameEl) return;
		// 移动端大标题同样呈现铅笔（Hatching）动效，仅在明确减弱动效时跳过
		if (prefersReducedMotion()) return;

		await heroTitleReady;

		// 再次检查元素是否仍在 DOM（Swup 可能已切走页面）
		if (token !== initToken || !document.contains(nameEl)) return;

		destroyHeroHatch();

		// VFX canvas 默认 z-index 为 9999 且挂载到 document.body，会盖住弹窗与浮动组件。
		// 这里把 canvas 挂到 hero 内部（hero 已 isolation: isolate），并降低 z-index 到 hero 内部层级。
		const heroEl = document.getElementById("home-hero") ?? undefined;
		const vfx = VFX.init({
			pixelRatio: Math.min(window.devicePixelRatio, 1.5),
			zIndex: 10,
			wrapper: heroEl,
		});
		if (!vfx) return;
		vfxInstance = vfx;

		heroHatchEffect = new HatchEffect({
			color: "#ffffff",
			angle: 45,
			spacing: 2.5,
			lineWidth: 2,
			angleJitter: 0.5,
			offsetJitter: 2,
			spacingJitter: 0.5,
			seed: 0,
			speed: 8,
			roundCap: true,
			soft: 0,
			originalColor: true,
			bypass: false,
		});

		try {
			await vfx.addHTML(nameEl, { effect: heroHatchEffect });
		} catch { /* ignore */ }
	}

	function destroyHeroHatch() {
		if (vfxInstance) {
			const nameEl = document.querySelector<HTMLElement>(".home-hero__name");
			if (nameEl) {
				try { vfxInstance.remove(nameEl); } catch { /* ignore */ }
			}
		}
		if (heroHatchEffect) {
			heroHatchEffect.dispose();
			heroHatchEffect = null;
		}
		if (vfxInstance) {
			vfxInstance.destroy();
			vfxInstance = null;
		}
	}

	// ============================================
	// 玻璃雨珠 + 撞击水花（Canvas 2D）
	// ============================================
	// 解析配置色为 "r, g, b" 字符串；无法解析或留空时返回 null（走主题自动取色）
	function parseRainColor(raw: string): string | null {
		const value = raw.trim();
		if (!value) return null;
		// "r,g,b" / "r, g, b"
		const parts = value.split(",").map((n) => Number.parseInt(n.trim(), 10));
		if (parts.length === 3 && parts.every((n) => Number.isFinite(n) && n >= 0 && n <= 255)) {
			return parts.join(", ");
		}
		// "#rgb" / "#rrggbb"
		let hex = value.replace(/^#/, "");
		if (hex.length === 3) hex = hex.split("").map((c) => c + c).join("");
		if (hex.length === 6 && /^[0-9a-fA-F]{6}$/.test(hex)) {
			const r = Number.parseInt(hex.slice(0, 2), 16);
			const g = Number.parseInt(hex.slice(2, 4), 16);
			const b = Number.parseInt(hex.slice(4, 6), 16);
			return `${r}, ${g}, ${b}`;
		}
		return null;
	}

	function rainStroke() {
		// 已配置固定颜色则优先使用
		if (rainColorRgb) return rainColorRgb;
		// 否则：暗色主题用白色雨珠，浅色主题用深灰，随主题实时取色
		return document.documentElement.classList.contains("dark")
			? "255, 255, 255"
			: "70, 78, 90";
	}

	function isRainEdgeVisible(el: HTMLElement, hero: HTMLElement): boolean {
	if (!document.contains(el)) return false;
	let current: HTMLElement | null = el;
	while (current && current !== hero) {
		const style = window.getComputedStyle(current);
		if (style.display === "none" || style.visibility === "hidden") {
			return false;
		}
		current = current.parentElement;
	}
	// 对 galgame 对话框额外判断 data-hidden，确保 transition 期间也立即生效
	const dialogueRoot = el.closest(".home-hero__dialogue");
	if (dialogueRoot && dialogueRoot.getAttribute("data-hidden") === "true") {
		return false;
	}
	return true;
}

function collectRainEdges(hero: HTMLElement) {
	const heroRect = hero.getBoundingClientRect();
	const edges: HitEdge[] = [];
	const selectors = [
		".home-hero__viewfinder-corner",
		".home-hero__dialogue-box",
	];
	for (const selector of selectors) {
		hero.querySelectorAll<HTMLElement>(selector).forEach((el) => {
			if (!isRainEdgeVisible(el, hero)) return;
			const rect = el.getBoundingClientRect();
			if (rect.width < 2 || rect.height < 2) return;
			// 以元素顶边作为"撞击线"
			edges.push({
				x1: rect.left - heroRect.left,
				x2: rect.right - heroRect.left,
				y: rect.top - heroRect.top,
			});
		});
	}
	rainEdges = edges;
}

	function spawnSplash(x: number, y: number) {
		// 克制：全局水花粒子上限，避免同帧爆量
		if (rainSplashes.length > 90) return;
		const count = 6 + Math.floor(vfxRand() * 4);
		for (let i = 0; i < count; i++) {
			const angle = -Math.PI / 2 + (vfxRand() - 0.5) * 1.9;
			const speed = 1.1 + vfxRand() * 2.2;
			rainSplashes.push({
				x,
				y,
				vx: Math.cos(angle) * speed,
				vy: Math.sin(angle) * speed,
				life: 0,
				maxLife: 22 + Math.floor(vfxRand() * 16),
				r: 0.8 + vfxRand() * 1.1,
			});
		}
	}

	// 轻量伪随机（避免依赖 Math.random 的语义，仅用于视觉抖动）
	let vfxSeed = 20260710;
	function vfxRand() {
		vfxSeed = (vfxSeed * 1664525 + 1013904223) % 4294967296;
		return vfxSeed / 4294967296;
	}

	function makeDrop(w: number, h: number, fromTop: boolean): RainDrop {
		return {
			x: vfxRand() * w,
			y: fromTop ? -vfxRand() * h * 0.5 : vfxRand() * h,
			r: 0.9 + vfxRand() * 1.4,
			vy: 2.4 + vfxRand() * 3.2,
			len: 9 + vfxRand() * 16,
			alpha: 0.12 + vfxRand() * 0.2,
		};
	}

	function initHeroRain() {
		const hero = document.getElementById("home-hero");
		if (!hero) return;
		if (prefersReducedMotion() || isMobile()) return;

		let cfg = { enabled: true, intensity: 0.6, color: "" };
		try {
			if (hero.dataset.heroRain) cfg = { ...cfg, ...JSON.parse(hero.dataset.heroRain) };
		} catch {
			// 配置损坏时使用默认值
		}
		if (!cfg.enabled) return;
		rainIntensity = Math.max(0, Math.min(1, cfg.intensity));
		rainColorRgb = parseRainColor(cfg.color || "");

		destroyHeroRain();

		const canvas = document.createElement("canvas");
		canvas.className = "home-hero__rain-canvas";
		canvas.setAttribute("aria-hidden", "true");
		hero.appendChild(canvas);
		const ctx = canvas.getContext("2d");
		if (!ctx) {
			canvas.remove();
			return;
		}
		rainCanvas = canvas;
		rainCtx = ctx;
		rainDpr = Math.min(window.devicePixelRatio || 1, 1.5);

		function resize() {
			if (!rainCanvas || !rainCtx || !hero) return;
			const rect = hero.getBoundingClientRect();
			rainCanvas.width = Math.round(rect.width * rainDpr);
			rainCanvas.height = Math.round(rect.height * rainDpr);
			rainCtx.setTransform(rainDpr, 0, 0, rainDpr, 0, 0);
			// 雨滴数量随强度与画面宽度缩放（克制上限 ~60）
			const target = Math.round((20 + rainIntensity * 40) * Math.min(1, rect.width / 1280));
			rainDrops = Array.from({ length: target }, () => makeDrop(rect.width, rect.height, false));
			collectRainEdges(hero);
		}
		resize();
		rainResizeHandler = resize;
		window.addEventListener("resize", resize);
		rainEdgeTimer = window.setInterval(() => collectRainEdges(hero), 500);

		function frame() {
			if (!rainCanvas || !rainCtx) return;
			const w = rainCanvas.width / rainDpr;
			const h = rainCanvas.height / rainDpr;
			rainCtx.clearRect(0, 0, w, h);
			const rgb = rainStroke();

			// 雨珠 + 水痕拖尾
			for (const d of rainDrops) {
				const prevY = d.y;
				d.y += d.vy;

				// 撞击检测：穿过某条撞击线且落在其 x 区间内
				let consumed = false;
				for (const e of rainEdges) {
					if (prevY < e.y && d.y >= e.y && d.x >= e.x1 && d.x <= e.x2) {
						spawnSplash(d.x, e.y);
						d.y = -vfxRand() * 40;
						d.x = vfxRand() * w;
						consumed = true;
						break;
					}
				}
				// 落到底部地面同样迸溅水花
				if (!consumed && prevY < h && d.y >= h) {
					spawnSplash(d.x, h - 1);
					d.y = -vfxRand() * 40;
					d.x = vfxRand() * w;
				}

				// 竖向水痕
				rainCtx.strokeStyle = `rgba(${rgb}, ${d.alpha})`;
				rainCtx.lineWidth = d.r;
				rainCtx.beginPath();
				rainCtx.moveTo(d.x, d.y - d.len);
				rainCtx.lineTo(d.x, d.y);
				rainCtx.stroke();
				// 珠头高光
				rainCtx.fillStyle = `rgba(${rgb}, ${Math.min(0.5, d.alpha + 0.18)})`;
				rainCtx.beginPath();
				rainCtx.arc(d.x, d.y, d.r * 0.9, 0, Math.PI * 2);
				rainCtx.fill();
			}

			// 水花：扇形迸溅 + 重力回落 + 快速淡出
			for (let i = rainSplashes.length - 1; i >= 0; i--) {
				const p = rainSplashes[i];
				p.life++;
				p.vy += 0.16; // 重力
				p.x += p.vx;
				p.y += p.vy;
				const t = 1 - p.life / p.maxLife;
				if (t <= 0) {
					rainSplashes.splice(i, 1);
					continue;
				}
				rainCtx.fillStyle = `rgba(${rgb}, ${0.4 * t})`;
				rainCtx.beginPath();
				rainCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
				rainCtx.fill();
			}

			rainRaf = requestAnimationFrame(frame);
		}
		rainRaf = requestAnimationFrame(frame);
	}

	function destroyHeroRain() {
		if (rainRaf) {
			cancelAnimationFrame(rainRaf);
			rainRaf = 0;
		}
		if (rainEdgeTimer) {
			window.clearInterval(rainEdgeTimer);
			rainEdgeTimer = 0;
		}
		if (rainResizeHandler) {
			window.removeEventListener("resize", rainResizeHandler);
			rainResizeHandler = null;
		}
		if (rainCanvas) {
			rainCanvas.remove();
			rainCanvas = null;
		}
		rainCtx = null;
		rainDrops = [];
		rainSplashes = [];
		rainEdges = [];
	}

	// ============================================
	// 初始化与清理（Swup 兼容）
	// ============================================
	function initHeroOpening() {
		const hero = document.getElementById("home-hero");
		if (!hero) return Promise.resolve();
		if (prefersReducedMotion() || isMobile()) {
			hero.classList.remove("home-hero--motion-pending");
			hero.classList.add("home-hero--motion-ready");
			// 无入场动画时立即开始对话
			if (dialogue) startDialogue(dialogue);
			return Promise.resolve();
		}

		const occupation = hero.querySelector(".home-hero__occupation");
		const badge = hero.querySelector(".home-hero__name-badge");
		const speech = hero.querySelector(".home-hero__dialogue-box");
		const rightPanel = hero.querySelector(".home-hero__right-panel");
		const focusFrame = hero.querySelector(".home-hero__focus-frame");
		const viewfinderCorners = hero.querySelectorAll(".home-hero__viewfinder-corner");
		const focusDot = hero.querySelector(".home-hero__focus-dot");
		const cameraParams = hero.querySelector(".home-hero__camera-params");

		hero.classList.add("home-hero--motion-ready");

		// 大标题（名字）不参与进场动画，默认直接呈现铅笔（Hatching）动效 → 立即就绪
		const heroTitleReady = Promise.resolve();

		heroOpeningTimeline = gsap.timeline({
			defaults: { ease: "power4.out" },
		});

		heroOpeningTimeline
			// 1. 外四角取景框依次展开
			.fromTo(viewfinderCorners, {
				autoAlpha: 0,
				scale: 0.3,
			}, {
				autoAlpha: 1,
				scale: 1,
				duration: 0.7,
				stagger: 0.08,
				ease: "expo.out",
			}, 0.1)
			// 2. 中心对焦框从放大到锁定
			.fromTo(focusFrame, {
				autoAlpha: 0,
				scale: 1.7,
			}, {
				autoAlpha: 1,
				scale: 1,
				duration: 0.85,
				ease: "expo.out",
			}, 0.45)
			.to(focusFrame, {
				scale: 0.9,
				duration: 0.2,
				ease: "power2.inOut",
			}, "-=0.1")
			.to(focusFrame, {
				scale: 1,
				duration: 0.28,
				ease: "power2.out",
			})
			// 3. 中心焦点闪烁出现
			.fromTo(focusDot, {
				autoAlpha: 0,
				scale: 0,
			}, {
				autoAlpha: 1,
				scale: 1,
				duration: 0.25,
				ease: "back.out(2.5)",
			}, "-=0.05")
			// 4. 拍摄参数面板滑入
			.fromTo(cameraParams, {
				autoAlpha: 0,
				x: -16,
			}, {
				autoAlpha: 1,
				x: 0,
				duration: 0.6,
				ease: "expo.out",
			}, 0.95)
			.fromTo(occupation, {
				autoAlpha: 0,
				y: 48,
			}, {
				autoAlpha: 1,
				y: 0,
				duration: 0.92,
				ease: "expo.out",
			}, 0.82)
			.fromTo(badge, {
				autoAlpha: 0,
				y: 18,
				scale: 0.7,
			}, {
				autoAlpha: 1,
				y: 0,
				scale: 1,
				duration: 0.78,
				ease: "expo.out",
			}, 1.34)
			.fromTo(rightPanel, {
				autoAlpha: 0,
				x: 60,
			}, {
				autoAlpha: 1,
				x: 0,
				duration: 0.95,
				ease: "power3.out",
			}, 1.66)
			.fromTo(speech, {
				autoAlpha: 0,
				y: 34,
				scale: 0.92,
				filter: "blur(10px)",
				transformOrigin: "50% 100%",
			}, {
				autoAlpha: 1,
				y: 0,
				scale: 1,
				filter: "blur(0px)",
				duration: 0.92,
				ease: "expo.out",
				clearProps: "filter",
				onComplete: () => {
					// 对话框入场完成后开始逐句打字
					if (dialogue) startDialogue(dialogue);
				},
			}, 2.12);

		hero.classList.remove("home-hero--motion-pending");
		return heroTitleReady;
	}

	function initHomeScrollMotion() {
		if (prefersReducedMotion() || isMobile()) {
			document.querySelector(".home-page--motion-pending")?.classList.remove("home-page--motion-pending");
			return;
		}

		const sections = Array.from(document.querySelectorAll<HTMLElement>(
			".home-page > :not(#home-hero), .home-pending-layer",
		)).filter((section, index, list) => list.indexOf(section) === index);

		sections.forEach((section, index) => {
			const title = section.querySelector(".home-section-title, [data-motion-title]");
			const cards = section.querySelectorAll(".card-base, .post-card-wrapper, .home-pending, .stats-container, [data-motion-card]");
			const images = section.querySelectorAll(
				"img[data-home-motion-image]:not([data-shutter-image]):not([data-shutter-final-midground]):not([data-shutter-final-foreground]), [data-home-motion-image]:not([data-shutter-image]):not([data-shutter-final-midground]):not([data-shutter-final-foreground])",
			);
			if (!title && cards.length === 0 && images.length === 0) return;

			const tl = gsap.timeline({
				scrollTrigger: {
					id: `home-motion-section-${index}`,
					trigger: section,
					start: "top 78%",
					once: true,
				},
				defaults: { ease: "power4.out" },
			});

			if (title) {
				tl.fromTo(title, {
					autoAlpha: 0,
					y: 110,
					scale: 0.82,
					clipPath: "inset(0 0 100% 0)",
				}, {
					autoAlpha: 1,
					y: 0,
					scale: 1,
					clipPath: "inset(0 0 0% 0)",
					duration: 1.05,
					ease: "expo.out",
				});
			}

			if (cards.length > 0) {
				tl.fromTo(cards, {
					autoAlpha: 0,
					y: 86,
					rotateX: 12,
					filter: "blur(12px)",
					transformOrigin: "50% 100%",
				}, {
					autoAlpha: 1,
					y: 0,
					rotateX: 0,
					filter: "blur(0px)",
					duration: 1.05,
					stagger: 0.12,
					ease: "expo.out",
				}, title ? "-=0.38" : 0);
			}

			if (images.length > 0) {
				tl.fromTo(images, {
					clipPath: "inset(0 0 100% 0)",
					scale: 1.1,
				}, {
					clipPath: "inset(0 0 0% 0)",
					scale: 1,
					duration: 1.18,
					stagger: 0.1,
					ease: "expo.out",
				}, "-=0.74");

				images.forEach((image, imageIndex) => {
					gsap.to(image, {
						yPercent: -5,
						ease: "none",
						scrollTrigger: {
							id: `home-motion-image-${index}-${imageIndex}`,
							trigger: image,
							start: "top bottom",
							end: "bottom top",
							scrub: 0.9,
						},
					});
				});
			}
		});

		document.querySelector(".home-page--motion-pending")?.classList.remove("home-page--motion-pending");
	}

	// ============================================
	// 上下班头像与状态牌
	// ============================================
	function initWorkStatus() {
		if (workStatusTimer) {
			window.clearInterval(workStatusTimer);
			workStatusTimer = null;
		}

		const hero = document.getElementById("home-hero");
		const avatar = document.getElementById("hero-avatar") as HTMLImageElement | null;
		const badge = document.getElementById("work-status");
		const statusText = badge?.querySelector(".home-hero__status-text");
		const verticalStatus = document.getElementById("hero-work-status-vertical");
		if (!hero || !avatar || !badge || !statusText) return;
		const heroEl = hero;
		const avatarEl = avatar;
		const badgeEl = badge;
		const statusTextEl = statusText;

		const workHoursData = heroEl.dataset.workHours;
		let workHours = { start: 9, end: 18, workDays: [1, 2, 3, 4, 5] };
		if (workHoursData) {
			try {
				workHours = JSON.parse(workHoursData);
			} catch {
				// Keep defaults when config data is malformed.
			}
		}

		function updateStatus() {
			const now = new Date();
			const hour = now.getHours() + now.getMinutes() / 60;
			const day = now.getDay();
			const isWorkday = workHours.workDays.includes(day);
			const isWorking = isWorkday && hour >= workHours.start && hour < workHours.end;
			const nextAvatar = isWorking
				? heroEl.dataset.avatar
				: heroEl.dataset.avatarOff;

			if (nextAvatar && avatarEl.getAttribute("src") !== nextAvatar) {
				avatarEl.setAttribute("src", nextAvatar);
			}
			statusTextEl.textContent = isWorking ? "上班中" : "下班";
			badgeEl.classList.toggle("is-off-work", !isWorking);

			if (verticalStatus) {
				verticalStatus.textContent = isWorking ? "WORKING" : "OFF WORK";
				verticalStatus.classList.toggle("is-working", isWorking);
			}
		}

		updateStatus();
		workStatusTimer = window.setInterval(updateStatus, 60_000);
	}

	function destroyWorkStatus() {
		if (workStatusTimer) {
			window.clearInterval(workStatusTimer);
			workStatusTimer = null;
		}
	}

	// ============================================
	// 初始化与清理（Swup 兼容）
	// ============================================
	let initToken = 0;

	function init() {
		cleanup();
		const token = initToken;
		initDialogue();
		const heroOpeningReady = initHeroOpening();
		initWorkStatus();
		void initHeroHatch(heroOpeningReady, token);

		// 推迟 ScrollTrigger 初始化，避免阻塞 Hero 入场动画的首次渲染
		requestAnimationFrame(() => {
			initHomeScrollMotion();
			initHeroRain();
		});
	}

	function cleanup() {
		killHomeMotion();
		destroyWorkStatus();
		destroyHeroHatch();
		destroyHeroRain();
		destroyDialogue();
	}

	async function scheduleHomeInit() {
		++initToken;
		cleanup();
		if (!document.getElementById("home-hero")) return;

		await waitForPageLoaderHidden();
		if (!document.getElementById("home-hero")) return;

		init();
	}

	// 首次初始化：等页面加载遮罩完全撤掉后再播放首页入场
	void scheduleHomeInit();

	// Swup 兼容：使用 astro:page-load（每次导航完成触发）
	document.addEventListener("astro:page-load", () => {
		const hero = document.getElementById("home-hero");
		if (hero) {
			void scheduleHomeInit();
		} else {
			initToken += 1;
			cleanup();
		}
	});
</script>
