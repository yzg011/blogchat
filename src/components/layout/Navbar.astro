---
import { Picture } from "astro:assets";
import * as path from "node:path";
import Icon from "@components/common/Icon.astro";
import type { ImageMetadata } from "astro";
import GlassSurface from "@/components/common/GlassSurface.svelte";
import LightDarkSwitch from "@/components/controls/LightDarkSwitch.svelte";
import { navBarConfig, siteConfig } from "@/config";
import { LinkPresets } from "@/constants/link-presets";
import { getFallbackFormat, getImageFormats } from "@/utils/image-utils";
import { url } from "@/utils/url-utils";
import DropdownMenu from "./DropdownMenu.astro";

const className = Astro.props.class;

const navbarTitle = siteConfig.navbar.title || siteConfig.title;
void siteConfig.navbar.widthFull;

let links = navBarConfig.links.map((item) => {
	if (typeof item === "number") return LinkPresets[item];
	return item;
});

const logoValue = siteConfig.navbar.logo?.value || "";
const isLocalSrcLogo =
	siteConfig.navbar.logo?.type === "image" &&
	logoValue &&
	!logoValue.startsWith("/") &&
	!logoValue.startsWith("http");
let logoImg: ImageMetadata | null = null;

if (isLocalSrcLogo) {
	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,webp,avif,gif,svg}",
		{ import: "default" },
	);
	const normalizedPath = path
		.normalize(path.join("../../", logoValue))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (file) logoImg = await file();
}
---

<div id="navbar" class="z-50">
    <div class:list={[className, "navbar-pill relative"]}>
        <div class="navbar-glass-layer absolute inset-0 z-0 opacity-0 transition-opacity duration-500 pointer-events-none">
            <GlassSurface
                client:load
                width="100%"
                height="100%"
                borderRadius={50}
                backgroundOpacity={0.15}
                saturation={1}
                borderWidth={0.05}
                brightness={50}
                opacity={1}
                blur={7}
                displace={0.5}
                distortionScale={-220}
                redOffset={0}
                greenOffset={5}
                blueOffset={10}
            />
        </div>
        <div class="navbar-inner relative z-10" data-nav-body>
            <a href={url('/')} class="navbar-logo scale-animation flex items-center text-(--deep-text)">
                {siteConfig.navbar.logo?.type === "icon" ? (
                    <Icon name={siteConfig.navbar.logo.value || "material-symbols:home-pin-outline"} is:inline class="text-[1.5rem] mr-2 flex-shrink-0" />
                ) : siteConfig.navbar.logo?.type === "image" && logoImg ? (
                    <Picture
                        src={logoImg}
                        alt={siteConfig.navbar.logo.alt || siteConfig.title}
                        class="h-7 w-7 mr-2 object-contain flex-shrink-0"
                        formats={getImageFormats()}
                        fallbackFormat={getFallbackFormat()}
                        widths={[28, 56]}
                        loading="eager"
                        fetchpriority="high"
                    />
                ) : siteConfig.navbar.logo?.type === "image" ? (
                    <img src={url(siteConfig.navbar.logo.value)} alt={siteConfig.navbar.logo.alt || siteConfig.title} class="h-7 w-7 mr-2 object-contain flex-shrink-0" fetchpriority="high" />
                ) : siteConfig.navbar.logo?.type === "url" ? (
                    <img src={siteConfig.navbar.logo.value} alt={siteConfig.navbar.logo.alt || siteConfig.title} class="h-7 w-7 mr-2 object-contain flex-shrink-0" fetchpriority="high" />
                ) : (
                    <Icon name="material-symbols:home-pin-outline" is:inline class="text-[1.5rem] mr-2 flex-shrink-0" />
                )}
                <span class="navbar-logo-text font-mono uppercase tracking-[0.15em] text-sm font-semibold ml-1">{navbarTitle}</span>
            </a>

            <div class="navbar-nav hidden lg:flex items-center gap-1 relative" data-navbar-nav>
                <div class="navbar-hover-border" data-hover-border></div>
                {links.map((l) => <DropdownMenu link={l} />)}
            </div>

            <div class="navbar-right flex items-center gap-1">
                <LightDarkSwitch client:load />
                <button aria-label="Menu" name="Nav Menu" class="btn-plain h-11 w-11 lg:hidden!" id="nav-menu-switch">
                    <Icon name="material-symbols:menu-rounded" is:inline class="text-[1.25rem]"></Icon>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    @reference "../../styles/main.css";

    /* ── pill 容器内边距 ── */
    .navbar-pill {
        padding: 0.5rem 0.75rem;
        /* 统一管理所有过渡，scoped style 优先级高于外部 CSS，确保不被覆盖 */
        transition:
            width 0.55s cubic-bezier(0.22, 1, 0.36, 1),
            max-width 0.55s cubic-bezier(0.22, 1, 0.36, 1),
            border-radius 0.55s cubic-bezier(0.22, 1, 0.36, 1),
            padding 0.55s cubic-bezier(0.22, 1, 0.36, 1),
            background-color 0.36s cubic-bezier(0.22, 1, 0.36, 1),
            border-color 0.36s cubic-bezier(0.22, 1, 0.36, 1),
            box-shadow 0.36s cubic-bezier(0.22, 1, 0.36, 1),
            backdrop-filter 0.36s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* 滚动后内边距收紧 */
    :global(#navbar.scrolled) .navbar-pill {
        padding: 0.35rem 0.5rem;
    }

    /* 移动端：简化 pill 过渡，减少复合开销 */
    @media (max-width: 1023px) {
        .navbar-pill {
            transition:
                width 0.45s cubic-bezier(0.22, 1, 0.36, 1),
                max-width 0.45s cubic-bezier(0.22, 1, 0.36, 1),
                border-radius 0.45s cubic-bezier(0.22, 1, 0.36, 1),
                padding 0.45s cubic-bezier(0.22, 1, 0.36, 1),
                background-color 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.05s,
                border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.05s,
                box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.05s,
                backdrop-filter 0.25s ease 0.2s;
            will-change: width, max-width, border-radius, padding, background-color, box-shadow;
            transform: translateZ(0);
            -webkit-transform: translateZ(0);
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }
    }

    /* ── 内层 flex 行 ── */
    .navbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        max-width: var(--page-width, 1200px);
        margin-inline: auto;
        padding: 0.25rem 0.75rem;
        position: relative;
    }

    :global(#navbar.scrolled) .navbar-inner {
        padding: 0.2rem 0.5rem;
    }

    /* ── Logo ── */
    .navbar-logo {
        display: flex;
        align-items: center;
        height: 2.75rem;
        padding: 0 0.5rem;
        font-weight: 600;
        position: relative;
        z-index: 10;
        flex-shrink: 0;
        text-decoration: none;
        color: var(--deep-text);
    }
    .navbar-logo::before {
        background-color: transparent !important;
        scale: 0.85;
    }
    .navbar-logo:hover::before {
        background-color: transparent !important;
    }

    /* logo 图片：暗黑主题下反转为白色 */
    .navbar-logo img,
    .navbar-logo picture img {
        transition: filter 0.3s ease;
    }
    :root.dark .navbar-logo img,
    :root.dark .navbar-logo picture img {
        filter: invert(1);
    }

    /* logo 文字：滚动后淡出收缩 */
    .navbar-logo-text {
        display: inline-block;
        max-width: 12rem;
        overflow: hidden;
        white-space: nowrap;
        opacity: 1;
        transform: translateX(0);
        transition:
            max-width 0.55s cubic-bezier(0.22, 1, 0.36, 1),
            opacity 0.3s ease,
            transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
            margin 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    }

    :global(#navbar.scrolled) .navbar-logo-text {
        max-width: 0;
        opacity: 0;
        transform: translateX(-6px);
        margin-left: 0 !important;
    }

    /* 移动端：logo 文字使用 GPU 友好的 transform，避免 max-width 布局抖动 */
    @media (max-width: 1023px) {
        .navbar-logo-text {
            transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            will-change: transform, opacity;
        }

        :global(#navbar.scrolled) .navbar-logo-text {
            opacity: 0;
            transform: translateX(-8px) scale(0.95);
            max-width: 12rem;
            margin-left: 0 !important;
        }
    }

    /* ── 中间导航菜单 ── */
    .navbar-nav {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        display: none;
        align-items: center;
        gap: 0.25rem;
        white-space: nowrap;
        transition: gap 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @media (min-width: 1024px) {
        .navbar-nav {
            display: flex;
        }
    }

    :global(#navbar.scrolled) .navbar-nav {
        gap: 0.1rem;
    }

    /* ── 右侧工具栏 ── */
    .navbar-right {
        position: relative;
        z-index: 10;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        transition: gap 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .navbar-right :global(.btn-plain) {
        background-color: transparent !important;
    }
    .navbar-right :global(.btn-plain::before) {
        background-color: transparent !important;
        scale: 0.85;
    }
    .navbar-right :global(.btn-plain:hover::before) {
        background-color: transparent !important;
    }

    :global(#navbar.scrolled) .navbar-right {
        gap: 0.1rem;
    }

    /* ── hover 滑动边框指示器 ── */
    .navbar-hover-border {
        position: absolute;
        height: 2.5rem;
        border-radius: 9999px;
        border: 1.5px solid oklch(0.35 0 0);
        background-color: transparent;
        opacity: 0;
        transition: left 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94), width 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94), height 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94), top 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        pointer-events: none;
        z-index: 0;
    }

    :root.dark .navbar-hover-border {
        border-color: oklch(0.6 0 0);
    }

    .navbar-nav:hover .navbar-hover-border,
    .navbar-nav.nav-has-active .navbar-hover-border {
        opacity: 1;
    }

    /* 禁用各 item 自身的 expand-animation 背景 */
    .navbar-nav .dropdown-container > a::before,
    .navbar-nav .dropdown-container > button::before,
    .navbar-nav .dropdown-container > a:hover::before,
    .navbar-nav .dropdown-container > button:hover::before,
    .navbar-nav .dropdown-container > a:active::before,
    .navbar-nav .dropdown-container > button:active::before {
        background-color: transparent !important;
    }
</style>

<script>
function initHoverSlider() {
    const navContainer = document.querySelector('[data-navbar-nav]') as HTMLElement | null;
    const hoverBorder = document.querySelector('[data-hover-border]') as HTMLElement | null;

    if (!navContainer || !hoverBorder) return;

    const _navContainer = navContainer;
    const _hoverBorder = hoverBorder;
    const navItems = _navContainer.querySelectorAll(':scope > .dropdown-container');

    function detectActiveItem() {
        const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
        let hasActive = false;
        navItems.forEach((item) => {
            const link = item.querySelector('a') as HTMLAnchorElement | null;
            if (!link) return;
            const href = link.getAttribute('href')?.replace(/\/$/, '') || '/';
            if (href === currentPath || (currentPath !== '/' && currentPath.startsWith(href + '/')) || (href !== '/' && currentPath.startsWith(href))) {
                item.classList.add('nav-item-active');
                hasActive = true;
                const rect = item.getBoundingClientRect();
                const containerRect = _navContainer.getBoundingClientRect();
                _hoverBorder.style.width = `${rect.width}px`;
                _hoverBorder.style.height = `${rect.height}px`;
                _hoverBorder.style.left = `${rect.left - containerRect.left}px`;
                _hoverBorder.style.top = `${(containerRect.height - rect.height) / 2}px`;
            } else {
                item.classList.remove('nav-item-active');
            }
        });
        if (hasActive) {
            _navContainer.classList.add('nav-has-active');
        } else {
            _navContainer.classList.remove('nav-has-active');
        }
    }

    navItems.forEach((item) => {
        item.addEventListener('mouseenter', () => {
            const rect = item.getBoundingClientRect();
            const containerRect = _navContainer.getBoundingClientRect();

            _hoverBorder.style.width = `${rect.width}px`;
            _hoverBorder.style.height = `${rect.height}px`;
            _hoverBorder.style.left = `${rect.left - containerRect.left}px`;
            _hoverBorder.style.top = `${(containerRect.height - rect.height) / 2}px`;
        });
    });

    _navContainer.addEventListener('mouseleave', () => {
        const activeItem = _navContainer.querySelector('.nav-item-active') as HTMLElement | null;
        if (activeItem) {
            const rect = activeItem.getBoundingClientRect();
            const containerRect = _navContainer.getBoundingClientRect();
            _hoverBorder.style.width = `${rect.width}px`;
            _hoverBorder.style.height = `${rect.height}px`;
            _hoverBorder.style.left = `${rect.left - containerRect.left}px`;
            _hoverBorder.style.top = `${(containerRect.height - rect.height) / 2}px`;
        } else {
            _hoverBorder.style.opacity = '0';
        }
    });

    _navContainer.addEventListener('mouseenter', () => {
        _hoverBorder.style.opacity = '1';
    });

    detectActiveItem();
    document.addEventListener('swup:page:view', detectActiveItem);
}

initHoverSlider();

(function() {
    const navbar = document.getElementById('navbar');
    const navbarWrapper = document.getElementById('navbar-wrapper');
    if (!navbar) return;

    const SCROLL_IN  = 80;   // 超过此值收缩
    const SCROLL_OUT = 40;   // 低于此值展开

    let ticking = false;

    function handleScroll() {
        const y = window.scrollY;

        if (y > SCROLL_IN) {
            navbar?.classList.add('scrolled');
            navbarWrapper?.classList.add('navbar-scrolled');
        } else if (y < SCROLL_OUT) {
            navbar?.classList.remove('scrolled');
            navbarWrapper?.classList.remove('navbar-scrolled');
        }

        ticking = false;
    }

    window.addEventListener('scroll', () => {
        if (!ticking) {
            requestAnimationFrame(handleScroll);
            ticking = true;
        }
    }, { passive: true });

    handleScroll();
})();

document.addEventListener("swup:page:view", () => {
    initHoverSlider();
});
</script>

{
    import.meta.env.PROD && (
        <script is:inline data-swup-ignore-script define:vars={{ scriptUrl: url('/pagefind/pagefind.js') }}>
            async function loadPagefind() {
                try {
                    const response = await fetch(scriptUrl, { method: 'HEAD' });
                    if (!response.ok) throw new Error(`Pagefind script not found: ${response.status}`);
                    const pagefind = await import(scriptUrl);
                    await pagefind.options({ excerptLength: 20 });
                    window.pagefind = pagefind;
                    document.dispatchEvent(new CustomEvent('pagefindready'));
                } catch (error) {
                    console.error('Failed to load Pagefind:', error);
                    window.pagefind = {
                        search: () => Promise.resolve({ results: [] }),
                        options: () => Promise.resolve(),
                    };
                    document.dispatchEvent(new CustomEvent('pagefindloaderror'));
                }
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadPagefind);
            } else {
                loadPagefind();
            }
        </script>
    )
}
