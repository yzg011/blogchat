---
import { homeConfig } from "@/config";
import { normalizeShutterPanels } from "@/utils/home-portfolio-shutter.js";

const displayConfig = homeConfig.displayLayer;
const shutterConfig = homeConfig.portfolioShutter;
const panels = normalizeShutterPanels(shutterConfig.panels);
const interlude = shutterConfig.interlude;
const transparentPixel =
	"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==";
---

<section
	class="home-display-layer"
	id="home-display-layer"
	aria-hidden="true"
	data-display
	data-display-enabled={displayConfig.enabled ? "true" : "false"}
	data-shutter-enabled={shutterConfig.enabled ? "true" : "false"}
	data-scroll-distance={String(displayConfig.scrollDistance)}
	data-shutter-scroll-distance={String(shutterConfig.scrollDistance)}
	data-pillar-final-width={displayConfig.pillarFinalWidth}
	style={`--display-pillar-final-width: ${displayConfig.pillarFinalWidth};`}
>
	<div class="home-display-layer__viewport" data-display-viewport>
		{/* ===== 展示层动画元素 ===== */}
		<div class="home-display-layer__line" data-display-line></div>
		{displayConfig.emitterImage && (
			<img
				class="home-display-layer__emitter"
				data-display-emitter
				src={displayConfig.emitterImage}
				alt=""
				loading="eager"
				decoding="async"
			/>
		)}
		<div class="home-display-layer__pillar" data-display-pillar></div>
		<div class="home-display-layer__stage" data-display-stage>
			<p class="home-display-layer__kicker" data-display-kicker>{displayConfig.kicker}</p>
			<h2 class="home-display-layer__title" data-display-title>{displayConfig.title}</h2>
			<p class="home-display-layer__description" data-display-desc>{displayConfig.description}</p>
		</div>

		{/* ===== 百叶窗动画元素 ===== */}
		{/* 最终图三层组合（从后到前）：后景视频 / 中景图 / 前景人物图 */}
		<video
			class="home-portfolio-shutter__final-video"
			data-shutter-final-video
			data-src={shutterConfig.finalImage.backgroundVideo}
			muted
			loop
			playsinline
			preload="auto"
			aria-hidden="true"
		></video>
		<img
			class="home-portfolio-shutter__final-image home-portfolio-shutter__final-image--midground"
			data-shutter-final-midground
			data-src={shutterConfig.finalImage.midgroundImage}
			src={transparentPixel}
			alt={shutterConfig.finalImage.alt}
			loading="eager"
			decoding="async"
		/>
		<img
			class="home-portfolio-shutter__final-image home-portfolio-shutter__final-image--foreground"
			data-shutter-final-foreground
			data-src={shutterConfig.finalImage.foregroundImage}
			src={transparentPixel}
			alt=""
			loading="eager"
			decoding="async"
		/>

		<div class="home-portfolio-shutter__mask" data-shutter-mask></div>

		<div class="home-portfolio-shutter__rail" aria-hidden="true">
			{panels.map((panel) => (
				<article
					class="home-portfolio-shutter__panel"
					data-shutter-panel
					data-direction={panel.direction}
					style={`--panel-index: ${panel.index};`}
				>
					<img
						class="home-portfolio-shutter__panel-image"
						data-shutter-image
						data-src={panel.image}
						src={transparentPixel}
						alt=""
						loading="eager"
						decoding="async"
					/>
					<div
						class="home-portfolio-shutter__panel-copy"
						data-shutter-panel-copy
						style={`--panel-image: url(${panel.image})`}
					>
						<div class="home-portfolio-shutter__panel-title-bar">
							<span class="home-portfolio-shutter__panel-label">{panel.english}</span>
							<strong>{panel.title}</strong>
							<span class="home-portfolio-shutter__panel-description">{panel.description}</span>
						</div>
					</div>
				</article>
			))}
		</div>

		<div class="home-portfolio-shutter__interlude" data-shutter-interlude aria-hidden="true">
			<div class="home-portfolio-shutter__interlude-bg" data-shutter-interlude-bg></div>

			<div class="home-portfolio-shutter__interlude-strips">
				<img
					class="home-portfolio-shutter__interlude-strip home-portfolio-shutter__interlude-strip--left"
					data-shutter-interlude-strip-left
					data-src={interlude.stripLeft}
					src={transparentPixel}
					alt=""
					loading="eager"
					decoding="async"
				/>
				<img
					class="home-portfolio-shutter__interlude-strip home-portfolio-shutter__interlude-strip--right"
					data-shutter-interlude-strip-right
					data-src={interlude.stripRight}
					src={transparentPixel}
					alt=""
					loading="eager"
					decoding="async"
				/>
			</div>

			<div class="home-portfolio-shutter__interlude-copy" data-shutter-interlude-copy>
				<span class="home-portfolio-shutter__interlude-copy-text home-portfolio-shutter__interlude-copy-text--left">
					{interlude.copyLeft}
				</span>
				<span class="home-portfolio-shutter__interlude-copy-text home-portfolio-shutter__interlude-copy-text--right">
					{interlude.copyRight}
				</span>
			</div>

			<img
			class="home-portfolio-shutter__interlude-fg"
			data-shutter-interlude-fg
			data-src={interlude.foreground}
			src={transparentPixel}
			alt=""
			loading="eager"
			decoding="async"
		/>
		</div>

		<div class="home-portfolio-shutter__final-copy" data-shutter-final-copy>
			<p>{shutterConfig.kicker}</p>
			<h2>{shutterConfig.title}</h2>
			<span>{shutterConfig.description}</span>
		</div>
	</div>
</section>

<script>
	import {
		DESKTOP_MEDIA_QUERY,
		getDisplayPinEndDistance,
	} from "@/utils/home-display-layer.js";
	import {
		SHUTTER_PANEL_STEP,
		getShutterMergeStart,
	} from "@/utils/home-portfolio-shutter.js";

	type Cleanup = () => void;

	const REDUCED_MOTION_QUERY = "(prefers-reduced-motion: reduce)";
	const TRANSPARENT_PIXEL =
		"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==";
	const IMAGE_DECODE_TIMEOUT = 8000;

	// ===== 展示层动画阶段常量 =====
	const PHASE1_DURATION = 1.2; // 垂直线从底部往上延展
	const PHASE2_DURATION = 1.0; // 柱子水平扩展
	const PHASE2_TEXT_OFFSET = 0.5; // 柱子扩展到 50% 时左右字体滑入
	const PHASE3_DURATION = 0.6; // 中间主标题渐入
	const PHASE4_DURATION = 1.5; // hold
	const PHASE5_DURATION = 0.4; // 字体消失
	const PHASE6_DURATION = 1.0; // 柱子扩全屏
	// 展示层动画总时长
	const DISPLAY_TOTAL =
		PHASE1_DURATION +
		PHASE2_DURATION +
		PHASE3_DURATION +
		PHASE4_DURATION +
		PHASE5_DURATION +
		PHASE6_DURATION;

	// ===== 百叶窗动画阶段常量 =====
	const INTERLUDE_FG_START = 0.1;
	const INTERLUDE_FG_DURATION = 0.5;
	const INTERLUDE_BG_START = 0.6;
	const INTERLUDE_BG_DURATION = 0.4;
	const INTERLUDE_STRIPS_START = 1.0;
	const INTERLUDE_STRIPS_DURATION = 1.0;
	const INTERLUDE_COPY_START = 1.5;
	const INTERLUDE_COPY_DURATION = 0.4;
	const INTERLUDE_TOTAL = 2.4;

	const MERGE_FINAL_IMAGE_OFFSET = 0.02;
	const MERGE_FINAL_IMAGE_DURATION = 1.2;
	// 后景视频在中景图渐入开始 0.5s 后开始渐入
	const MERGE_VIDEO_START = MERGE_FINAL_IMAGE_OFFSET + 0.5;
	const MERGE_VIDEO_DURATION = 0.8;
	// 前景人物图在中景图完全显现后开始渐入，持续 1s
	const MERGE_MIDGROUND_REVEAL_END =
		MERGE_FINAL_IMAGE_OFFSET + MERGE_FINAL_IMAGE_DURATION;
	const MERGE_FOREGROUND_DURATION = 1.0;
	const MERGE_FINAL_COPY_GAP = 0.12;
	// 文字在中景、视频、前景均完全显现后再渐入
	const MERGE_FINAL_COPY_AT = `merge+=${(
		MERGE_MIDGROUND_REVEAL_END +
		MERGE_FOREGROUND_DURATION +
		MERGE_FINAL_COPY_GAP
	).toFixed(2)}`;

	// 百叶窗在展示层动画完成后开始的偏移
	const SHUTTER_START_OFFSET = DISPLAY_TOTAL + 0.3;

	let activeCleanup: Cleanup | null = null;
let mediaCleanup: Cleanup | null = null;
let initToken = 0;

	function matchesDesktop() {
		return window.matchMedia(DESKTOP_MEDIA_QUERY).matches;
	}

	function prefersReducedMotion() {
		return window.matchMedia(REDUCED_MOTION_QUERY).matches;
	}

	function getRoot() {
		return document.getElementById("home-display-layer");
	}

	function getLazyImages(root: HTMLElement) {
		return Array.from(
			root.querySelectorAll<HTMLElement>(
				"img[data-shutter-image], img[data-shutter-final-midground], img[data-shutter-final-foreground], img[data-shutter-interlude-fg], img[data-shutter-interlude-strip-left], img[data-shutter-interlude-strip-right], video[data-shutter-final-video]",
			),
		);
	}

	function resetLazyImages(root: HTMLElement) {
		getLazyImages(root).forEach((element) => {
			if (element instanceof HTMLVideoElement) {
				element.pause?.();
				element.removeAttribute("src");
				element.load?.();
				return;
			}
			element.setAttribute("src", TRANSPARENT_PIXEL);
		});
	}

	function withTimeout<T>(promise: Promise<T>, ms: number): Promise<T> {
		return Promise.race([
			promise,
			new Promise<T>((_, reject) => {
				window.setTimeout(() => reject(new Error("Display image decode timeout")), ms);
			}),
		]);
	}

	function setMediaSrc(element: HTMLElement) {
		const src = element.dataset.src;
		if (!src) return;
		if (element instanceof HTMLVideoElement) {
			if (element.getAttribute("src") !== src) element.setAttribute("src", src);
			return;
		}
		if (element.getAttribute("src") !== src) element.setAttribute("src", src);
	}

	// 分帧 decode 图片，避免一次性解码大量位图阻塞主线程。
	// 视频等待 canplaythrough，无需 decode。
	async function decodeImageBatch(images: HTMLImageElement[], batchSize: number) {
		for (let i = 0; i < images.length; i += batchSize) {
			await new Promise<void>((resolve) => {
				requestAnimationFrame(() => {
					const batch = images.slice(i, i + batchSize);
					Promise.allSettled(batch.map((img) => img.decode?.().catch(() => undefined))).then(
						() => resolve(),
					);
				});
			});
		}
	}

	// 等待视频加载到可流畅播放状态（HAVE_ENOUGH_DATA, readyState===4），
// 确保百叶窗 merge 阶段视频渐入时不会出现卡顿/黑帧。
function waitVideoReady(video: HTMLVideoElement) {
	return new Promise<void>((resolve) => {
		if (video.readyState >= 4) return resolve();
		const cleanup = () => {
			video.removeEventListener("canplaythrough", onReady);
			video.removeEventListener("canplay", onReady);
			video.removeEventListener("loadeddata", onReady);
			video.removeEventListener("error", onReady);
		};
		const onReady = () => {
			cleanup();
			resolve();
		};
		// canplaythrough 是最理想状态，但部分浏览器对循环视频可能只触发 canplay/loadeddata，
		// 因此三者任一触发即视为就绪，error 也 resolve 以避免阻塞动画。
		video.addEventListener("canplaythrough", onReady);
		video.addEventListener("canplay", onReady);
		video.addEventListener("loadeddata", onReady);
		video.addEventListener("error", onReady);
	});
}

async function hydrateLazyImages(root: HTMLElement) {
	const elements = getLazyImages(root);
	const images: HTMLImageElement[] = [];
	const videos: HTMLVideoElement[] = [];

	for (const element of elements) {
		setMediaSrc(element);
		if (element instanceof HTMLVideoElement) {
			// 显式调用 load() 触发下载，确保视频尽早开始流式加载
			element.load();
			videos.push(element);
		} else if (element instanceof HTMLImageElement) {
			images.push(element);
		}
	}

	await withTimeout(
		Promise.allSettled([
			decodeImageBatch(images, 2),
			...videos.map((video) => waitVideoReady(video)),
		]),
		IMAGE_DECODE_TIMEOUT,
	).catch(() => {
		console.warn("[home-display-layer] media decode timeout, proceeding with fallback");
	});
}

	function ensureNoContentWrapperContainingBlock(): Promise<void> {
		return new Promise((resolve) => {
			const wrapper = document.getElementById("content-wrapper");
			if (!wrapper) return resolve();

			if (!wrapper.classList.contains("onload-animation")) {
				wrapper.style.removeProperty("transform");
				return resolve();
			}

			let resolved = false;
			const done = () => {
				if (resolved) return;
				resolved = true;
				wrapper.classList.remove("onload-animation");
				wrapper.style.removeProperty("transform");
				resolve();
			};

			wrapper.addEventListener("animationend", done, { once: true });
			setTimeout(done, 1200);
		});
	}

	function teardownDisplay() {
	initToken += 1;
	if (activeCleanup) {
		activeCleanup();
		activeCleanup = null;
	}
	const root = getRoot();
	if (!root) return;
	delete root.dataset.displayBootstrapped;
	root.removeAttribute("data-display-ready");
	if (!matchesDesktop()) resetLazyImages(root);
	mediaCleanup?.();
	mediaCleanup = null;
}

	function syncTitleBarClipPaths(root: HTMLElement) {
		const copies = Array.from(
			root.querySelectorAll<HTMLElement>("[data-shutter-panel-copy]"),
		);
		for (const copy of copies) {
			const titleBar = copy.querySelector<HTMLElement>(
				".home-portfolio-shutter__panel-title-bar",
			);
			if (!titleBar) continue;
			const top = titleBar.offsetTop;
			const bottom = copy.clientHeight - top - titleBar.offsetHeight;
			copy.style.setProperty("--title-bar-clip-top", `${top}px`);
			copy.style.setProperty("--title-bar-clip-bottom", `${bottom}px`);
		}
	}

	async function initHomeDisplayLayer() {
		const token = ++initToken;
		if (activeCleanup) {
			activeCleanup();
			activeCleanup = null;
		}

		const root = getRoot();
		if (!root) return;

		if (
			root.dataset.displayEnabled !== "true" ||
			!matchesDesktop() ||
			prefersReducedMotion()
		) {
			root.dataset.displayReady = "disabled";
			resetLazyImages(root);
			return;
		}

		root.dataset.displayReady = "loading";

	// 并行：等待 content-wrapper 入场动画结束 + 加载百叶窗媒体资源。
	// 资源加载（图片 decode / 视频 canplaythrough）通常耗时较长，
	// 与 content-wrapper 动画等待并行可显著提前资源就绪时机，
	// 避免快速滚动时 ScrollTrigger pin 已激活但图片/视频尚未就绪。
	await Promise.all([
		ensureNoContentWrapperContainingBlock(),
		hydrateLazyImages(root),
	]);

	if (token !== initToken || !document.contains(root) || !matchesDesktop()) return;

		const [{ gsap }, { ScrollTrigger }] = await Promise.all([
			import("gsap"),
			import("gsap/ScrollTrigger"),
		]);

		if (token !== initToken || !document.contains(root) || !matchesDesktop()) return;

		gsap.registerPlugin(ScrollTrigger);

		const viewport = root.querySelector<HTMLElement>("[data-display-viewport]");
		// 展示层元素
		const line = root.querySelector<HTMLElement>("[data-display-line]");
		const pillar = root.querySelector<HTMLElement>("[data-display-pillar]");
		const kicker = root.querySelector<HTMLElement>("[data-display-kicker]");
		const title = root.querySelector<HTMLElement>("[data-display-title]");
		const desc = root.querySelector<HTMLElement>("[data-display-desc]");
		// 百叶窗元素
		const finalVideo = root.querySelector<HTMLVideoElement>(
			"[data-shutter-final-video]",
		);
		const finalMidground = root.querySelector<HTMLElement>(
			"[data-shutter-final-midground]",
		);
		const finalForeground = root.querySelector<HTMLElement>(
			"[data-shutter-final-foreground]",
		);
		const finalCopy = root.querySelector<HTMLElement>("[data-shutter-final-copy]");
		const rail = root.querySelector<HTMLElement>(".home-portfolio-shutter__rail");
		const mask = root.querySelector<HTMLElement>("[data-shutter-mask]");
		const panels = Array.from(
			root.querySelectorAll<HTMLElement>("[data-shutter-panel]"),
		);
		const panelCopies = Array.from(
			root.querySelectorAll<HTMLElement>("[data-shutter-panel-copy]"),
		);
		const interlude = root.querySelector<HTMLElement>("[data-shutter-interlude]");
		const interludeBg = root.querySelector<HTMLElement>("[data-shutter-interlude-bg]");
		const interludeFg = root.querySelector<HTMLElement>("[data-shutter-interlude-fg]");
		const interludeCopy = root.querySelector<HTMLElement>("[data-shutter-interlude-copy]");
		const interludeCopyLeft = root.querySelector<HTMLElement>(
			".home-portfolio-shutter__interlude-copy-text--left",
		);
		const interludeCopyRight = root.querySelector<HTMLElement>(
			".home-portfolio-shutter__interlude-copy-text--right",
		);
		const stripLeft = root.querySelector<HTMLElement>("[data-shutter-interlude-strip-left]");
		const stripRight = root.querySelector<HTMLElement>("[data-shutter-interlude-strip-right]");

		if (
			!viewport ||
			!line ||
			!pillar ||
			!kicker ||
			!title ||
			!desc ||
			!finalVideo ||
			!finalMidground ||
			!finalForeground ||
			!finalCopy ||
			!rail ||
			!mask ||
			!interlude ||
			!interludeBg ||
			!interludeFg ||
			!interludeCopy ||
			!interludeCopyLeft ||
			!interludeCopyRight ||
			!stripLeft ||
			!stripRight ||
			panels.length !== 5
		) {
			return;
		}

		root.dataset.displayReady = "ready";

		// 总滚动距离 = 展示层距离 + 百叶窗距离
		const getPinEnd = () => {
			const displayDistance = getDisplayPinEndDistance(
				root.dataset.scrollDistance,
				window.innerHeight,
			);
			const shutterDistance = getDisplayPinEndDistance(
				root.dataset.shutterScrollDistance,
				window.innerHeight,
			);
			return `+=${displayDistance + shutterDistance}`;
		};

		// ===== 初始状态 =====
		// 细线、柱子、文字均不可见
		// 注意：不使用 xPercent 居中，改为 CSS calc(50% - width/2) 定位
		// 避免 GSAP translate + scale 组合在 Chrome 下产生位置偏移
		gsap.set(line, { scaleY: 0, transformOrigin: "50% 100%" });
		gsap.set(pillar, { scaleX: 0, transformOrigin: "50% 50%" });
		gsap.set([kicker, title, desc], { autoAlpha: 0 });
		// 百叶窗
		gsap.set(rail, { autoAlpha: 1 });
		gsap.set(mask, { scaleY: 0, transformOrigin: "50% 100%" });
		// 最终图三层：中景图（首层渐入）、后景视频（最底）、前景人物图（最前，xPercent:-50 保持居中）
		gsap.set(finalMidground, { autoAlpha: 0, yPercent: -35, scale: 1.06 });
		gsap.set(finalVideo, { autoAlpha: 0 });
		gsap.set(finalForeground, { autoAlpha: 0, xPercent: -50, scale: 1.02 });
		gsap.set(finalCopy, { autoAlpha: 0, y: 80 });
		gsap.set(panelCopies, { autoAlpha: 0, y: 48 });

		panels.forEach((panel) => {
			const direction = panel.dataset.direction === "down" ? "down" : "up";
			const image = panel.querySelector<HTMLElement>("[data-shutter-image]");
			const fromY = direction === "up" ? 150 : -150;
			gsap.set(panel, { autoAlpha: 0, yPercent: fromY });
			if (image) gsap.set(image, { yPercent: 0, scale: 1.02 });
		});

		gsap.set(interlude, { autoAlpha: 1 });
		gsap.set(interludeBg, { autoAlpha: 0 });
		gsap.set(interludeFg, { autoAlpha: 0, yPercent: 8, scale: 1.04 });
		gsap.set([interludeCopyLeft, interludeCopyRight], { autoAlpha: 0 });
		gsap.set(stripLeft, { xPercent: -100 });
		gsap.set(stripRight, { xPercent: 100 });

		const timeline = gsap.timeline({
			defaults: { ease: "none" },
			scrollTrigger: {
				id: "home-display-layer-pin",
				trigger: root,
				start: "top top",
				end: getPinEnd,
				pin: root,
				pinSpacing: true,
				scrub: true,
				invalidateOnRefresh: true,
				anticipatePin: 1,
			},
		});

		// ============================================
		// 第一部分：展示层动画（0 → DISPLAY_TOTAL）
		// ============================================

		// Phase 1: 垂直线从底部往上延展
		timeline.addLabel("display-phase1", 0);
		timeline.to(
			line,
			{
				scaleY: 1,
				duration: PHASE1_DURATION,
				ease: "power3.inOut",
			},
			"display-phase1",
		);

		// Phase 2: 细线淡出 + 柱子水平扩展
		timeline.addLabel("display-phase2", `display-phase1+=${PHASE1_DURATION}`);
		timeline.to(
			line,
			{ autoAlpha: 0, duration: 0.15, ease: "power2.in" },
			"display-phase2",
		);
		timeline.to(
			pillar,
			{ scaleX: 1, duration: PHASE2_DURATION, ease: "power3.inOut" },
			"display-phase2",
		);
		timeline.fromTo(
			kicker,
			{ autoAlpha: 0, xPercent: -30 },
			{ autoAlpha: 1, xPercent: 0, duration: 0.5, ease: "power2.out" },
			`display-phase2+=${PHASE2_TEXT_OFFSET}`,
		);
		timeline.fromTo(
			desc,
			{ autoAlpha: 0, xPercent: 30 },
			{ autoAlpha: 1, xPercent: 0, duration: 0.5, ease: "power2.out" },
			`display-phase2+=${PHASE2_TEXT_OFFSET}`,
		);

		// Phase 3: 中间主标题渐入
		timeline.addLabel("display-phase3", `display-phase2+=${PHASE2_DURATION}`);
		timeline.to(
			title,
			{ autoAlpha: 1, duration: PHASE3_DURATION, ease: "power2.out" },
			"display-phase3",
		);

		// Phase 4: hold
		timeline.addLabel("display-phase4", `display-phase3+=${PHASE3_DURATION}`);
		timeline.to({}, { duration: PHASE4_DURATION, ease: "none" }, "display-phase4");

		// Phase 5: 字体消失
		timeline.addLabel("display-phase5", `display-phase4+=${PHASE4_DURATION}`);
		timeline.to(
			[kicker, title, desc],
			{
				autoAlpha: 0,
				duration: PHASE5_DURATION,
				ease: "power2.inOut",
				stagger: 0.04,
			},
			"display-phase5",
		);

		// Phase 6: 柱子扩全屏
		timeline.addLabel("display-phase6", `display-phase5+=${PHASE5_DURATION}`);
		const finalWidthValue = parseFloat(root.dataset.pillarFinalWidth || "");
		const fullWidthScale = Number.isFinite(finalWidthValue) && finalWidthValue > 0
			? 100 / finalWidthValue
			: 5.56;
		timeline.to(
			pillar,
			{
				scaleX: fullWidthScale,
				duration: PHASE6_DURATION,
				ease: "power3.inOut",
			},
			"display-phase6",
		);

		// ============================================
		// 第二部分：百叶窗动画（SHUTTER_START_OFFSET → end）
		// ============================================
		timeline.addLabel("shutter-start", SHUTTER_START_OFFSET);

		// Phase A: Panels — 5 张长条图依次滑入
		timeline.addLabel("shutter-panels", SHUTTER_START_OFFSET);
		panels.forEach((panel, index) => {
			const image = panel.querySelector<HTMLElement>("[data-shutter-image]");
			const copy = panel.querySelector<HTMLElement>("[data-shutter-panel-copy]");

			timeline.to(
				panel,
				{ autoAlpha: 1, yPercent: 0, duration: 0.48, ease: "power3.out" },
				`shutter-panels+=${index * SHUTTER_PANEL_STEP}`,
			);

			if (image) {
				timeline.to(
					image,
					{ yPercent: 0, scale: 1.02, duration: 0.58, ease: "power2.out" },
					`shutter-panels+=${index * SHUTTER_PANEL_STEP}`,
				);
			}

			if (copy) {
				timeline.to(
					copy,
					{ autoAlpha: 1, y: 0, duration: 0.18, ease: "power2.out" },
					`shutter-panels+=${index * SHUTTER_PANEL_STEP + 0.3}`,
				);
			}
		});

		// Phase B: Interlude — 三层插入动画
		const shutterMergeStart = SHUTTER_START_OFFSET + getShutterMergeStart(panels.length);
		timeline.addLabel("shutter-interlude", shutterMergeStart);

		// 面板文字淡出
		timeline.to(
			panelCopies,
			{ autoAlpha: 0, y: -36, duration: 0.28, stagger: 0.02, ease: "power2.out" },
			"shutter-interlude",
		);

		// 前景渐入
		timeline.to(
			interludeFg,
			{
				autoAlpha: 1,
				yPercent: 0,
				scale: 1,
				duration: INTERLUDE_FG_DURATION,
				ease: "power3.out",
			},
			`shutter-interlude+=${INTERLUDE_FG_START}`,
		);

		// 背景渐黑
		timeline.to(
			interludeBg,
			{ autoAlpha: 1, duration: INTERLUDE_BG_DURATION, ease: "power2.inOut" },
			`shutter-interlude+=${INTERLUDE_BG_START}`,
		);

		// 两条长条反向滑入
		timeline.to(
			stripLeft,
			{ xPercent: 0, duration: INTERLUDE_STRIPS_DURATION, ease: "power3.inOut" },
			`shutter-interlude+=${INTERLUDE_STRIPS_START}`,
		);
		timeline.to(
			stripRight,
			{ xPercent: 0, duration: INTERLUDE_STRIPS_DURATION, ease: "power3.inOut" },
			`shutter-interlude+=${INTERLUDE_STRIPS_START}`,
		);

		// 中景文字渐入
		timeline.to(
			[interludeCopyLeft, interludeCopyRight],
			{
				autoAlpha: 1,
				duration: INTERLUDE_COPY_DURATION,
				ease: "power2.out",
				stagger: 0.08,
			},
			`shutter-interlude+=${INTERLUDE_COPY_START}`,
		);

		// Phase C: Merge — 遮罩 + 最终图三层组合
		// 时序：中景图渐入 →（完全显现后）后景视频 + 前景图同时渐入 →（完全显现后）文字渐入
		timeline.addLabel("merge", `shutter-interlude+=${INTERLUDE_TOTAL}`);

		// 黑色遮罩从底部向上展开
		timeline.to(
			mask,
			{ scaleY: 1, duration: 0.9, ease: "power3.inOut" },
			"merge",
		);

		// 1. 中景图渐入（代替原 finalImage）
		timeline.to(
			finalMidground,
			{
				autoAlpha: 1,
				yPercent: 0,
				scale: 1,
				duration: MERGE_FINAL_IMAGE_DURATION,
				ease: "power3.inOut",
			},
			`merge+=${MERGE_FINAL_IMAGE_OFFSET}`,
		);

		// 2. 后景视频在中景渐入 0.5s 后开始渐入（静音循环）
		// 视频已在 initHomeDisplayLayer 阶段通过 hydrateLazyImages 加载到 canplaythrough，
		// 此处仅触发 play()，避免动画过程中才发起网络请求导致黑帧。
		timeline.to(
			finalVideo,
			{
				autoAlpha: 1,
				duration: MERGE_VIDEO_DURATION,
				ease: "power2.inOut",
				onStart: () => {
					finalVideo.play().catch(() => undefined);
				},
			},
			`merge+=${MERGE_VIDEO_START}`,
		);

		// 3. 前景人物图在中景完全显现后渐入（xPercent:-50 保持水平居中）
		timeline.to(
			finalForeground,
			{
				autoAlpha: 1,
				xPercent: -50,
				scale: 1,
				duration: MERGE_FOREGROUND_DURATION,
				ease: "power2.inOut",
			},
			`merge+=${MERGE_MIDGROUND_REVEAL_END}`,
		);

		// 4. 三层完全显现后，最终文字渐入
		timeline.to(
			finalCopy,
			{ autoAlpha: 1, y: 0, duration: 0.46, ease: "power3.inOut" },
			MERGE_FINAL_COPY_AT,
		);

		// 保持
		timeline.to({ hold: 0 }, { hold: 1, duration: 1.0, ease: "none" });

		ScrollTrigger.refresh();
		syncTitleBarClipPaths(root);

		activeCleanup = () => {
			timeline.scrollTrigger?.kill();
			timeline.kill();
			finalVideo.pause?.();
			gsap.set(
				[
					root,
					viewport,
					line,
					pillar,
					kicker,
					title,
					desc,
					rail,
					mask,
					finalVideo,
					finalMidground,
					finalForeground,
					finalCopy,
					interlude,
					interludeBg,
					interludeFg,
					interludeCopy,
					interludeCopyLeft,
					interludeCopyRight,
					stripLeft,
					stripRight,
					...panels,
					...panelCopies,
				],
				{ clearProps: "all" },
			);
		};
	}

	function setupMediaWatchers() {
		if (mediaCleanup) return;
		const desktopQuery = window.matchMedia(DESKTOP_MEDIA_QUERY);
		const reduceMotionQuery = window.matchMedia(REDUCED_MOTION_QUERY);
		const handleChange = () => {
			const root = getRoot();
			if (root) delete root.dataset.displayBootstrapped;
			bootHomeDisplayLayer();
		};

		let resizeTimeout: number | undefined;
		const handleResize = () => {
			window.clearTimeout(resizeTimeout);
			resizeTimeout = window.setTimeout(() => {
				const root = getRoot();
				if (root && root.dataset.displayReady === "ready") {
					syncTitleBarClipPaths(root);
				}
			}, 150);
		};

		desktopQuery.addEventListener("change", handleChange);
		reduceMotionQuery.addEventListener("change", handleChange);
		window.addEventListener("resize", handleResize);
		mediaCleanup = () => {
			desktopQuery.removeEventListener("change", handleChange);
			reduceMotionQuery.removeEventListener("change", handleChange);
			window.removeEventListener("resize", handleResize);
			window.clearTimeout(resizeTimeout);
		};
	}

	function bootHomeDisplayLayer() {
	const root = getRoot();
	if (!root || root.dataset.displayBootstrapped === "true") return;
	root.dataset.displayBootstrapped = "true";
	setupMediaWatchers();

	// 首页关键资源：boot 时立即初始化，initHomeDisplayLayer 内部会尽早并行
	// 加载所有图片/视频并等待 decode/canplaythrough，确保用户滚动到时资源已就绪。
	if (matchesDesktop() && !prefersReducedMotion()) {
		void initHomeDisplayLayer();
	}
}

	bootHomeDisplayLayer();
	document.addEventListener("astro:page-load", bootHomeDisplayLayer);
	document.addEventListener("swup:willReplaceContent", teardownDisplay);
</script>
