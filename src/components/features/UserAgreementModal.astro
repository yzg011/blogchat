---
import { getEntry, render } from "astro:content";
import Markdown from "@components/common/Markdown.astro";

const agreementPost = await getEntry("spec", "user-agreement");
let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
if (agreementPost) {
	const rendered = await render(agreementPost);
	Content = rendered.Content;
}
---

<dialog id="user-agreement-modal" class="privacy-modal">
	<div class="privacy-overlay" data-close-user-agreement></div>
	<div class="privacy-panel">
		<div class="privacy-header">
			<h2 class="privacy-title">用户协议</h2>
			<button class="privacy-close" data-close-user-agreement aria-label="关闭">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="18" y1="6" x2="6" y2="18" />
					<line x1="6" y1="6" x2="18" y2="18" />
				</svg>
			</button>
		</div>
		<div class="privacy-body">
			{Content && (
				<Markdown class="">
					<Content />
				</Markdown>
			)}
		</div>
		<div class="privacy-footer">
			<button class="privacy-confirm-btn" data-close-user-agreement>我知道了</button>
		</div>
	</div>
</dialog>

<script>
	let userAgreementController: AbortController | null = null;

	function initUserAgreementModal() {
		const modal = document.getElementById("user-agreement-modal") as HTMLDialogElement | null;
		if (!modal) return;

		if (userAgreementController) userAgreementController.abort();
		userAgreementController = new AbortController();
		const signal = userAgreementController.signal;

		function openModal() {
			modal!.showModal();
			document.body.style.overflow = "hidden";
		}

		function closeModal() {
			modal!.close();
			document.body.style.overflow = "";
		}

		modal.querySelectorAll("[data-close-user-agreement]").forEach((element) => {
			element.addEventListener("click", closeModal, { signal });
		});

		modal.addEventListener("click", (event) => {
			if (event.target === modal) closeModal();
		}, { signal });

		modal.addEventListener("close", () => {
			document.body.style.overflow = "";
		}, { signal });

		modal.addEventListener("cancel", (event) => {
			event.preventDefault();
			closeModal();
		}, { signal });

		window.addEventListener("user-agreement:open", openModal, { signal });
		(window as any).openUserAgreementModal = openModal;
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initUserAgreementModal);
	} else {
		initUserAgreementModal();
	}
	document.addEventListener("astro:page-load", initUserAgreementModal);
	document.addEventListener("astro:after-swap", initUserAgreementModal);
</script>
