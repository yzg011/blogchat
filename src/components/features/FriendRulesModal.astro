---
import Icon from "@components/common/Icon.astro";
import { friendsPageConfig } from "@/config";

interface Props {
	applyLink?: string;
}

const { applyLink = friendsPageConfig.applyLink } = Astro.props;
const site = friendsPageConfig.siteInfo;
const notes = friendsPageConfig.notes;
---

<dialog id="friend-rules-modal" class="fr-modal">
  <div class="fr-overlay" data-close-modal></div>
  <div class="fr-panel">
    <!-- 头部 -->
    <div class="fr-header">
      <h2 class="fr-title">友链申请指南</h2>
      <button class="fr-close" data-close-modal aria-label="关闭">
        <Icon name="material-symbols:close-rounded" class="text-xl" />
      </button>
    </div>

    <!-- 内容 -->
    <div class="fr-body">
      <!-- 本站信息 -->
      {site && (
        <section class="fr-section">
          <div class="fr-section-head">
            <div class="fr-section-icon">
              <Icon name="material-symbols:info-outline-rounded" />
            </div>
            <h3>本站信息</h3>
          </div>
          <div class="fr-info-grid">
            {[
              { label: "站点名称", value: site.name },
              { label: "站点描述", value: site.desc },
              { label: "站点链接", value: site.url },
              { label: "头像链接", value: site.avatar },
            ].map((item) => (
              <div class="fr-info-row">
                <div class="fr-info-text">
                  <span class="fr-info-label">{item.label}</span>
                  <span class="fr-info-value">{item.value}</span>
                </div>
                <button
                  class="fr-copy-btn"
                  onclick={`navigator.clipboard.writeText('${item.value.replace(/'/g, "\\'")}');this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),1500)`}
                  aria-label={`复制${item.label}`}
                >
                  <Icon name="material-symbols:content-copy-outline-rounded" class="fr-copy-icon" />
                  <Icon name="material-symbols:check-rounded" class="fr-check-icon" />
                </button>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- 申请流程 -->
      <section class="fr-section">
        <div class="fr-section-head">
          <div class="fr-section-icon">
            <Icon name="material-symbols:list-alt-outline-rounded" />
          </div>
          <h3>申请流程</h3>
        </div>
        <div class="fr-steps">
          <div class="fr-step">
            <div class="fr-step-num">1</div>
            <div class="fr-step-line"></div>
            <div class="fr-step-content">
              <p class="fr-step-title">添加本站友链</p>
              <p class="fr-step-desc">请先在您的网站友链页面添加本站信息，可直接复制上方各字段</p>
            </div>
          </div>
          <div class="fr-step">
            <div class="fr-step-num">2</div>
            <div class="fr-step-line"></div>
            <div class="fr-step-content">
              <p class="fr-step-title">
                发送申请邮件至：<code class="fr-code">{site?.email}</code>
              </p>
              <p class="fr-step-desc">将下方模板内容复制修改后发送</p>
              <div class="fr-template">
                <button
                  class="fr-copy-btn fr-template-copy"
                  onclick={`navigator.clipboard.writeText('站点名称：您的站点名称\\n站点描述：您的站点描述\\n站点链接：您的站点链接\\n头像链接：您的站点头像');this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),1500)`}
                  aria-label="复制模板"
                >
                  <Icon name="material-symbols:content-copy-outline-rounded" class="fr-copy-icon" />
                  <Icon name="material-symbols:check-rounded" class="fr-check-icon" />
                </button>
                <pre class="fr-template-text">{`站点名称：您的站点名称\n站点描述：您的站点描述\n站点链接：您的站点链接\n头像链接：您的站点头像`}</pre>
              </div>
            </div>
          </div>
          <div class="fr-step">
            <div class="fr-step-num">3</div>
            <div class="fr-step-content">
              <p class="fr-step-title">等待审核</p>
              <p class="fr-step-desc">确认信息无误后会尽快添加您的友链</p>
            </div>
          </div>
        </div>
      </section>

      <!-- 注意事项 -->
      {notes && (
        <section class="fr-section">
          <div class="fr-section-head">
            <div class="fr-section-icon">
              <Icon name="material-symbols:info-outline-rounded" />
            </div>
            <h3>注意事项</h3>
          </div>
          <div class="fr-notes">
            {notes.map((item) => (
              <div class="fr-note">
                <span class="fr-note-dot"></span>
                <p><strong>{item.title}</strong>：{item.content}</p>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- 底部按钮 -->
    <div class="fr-footer">
      {applyLink && (
        <a
          href={applyLink}
          target="_blank"
          rel="noopener noreferrer"
          class="fr-btn fr-btn-primary"
        >
          <Icon name="material-symbols:edit-square-outline" class="text-base" />
          自助申请友链（推荐）
        </a>
      )}
      <button class="fr-btn fr-btn-secondary" data-close-modal>
        <Icon name="material-symbols:mail-outline-rounded" class="text-base" />
        手动申请友链
      </button>
    </div>
  </div>
</dialog>

<style>
  /* ========== 弹窗基础 ========== */
  .fr-modal {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    border: none;
    background: transparent;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    overflow: visible;
  }
  .fr-modal[open] { display: flex; }
  .fr-modal::backdrop { background: transparent; }

  .fr-overlay {
    position: fixed;
    inset: 0;
    background: oklch(0 0 0 / 0.5);
    backdrop-filter: blur(4px);
    z-index: -1;
    animation: frFadeIn 0.2s ease-out;
  }

  .fr-panel {
    background: oklch(1 0 0);
    border: 1px solid var(--line-divider);
    border-radius: 1rem;
    box-shadow: 0 25px 50px -12px oklch(0 0 0 / 0.25);
    max-width: 40rem;
    width: 100%;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    animation: frSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :root.dark .fr-panel {
    background: oklch(0.15 0 0);
    border-color: var(--line-divider);
    box-shadow: 0 25px 50px -12px oklch(0 0 0 / 0.6);
  }

  /* ========== 头部 ========== */
  .fr-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--line-divider);
    flex-shrink: 0;
  }
  .fr-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: oklch(0.2 0 0);
    margin: 0;
  }
  :root.dark .fr-title { color: oklch(0.9 0 0); }

  .fr-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    border: none;
    background: transparent;
    color: oklch(0.5 0 0);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .fr-close:hover {
    background: var(--btn-plain-bg-hover);
    color: oklch(0.2 0 0);
  }
  :root.dark .fr-close { color: oklch(0.6 0 0); }
  :root.dark .fr-close:hover { color: oklch(0.9 0 0); }

  /* ========== 内容区 ========== */
  .fr-body {
    padding: 1.5rem;
    overflow-y: auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ========== 区块通用 ========== */
  .fr-section {}
  .fr-section-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
  }
  .fr-section-icon {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    background: oklch(0.95 0 0);
    color: oklch(0.4 0 0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }
  :root.dark .fr-section-icon {
    background: oklch(0.25 0 0);
    color: oklch(0.7 0 0);
  }
  .fr-section-head h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.2 0 0);
    margin: 0;
  }
  :root.dark .fr-section-head h3 { color: oklch(0.85 0 0); }

  /* ========== 站点信息 ========== */
  .fr-info-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .fr-info-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.625rem;
    background: oklch(0.97 0 0);
    border: 1px solid oklch(0.92 0 0);
  }
  :root.dark .fr-info-row {
    background: oklch(0.2 0 0);
    border-color: oklch(0.28 0 0);
  }
  .fr-info-text { min-width: 0; flex: 1; }
  .fr-info-label {
    display: block;
    font-size: 0.6875rem;
    color: oklch(0.55 0 0);
    margin-bottom: 0.125rem;
  }
  :root.dark .fr-info-label { color: oklch(0.5 0 0); }
  .fr-info-value {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: oklch(0.2 0 0);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :root.dark .fr-info-value { color: oklch(0.85 0 0); }

  /* ========== 复制按钮 ========== */
  .fr-copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: none;
    background: oklch(0.92 0 0);
    color: oklch(0.4 0 0);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
    position: relative;
  }
  .fr-copy-btn:hover {
    background: oklch(0.88 0 0);
    color: oklch(0.2 0 0);
  }
  :root.dark .fr-copy-btn {
    background: oklch(0.28 0 0);
    color: oklch(0.6 0 0);
  }
  :root.dark .fr-copy-btn:hover {
    background: oklch(0.35 0 0);
    color: oklch(0.85 0 0);
  }
  .fr-copy-btn .fr-check-icon { display: none; }
  .fr-copy-btn.copied .fr-copy-icon { display: none; }
  .fr-copy-btn.copied .fr-check-icon { display: block; color: oklch(0.6 0.15 145); }

  /* ========== 申请流程 ========== */
  .fr-steps { display: flex; flex-direction: column; }
  .fr-step {
    display: flex;
    gap: 0.875rem;
    position: relative;
  }
  .fr-step-num {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: oklch(0.3 0 0);
    color: oklch(1 0 0);
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  :root.dark .fr-step-num {
    background: oklch(0.85 0 0);
    color: oklch(0.15 0 0);
  }
  .fr-step-line {
    position: absolute;
    left: 0.875rem;
    top: 1.75rem;
    width: 1px;
    bottom: 0;
    background: var(--line-divider);
  }
  .fr-step-content {
    padding-bottom: 1rem;
    flex: 1;
    min-width: 0;
  }
  .fr-step:last-child .fr-step-content { padding-bottom: 0; }
  .fr-step-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: oklch(0.2 0 0);
    margin: 0 0 0.25rem 0;
  }
  :root.dark .fr-step-title { color: oklch(0.85 0 0); }
  .fr-step-desc {
    font-size: 0.8125rem;
    color: oklch(0.5 0 0);
    margin: 0;
    line-height: 1.5;
  }
  :root.dark .fr-step-desc { color: oklch(0.55 0 0); }

  .fr-code {
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background: oklch(0.95 0 0);
    font-size: 0.75rem;
    font-family: monospace;
    border: 1px solid oklch(0.9 0 0);
  }
  :root.dark .fr-code {
    background: oklch(0.22 0 0);
    border-color: oklch(0.3 0 0);
  }

  .fr-template {
    position: relative;
    margin-top: 0.625rem;
    border-radius: 0.5rem;
    background: oklch(0.97 0 0);
    border: 1px solid oklch(0.92 0 0);
    padding: 0.875rem 2.5rem 0.875rem 0.875rem;
  }
  :root.dark .fr-template {
    background: oklch(0.18 0 0);
    border-color: oklch(0.28 0 0);
  }
  .fr-template-copy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
  }
  .fr-template-text {
    font-size: 0.75rem;
    line-height: 1.6;
    color: oklch(0.4 0 0);
    margin: 0;
    white-space: pre-wrap;
    word-break: break-all;
    font-family: monospace;
  }
  :root.dark .fr-template-text { color: oklch(0.6 0 0); }

  /* ========== 注意事项 ========== */
  .fr-notes {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .fr-note {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: oklch(0.45 0 0);
  }
  :root.dark .fr-note { color: oklch(0.55 0 0); }
  .fr-note-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background: oklch(0.3 0 0);
    flex-shrink: 0;
    margin-top: 0.5rem;
  }
  :root.dark .fr-note-dot { background: oklch(0.7 0 0); }
  .fr-note strong {
    color: oklch(0.2 0 0);
    font-weight: 600;
  }
  :root.dark .fr-note strong { color: oklch(0.8 0 0); }

  /* ========== 底部 ========== */
  .fr-footer {
    display: flex;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--line-divider);
    justify-content: flex-end;
    flex-shrink: 0;
  }

  .fr-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.625rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s, background 0.15s, color 0.15s;
    text-decoration: none;
    border: none;
    line-height: 1;
  }
  .fr-btn-primary {
    background: oklch(0.3 0 0);
    color: oklch(1 0 0);
  }
  .fr-btn-primary:hover { opacity: 0.9; }
  :root.dark .fr-btn-primary {
    background: oklch(0.85 0 0);
    color: oklch(0.15 0 0);
  }

  .fr-btn-secondary {
    background: transparent;
    border: 1px solid var(--line-divider);
    color: oklch(0.3 0 0);
  }
  .fr-btn-secondary:hover {
    background: var(--btn-plain-bg-hover);
  }
  :root.dark .fr-btn-secondary { color: oklch(0.8 0 0); }

  /* ========== 动画 ========== */
  @keyframes frFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes frSlideIn {
    from { opacity: 0; transform: translateY(-0.75rem) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ========== 移动端 ========== */
  @media (max-width: 640px) {
    .fr-panel {
      max-width: calc(100% - 1.5rem);
      max-height: 90vh;
    }
    .fr-footer { flex-direction: column; }
    .fr-btn { justify-content: center; }
  }
</style>

<script>
  function initFriendRulesModal() {
    const modal = document.getElementById('friend-rules-modal') as HTMLDialogElement | null;
    if (!modal) return;

    const openBtns = document.querySelectorAll('[data-open-friend-rules]');
    openBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        modal.showModal();
        document.body.style.overflow = 'hidden';
      });
    });

    modal.querySelectorAll('[data-close-modal]').forEach(el => {
      el.addEventListener('click', () => {
        modal.close();
        document.body.style.overflow = '';
      });
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.close();
        document.body.style.overflow = '';
      }
    });

    modal.addEventListener('close', () => {
      document.body.style.overflow = '';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFriendRulesModal);
  } else {
    initFriendRulesModal();
  }
  document.addEventListener('astro:page-load', initFriendRulesModal);
  document.addEventListener('astro:after-swap', initFriendRulesModal);
</script>
