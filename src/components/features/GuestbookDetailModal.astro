---
---

<dialog id="guestbook-detail-modal" class="gb-detail-modal">
	<div class="gb-detail-overlay" data-close-detail></div>
	<div class="gb-detail-panel">
		<!-- 角标装饰 -->
		<div class="corner-mark top-left"></div>
		<div class="corner-mark top-right"></div>
		<div class="corner-mark bottom-left"></div>
		<div class="corner-mark bottom-right"></div>

		<!-- 头部 -->
		<div class="detail-header">
			<div class="header-bg"></div>
			<div class="header-content">
				<div class="author-info">
					<div class="author-avatar"></div>
					<span class="author-name" id="detail-author"></span>
				</div>
				<span class="message-time" id="detail-time"></span>
			</div>
		</div>

		<!-- 留言信息 -->
		<div class="detail-body">
			<div class="body-line"></div>
			<div class="body-content">
				<h3 class="message-title" id="detail-title"></h3>
				<div class="title-underline"></div>
				<p class="detail-text" id="detail-content"></p>
			</div>
		</div>

		<!-- 投票统计 -->
		<div class="detail-stats">
			<div class="stat-item agree">
				<svg xmlns="http://www.w3.org/2000/svg" width="0.75rem" height="0.75rem" viewBox="0 0 24 24"><path fill="currentColor" d="M18 21V9h-2V7h2V5h-2V3h2v2h2v2h-2v2h2v12zM9.05 21H4V9h.95l.45-2.025q.1-.45.5-.712T6.75 6h.5q.45 0 .85.263t.5.712L9.05 9h.95v12z"/></svg>
				<span class="stat-label">赞同</span>
				<span class="stat-count" id="detail-agree">0</span>
			</div>
			<div class="stat-item neutral">
				<svg xmlns="http://www.w3.org/2000/svg" width="0.75rem" height="0.75rem" viewBox="0 0 24 24"><path fill="currentColor" d="M6 13v-2h12v2z"/></svg>
				<span class="stat-label">中立</span>
				<span class="stat-count" id="detail-neutral">0</span>
			</div>
			<div class="stat-item disagree">
				<svg xmlns="http://www.w3.org/2000/svg" width="0.75rem" height="0.75rem" viewBox="0 0 24 24"><path fill="currentColor" d="M18 3v12h-2v2h2v2h-2v2h2v-2h2v-2h-2V3zM9.05 3H4v12h.95l.45 2.025q.1.45.5.713t.85.262h.5q.45 0 .85-.262t.5-.713L9.05 15h.95V3z"/></svg>
				<span class="stat-label">反对</span>
				<span class="stat-count" id="detail-disagree">0</span>
			</div>
		</div>

		<!-- 底部 -->
		<div class="card-footer">
			<div class="footer-bars">
				<div class="bar"></div>
				<div class="bar"></div>
				<div class="bar"></div>
				<div class="bar"></div>
				<div class="bar"></div>
			</div>
			<span class="footer-text">ESC 关闭</span>
		</div>
	</div>
</dialog>

<script>
	function initGuestbookDetailModal() {
		const modal = document.getElementById('guestbook-detail-modal') as HTMLDialogElement | null;
		if (!modal) return;

		// 监听打开事件
		window.addEventListener('guestbook:open-detail', ((e: CustomEvent) => {
			const card = e.detail;
			if (!card) return;

			// 填充数据
			const authorEl = document.getElementById('detail-author');
			const timeEl = document.getElementById('detail-time');
			const titleEl = document.getElementById('detail-title');
			const contentEl = document.getElementById('detail-content');
			const agreeEl = document.getElementById('detail-agree');
			const neutralEl = document.getElementById('detail-neutral');
			const disagreeEl = document.getElementById('detail-disagree');

			if (authorEl) authorEl.textContent = card.author;
			if (timeEl) timeEl.textContent = card.time;
			if (titleEl) titleEl.textContent = '留言 #' + card.id.split('_')[1];
			if (contentEl) contentEl.textContent = card.content;
			if (agreeEl) agreeEl.textContent = card.votes.agree;
			if (neutralEl) neutralEl.textContent = card.votes.neutral;
			if (disagreeEl) disagreeEl.textContent = card.votes.disagree;

			modal.showModal();
			document.body.style.overflow = 'hidden';
		}) as EventListener);

		// 关闭
		modal.querySelectorAll('[data-close-detail]').forEach(el => {
			el.addEventListener('click', () => {
				modal.close();
				document.body.style.overflow = '';
			});
		});

		modal.addEventListener('click', (e) => {
			if (e.target === modal) {
				modal.close();
				document.body.style.overflow = '';
			}
		});

		modal.addEventListener('close', () => {
			document.body.style.overflow = '';
		});

		// ESC 关闭
		modal.addEventListener('cancel', (e) => {
			e.preventDefault();
			modal.close();
			document.body.style.overflow = '';
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initGuestbookDetailModal);
	} else {
		initGuestbookDetailModal();
	}
	document.addEventListener('astro:page-load', initGuestbookDetailModal);
	document.addEventListener('astro:after-swap', initGuestbookDetailModal);
</script>

<style>
	/* ========== 弹窗基础 ========== */
	.gb-detail-modal {
		position: fixed;
		inset: 0;
		z-index: 99999;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		border: none;
		background: transparent;
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		overflow: visible;
	}
	.gb-detail-modal[open] { display: flex; }
	.gb-detail-modal::backdrop { background: transparent; }

	.gb-detail-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(6px);
		z-index: -1;
		animation: gbFadeIn 0.2s ease-out;
	}
	:root.dark .gb-detail-overlay {
		background: rgba(0, 0, 0, 0.75);
	}

	.gb-detail-panel {
		position: relative;
		width: 90%;
		max-width: 720px;
		background: #ffffff;
		border: 2px solid #18181b;
		border-radius: 0.5rem;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		animation: gbSlideIn 0.25s cubic-bezier(0.22, 0.68, 0.25, 1);
	}
	:root.dark .gb-detail-panel {
		background: #18181b;
		border-color: #52525b;
	}

	@keyframes gbFadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes gbSlideIn {
		from { opacity: 0; transform: scale(0.92) translateY(12px); }
		to { opacity: 1; transform: scale(1) translateY(0); }
	}

	/* 角标 */
	.corner-mark {
		position: absolute;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		border: 1px solid #18181b;
		background: #f4f4f5;
		z-index: 20;
	}
	:root.dark .corner-mark {
		border-color: #52525b;
		background: #27272a;
	}
	.corner-mark::after {
		content: "";
		position: absolute;
		inset: 0;
		margin: auto;
		width: 60%;
		height: 1px;
		background: #18181b;
		transform: rotate(45deg);
	}
	:root.dark .corner-mark::after {
		background: #52525b;
	}
	.corner-mark.top-left { top: 0.5rem; left: 0.5rem; }
	.corner-mark.top-right { top: 0.5rem; right: 0.5rem; }
	.corner-mark.bottom-left { bottom: 0.5rem; left: 0.5rem; }
	.corner-mark.bottom-right { bottom: 0.5rem; right: 0.5rem; }

	/* 头部 */
	.detail-header {
		position: relative;
		height: 4rem;
		border-bottom: 2px solid #18181b;
		padding: 0 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		overflow: hidden;
	}
	:root.dark .detail-header {
		border-color: #52525b;
	}

	.header-bg {
		position: absolute;
		inset: 0;
		opacity: 0.06;
		pointer-events: none;
		background-image: repeating-linear-gradient(
			45deg,
			transparent,
			transparent 5px,
			#18181b 5px,
			#18181b 10px
		);
	}
	:root.dark .header-bg {
		background-image: repeating-linear-gradient(
			45deg,
			transparent,
			transparent 5px,
			#fafafa 5px,
			#fafafa 10px
		);
	}

	.header-content {
		position: relative;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
	}

	.author-info {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.author-avatar {
		width: 0.75rem;
		height: 0.75rem;
		background: #18181b;
		border-radius: 0.125rem;
		animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}
	:root.dark .author-avatar {
		background: #fafafa;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.5; }
	}

	.author-name {
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: #18181b;
	}
	:root.dark .author-name {
		color: #fafafa;
	}

	.message-time {
		font-size: 0.65rem;
		font-family: ui-monospace, monospace;
		opacity: 0.6;
		color: #52525b;
	}
	:root.dark .message-time {
		color: #a1a1aa;
	}

	/* 主体 */
	.detail-body {
		position: relative;
		padding: 2rem;
		display: flex;
		overflow: hidden;
	}

	.body-line {
		position: absolute;
		left: 1rem;
		top: 1.5rem;
		bottom: 1.5rem;
		width: 1px;
		background: #d4d4d8;
	}
	:root.dark .body-line {
		background: #27272a;
	}

	.body-content {
		padding-left: 1rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	.source-tag {
		display: inline-block;
		padding: 0.125rem 0.5rem;
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		border: 1px solid #06b6d4;
		color: #06b6d4;
		width: fit-content;
		margin-bottom: 0.75rem;
	}

	.message-title {
		font-size: 1.125rem;
		font-weight: 700;
		line-height: 1.3;
		margin-bottom: 0.75rem;
		color: #18181b;
		text-transform: uppercase;
		letter-spacing: -0.02em;
	}
	:root.dark .message-title {
		color: #fafafa;
	}

	.title-underline {
		width: 3rem;
		height: 1px;
		background: #18181b;
		margin-bottom: 1rem;
	}
	:root.dark .title-underline {
		background: #fafafa;
	}

	.detail-text {
		font-size: 1rem;
		line-height: 1.9;
		font-family: ui-monospace, monospace;
		color: #52525b;
		white-space: pre-wrap;
		word-break: break-word;
	}
	:root.dark .detail-text {
		color: #a1a1aa;
	}

	/* 投票统计 */
	.detail-stats {
		display: flex;
		border-top: 1px solid #d4d4d8;
		border-bottom: 1px solid #d4d4d8;
	}
	:root.dark .detail-stats {
		border-color: #27272a;
	}

	.stat-item {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		padding: 0.75rem 0;
		transition: background 0.2s;
	}
	.stat-item:not(:last-child) {
		border-right: 1px solid #d4d4d8;
	}
	:root.dark .stat-item:not(:last-child) {
		border-color: #27272a;
	}
	.stat-item:hover {
		background: rgba(255, 255, 255, 0.03);
	}

	.stat-icon {
		font-size: 0.75rem;
		line-height: 1;
	}
	.stat-item.agree .stat-icon { color: #34d399; }
	.stat-item.neutral .stat-icon { color: #eab308; }
	.stat-item.disagree .stat-icon { color: #fb7185; }

	.stat-label {
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #52525b;
	}
	:root.dark .stat-label {
		color: #a1a1aa;
	}

	.stat-count {
		font-size: 1.5rem;
		font-weight: 700;
		font-family: ui-monospace, monospace;
		color: #18181b;
	}
	:root.dark .stat-count {
		color: #fafafa;
	}

	/* 底部 */
	.card-footer {
		height: 2.5rem;
		border-top: 2px solid #18181b;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 2rem;
		background: #18181b;
	}
	:root.dark .card-footer {
		border-color: #52525b;
		background: #fafafa;
	}

	.footer-bars {
		display: flex;
		gap: 0.25rem;
	}

	.bar {
		width: 0.25rem;
		height: 1rem;
		background: #ffffff;
		opacity: 0.4;
	}
	:root.dark .bar {
		background: #000000;
	}

	.footer-text {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #ffffff;
	}
	:root.dark .footer-text {
		color: #000000;
	}

	/* 响应式 */
	@media (max-width: 640px) {
		.gb-detail-panel {
			max-width: 100%;
			width: 95%;
		}
		.detail-body {
			padding: 1.25rem;
		}
		.detail-text {
			font-size: 0.9rem;
		}
		.detail-header {
			padding: 0 1.25rem;
		}
		.card-footer {
			padding: 0 1.25rem;
		}
	}
</style>
