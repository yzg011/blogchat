---
import Icon from "@/components/common/Icon.astro";
import MessageBox from "@/components/common/PioMessageBox.astro";
import type { Live2DModelConfig } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	config: Live2DModelConfig;
}

const { config } = Astro.props;

// 获取位置和尺寸配置
const position = config.position || {
	corner: "bottom-right" as const,
	offsetX: 20,
	offsetY: 20,
};
const size = config.size || { width: 280, height: 250 };
---

<div
  id="live2d-widget"
  class="live2d-widget"
  style={`
    width: ${size.width}px;
    height: ${size.height}px;
    ${position.corner?.includes("right") ? "right" : "left"}: ${position.offsetX}px;
    ${position.corner?.includes("top") ? "top" : "bottom"}: ${position.offsetY}px;
  `}
>
  <canvas id="live2d-canvas" width={size.width} height={size.height}></canvas>

  <!-- 右侧工具栏 -->
  <div class="live2d-toolbar">
    <button class="live2d-toolbar-btn" id="toolbar-drag" title="移动">
      <Icon name="material-symbols:drag-indicator" class="text-base" />
    </button>
    <button class="live2d-toolbar-btn" id="toolbar-switch" title="切换动画组">
      <Icon name="material-symbols:swap-horiz" class="text-base" />
    </button>
    <button class="live2d-toolbar-btn active" id="toolbar-info" title="作者信息">
      <Icon name="material-symbols:info" class="text-base" />
    </button>
  </div>

  <!-- 作者信息面板 -->
  {config.author && (
    <div class="live2d-author visible" id="live2d-author">
      <span>by </span>
      {config.author.url ? (
        <a href={config.author.url} target="_blank" rel="noopener noreferrer">
          {config.author.name}
        </a>
      ) : (
        <span>{config.author.name}</span>
      )}
    </div>
  )}

  <!-- 动画组指示器 -->
  <div class="live2d-group-indicator" id="live2d-group-indicator"></div>
</div>

<!-- 引入消息框组件 -->
<MessageBox />

<script is:inline define:vars={{ config, modelPathUrl: url(config.model.path) }}>
  // 使用 window 持久化引用，避免 Swup 导航后局部变量丢失
  let live2dApp = window._live2dApp || null;
  let live2dModel = window._live2dModel || null;

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) {
        resolve();
        return;
      }
      const s = document.createElement("script");
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function initLive2D() {
    if (!config.model || !config.model.path) {
      return;
    }

    try {
      await loadScript("https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js");
      await loadScript("https://cdn.jsdelivr.net/npm/pixi.js@6.5.10/dist/browser/pixi.min.js");
      await loadScript("https://cdn.jsdelivr.net/npm/pixi-live2d-display/dist/cubism4.min.js");

      if (!window.PIXI || !window.PIXI.live2d) {
        return;
      }

      const canvas = document.getElementById("live2d-canvas");
      const size = config.size || { width: 280, height: 250 };
      const resolution = config.resolution || Math.min(window.devicePixelRatio || 1, 2);

      live2dApp = new PIXI.Application({
        view: canvas,
        width: size.width,
        height: size.height,
        backgroundAlpha: 0,
        antialias: true,
        resolution: resolution,
        autoDensity: true,
      });

      live2dModel = await PIXI.live2d.Live2DModel.from(modelPathUrl);

      // Auto-fit model to canvas
      const scaleX = size.width / live2dModel.width;
      const scaleY = size.height / live2dModel.height;
      const fitScale = Math.min(scaleX, scaleY);
      live2dModel.scale.set(fitScale);
      live2dModel.anchor.set(0.5, 0.5);
      live2dModel.x = size.width / 2;
      live2dModel.y = size.height / 2;

      live2dApp.stage.addChild(live2dModel);

      // 持久化到 window，Swup 导航后可恢复引用
      window._live2dApp = live2dApp;
      window._live2dModel = live2dModel;

      // Click interaction — trigger random motion + expression + message
      const allMotionGroups = ["Expression", "TapShort", "TapLong", "Other"];
      let clickMotionGroups = ["Expression", "TapShort"];
      let currentGroupIndex = 0;

      live2dModel.on("hit", (_hitAreas) => {
        if (!window._live2dWasDragging) playRandomMotion();
        window._live2dWasDragging = false;
      });

      canvas.addEventListener("click", () => {
        if (!window._live2dWasDragging) playRandomMotion();
        window._live2dWasDragging = false;
      });

      // Toolbar: switch animation group
      const switchBtn = document.getElementById("toolbar-switch");
      const groupIndicator = document.getElementById("live2d-group-indicator");
      let indicatorTimer = null;

      if (switchBtn) {
        switchBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          currentGroupIndex = (currentGroupIndex + 1) % allMotionGroups.length;
          clickMotionGroups = [allMotionGroups[currentGroupIndex]];
          // Show group name indicator
          if (groupIndicator) {
            const groupNames = { Expression: "表情", TapShort: "短动画", TapLong: "长动画", Other: "其他" };
            groupIndicator.textContent = groupNames[allMotionGroups[currentGroupIndex]] || allMotionGroups[currentGroupIndex];
            groupIndicator.classList.add("show");
            clearTimeout(indicatorTimer);
            indicatorTimer = setTimeout(() => groupIndicator.classList.remove("show"), 1500);
          }
          // Play a random motion from the new group
          if (live2dModel) {
            try {
              live2dModel.motion(clickMotionGroups[0], undefined, 2);
              live2dModel.expression();
            } catch (e) { /* ignore */ }
          }
        });
      }

      // Toolbar: toggle author info
      const infoBtn = document.getElementById("toolbar-info");
      const authorPanel = document.getElementById("live2d-author");

      if (infoBtn && authorPanel) {
        infoBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          authorPanel.classList.toggle("visible");
          infoBtn.classList.toggle("active");
        });
      }

      // Toolbar: drag mode (prevent click-trigger after drag)
      const dragBtn = document.getElementById("toolbar-drag");
      if (dragBtn) {
        dragBtn.addEventListener("click", (e) => {
          e.stopPropagation();
        });
      }

      // Idle animation: play a random motion every 15-30s when idle
      let idleTimer = null;
      function scheduleIdle() {
        clearTimeout(idleTimer);
        const delay = 15000 + Math.random() * 15000;
        idleTimer = setTimeout(() => {
          if (live2dModel) {
            try {
              live2dModel.motion("Idle", 0, 1); // IDLE priority
              live2dModel.expression(); // random expression
            } catch (e) { /* ignore */ }
          }
          scheduleIdle();
        }, delay);
      }
      scheduleIdle();

      function playRandomMotion() {
        if (!live2dModel) return;
        clearTimeout(idleTimer);
        try {
          const group = clickMotionGroups[Math.floor(Math.random() * clickMotionGroups.length)];
          live2dModel.motion(group, undefined, 2); // NORMAL priority, random index
          // Also trigger a random expression
          live2dModel.expression();
        } catch (_e) {
          // Failed to play motion
        }
        showMessage();
        scheduleIdle();
      }

      setupDrag();
    } catch (_error) {
      // Failed to load Live2D model
    }
  }

  function setupDrag() {
    const container = document.getElementById("live2d-widget");
    if (!container) return;

    let isDragging = false;
    let dragStart = { x: 0, y: 0 };
    let containerStart = { x: 0, y: 0 };
    let dragMoved = false;
    const DRAG_THRESHOLD = 5;

    container.addEventListener("mousedown", (e) => {
      if (e.button !== 0) return;
      isDragging = true;
      dragMoved = false;
      dragStart = { x: e.clientX, y: e.clientY };
      const rect = container.getBoundingClientRect();
      containerStart = { x: rect.left, y: rect.top };
      container.style.cursor = "grabbing";
      e.preventDefault();
    });

    document.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      const dx = e.clientX - dragStart.x;
      const dy = e.clientY - dragStart.y;
      if (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD) {
        dragMoved = true;
      }
      const clampedX = Math.max(0, Math.min(containerStart.x + dx, window.innerWidth - container.offsetWidth));
      const clampedY = Math.max(0, Math.min(containerStart.y + dy, window.innerHeight - container.offsetHeight));
      container.style.left = clampedX + "px";
      container.style.right = "auto";
      container.style.top = clampedY + "px";
      container.style.bottom = "auto";
    });

    document.addEventListener("mouseup", () => {
      if (isDragging) {
        isDragging = false;
        if (dragMoved) {
          window._live2dWasDragging = true;
        }
        container.style.cursor = "grab";
      }
    });

    container.addEventListener("touchstart", (e) => {
      if (e.touches.length !== 1) return;
      isDragging = true;
      dragMoved = false;
      const touch = e.touches[0];
      dragStart = { x: touch.clientX, y: touch.clientY };
      const rect = container.getBoundingClientRect();
      containerStart = { x: rect.left, y: rect.top };
      e.preventDefault();
    });

    document.addEventListener("touchmove", (e) => {
      if (!isDragging || e.touches.length !== 1) return;
      const touch = e.touches[0];
      const dx = touch.clientX - dragStart.x;
      const dy = touch.clientY - dragStart.y;
      if (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD) {
        dragMoved = true;
      }
      const clampedX = Math.max(0, Math.min(containerStart.x + dx, window.innerWidth - container.offsetWidth));
      const clampedY = Math.max(0, Math.min(containerStart.y + dy, window.innerHeight - container.offsetHeight));
      container.style.left = clampedX + "px";
      container.style.right = "auto";
      container.style.top = clampedY + "px";
      container.style.bottom = "auto";
      e.preventDefault();
    });

    document.addEventListener("touchend", () => {
      if (isDragging && dragMoved) {
        window._live2dWasDragging = true;
      }
      isDragging = false;
    });

    container.style.cursor = "grab";

    window.addEventListener("resize", () => {
      const rect = container.getBoundingClientRect();
      const maxX = window.innerWidth - container.offsetWidth;
      const maxY = window.innerHeight - container.offsetHeight;
      if (rect.left > maxX) {
        container.style.left = maxX + "px";
        container.style.right = "auto";
      }
      if (rect.top > maxY) {
        container.style.top = maxY + "px";
        container.style.bottom = "auto";
      }
    });
  }

  function showMessage() {
    const messages = config.interactive?.clickMessages || [
      "你好！",
      "有什么需要帮助的吗？",
      "今天天气真不错呢！",
      "要不要一起玩游戏？",
      "记得按时休息哦！",
    ];
    const randomMessage = messages[Math.floor(Math.random() * messages.length)];
    if (window.showModelMessage) {
      window.showModelMessage(randomMessage, {
        containerId: "live2d-widget",
        displayTime: config.interactive?.messageDisplayTime || 3000
      });
    }
  }

  function handleResponsive() {
    const widget = document.getElementById("live2d-widget");
    if (!widget) return;
    // 用户手动关闭时不强制覆盖
    if (localStorage.getItem("live2d-hidden") === "true") return;
    if (config.responsive?.hideOnMobile) {
      const breakpoint = config.responsive.mobileBreakpoint || 768;
      widget.style.display = window.innerWidth <= breakpoint ? "none" : "";
    }
  }

  // 检查是否需要重新初始化（canvas 被替换或 PIXI 引用丢失）
  function needsReinit() {
    if (!window.live2dModelInitialized) return true;
    const canvas = document.getElementById("live2d-canvas");
    // canvas 被替换（不在 DOM 或 PIXI 引用的 view 不是当前 canvas）
    if (!canvas || (window._live2dApp && window._live2dApp.renderer.view !== canvas)) {
      window.live2dModelInitialized = false;
      window._live2dApp = null;
      window._live2dModel = null;
      return true;
    }
    return false;
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      if (needsReinit()) {
        initLive2D();
        window.live2dModelInitialized = true;
      }
      live2dApp = window._live2dApp;
      live2dModel = window._live2dModel;
      handleResponsive();
    });
  } else {
    if (needsReinit()) {
      initLive2D();
      window.live2dModelInitialized = true;
    }
    live2dApp = window._live2dApp;
    live2dModel = window._live2dModel;
    handleResponsive();
  }

  window.addEventListener("resize", handleResponsive);

  if (typeof window.swup !== "undefined" && window.swup.hooks) {
    window.swup.hooks.on("content:replace", () => {
      setTimeout(handleResponsive, 100);
    });
  } else {
    document.addEventListener("swup:enable", () => {
      if (window.swup?.hooks) {
        window.swup.hooks.on("content:replace", () => {
          setTimeout(handleResponsive, 100);
        });
      }
    });
  }
</script>

<style>
  .live2d-widget {
    position: fixed;
    z-index: 999;
    pointer-events: auto;
    cursor: grab;
  }

  #live2d-canvas {
    pointer-events: auto;
    cursor: pointer;
    transition: opacity 0.3s ease;
    width: 100%;
    height: 100%;
  }

  .live2d-widget:hover #live2d-canvas {
    opacity: 1;
  }

  .live2d-widget:active {
    cursor: grabbing;
  }

  /* 右侧工具栏 */
  .live2d-toolbar {
    position: absolute;
    right: -34px;
    top: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    z-index: 1000;
  }

  /* 透明桥接区域，防止鼠标移到 toolbar 时脱离 hover */
  .live2d-widget::after {
    content: "";
    position: absolute;
    top: 0;
    right: -40px;
    width: 46px;
    height: 100%;
    z-index: 999;
  }

  .live2d-widget:hover .live2d-toolbar {
    opacity: 1;
    pointer-events: auto;
  }

  .live2d-toolbar-btn {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(0.95 0 0 / 0.85);
    border: 1px solid oklch(0.8 0 0);
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    color: oklch(0.4 0 0);
    backdrop-filter: blur(4px);
  }

  :root.dark .live2d-toolbar-btn {
    background: oklch(0.2 0 0 / 0.85);
    border-color: oklch(0.4 0 0);
    color: oklch(0.8 0 0);
  }

  .live2d-toolbar-btn:hover {
    background: oklch(0.5 0 0 / 0.9);
    color: oklch(1 0 0);
  }

  :root.dark .live2d-toolbar-btn:hover {
    background: oklch(0.7 0 0 / 0.9);
    color: oklch(0.1 0 0);
  }

  .live2d-toolbar-btn.active {
    background: oklch(0.4 0 0 / 0.9);
    color: oklch(1 0 0);
  }

  :root.dark .live2d-toolbar-btn.active {
    background: oklch(0.7 0 0 / 0.9);
    color: oklch(0.1 0 0);
  }

  /* 作者信息面板 */
  .live2d-author {
    position: absolute;
    top: -28px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 15px;
    font-weight: 600;
    line-height: 1;
    color: oklch(0.3 0 0);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    white-space: nowrap;
    text-shadow: 0 1px 3px oklch(1 0 0 / 0.6);
    letter-spacing: 0.02em;
  }

  .live2d-author.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .live2d-author a {
    color: oklch(0.25 0 0);
    text-decoration: none;
    border-bottom: 2px solid oklch(0.25 0 0);
    padding-bottom: 1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .live2d-author a:hover {
    color: oklch(0.1 0 0);
    border-color: oklch(0.1 0 0);
  }

  :root.dark .live2d-author {
    color: oklch(0.85 0 0);
    text-shadow: 0 1px 3px oklch(0 0 0 / 0.6);
  }

  :root.dark .live2d-author a {
    color: oklch(0.95 0 0);
    border-bottom-color: oklch(0.95 0 0);
  }

  :root.dark .live2d-author a:hover {
    color: oklch(1 0 0);
    border-color: oklch(1 0 0);
  }

  /* 动画组指示器 */
  .live2d-group-indicator {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    padding: 2px 8px;
    background: oklch(0.2 0 0 / 0.7);
    color: oklch(0.95 0 0);
    border-radius: 3px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    white-space: nowrap;
    backdrop-filter: blur(4px);
  }

  :root.dark .live2d-group-indicator {
    background: oklch(0.9 0 0 / 0.7);
    color: oklch(0.1 0 0);
  }

  .live2d-group-indicator.show {
    opacity: 1;
  }
</style>
