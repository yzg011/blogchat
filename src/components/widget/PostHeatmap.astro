---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

interface Post {
	id: string;
	data: {
		title: string;
		published: Date;
	};
}

interface Props {
	posts: Post[];
}

const { posts } = Astro.props;

const now = new Date();
const currentYear = now.getFullYear();

// 收集所有有文章的年份
const yearSet = new Set<number>();
for (const p of posts) {
	yearSet.add(p.data.published.getFullYear());
}
const years = Array.from(yearSet).sort((a, b) => b - a);

// 按年份+月+周统计文章数量
const postCountByYearMonthWeek = new Map<string, number>(); // key: "year-month-week"

for (const p of posts) {
	const d = p.data.published;
	const year = d.getFullYear();
	const month = d.getMonth();
	const day = d.getDate();
	const week = day <= 7 ? 0 : day <= 14 ? 1 : day <= 21 ? 2 : 3;
	const key = `${year}-${month}-${week}`;
	postCountByYearMonthWeek.set(
		key,
		(postCountByYearMonthWeek.get(key) || 0) + 1,
	);
}

// 按年份统计每月文章总数
const monthTotalsByYear = new Map<string, number>(); // key: "year-month"
const totalPostsByYear = new Map<number, number>();
for (const p of posts) {
	const d = p.data.published;
	const year = d.getFullYear();
	const key = `${year}-${d.getMonth()}`;
	monthTotalsByYear.set(key, (monthTotalsByYear.get(key) || 0) + 1);
	totalPostsByYear.set(year, (totalPostsByYear.get(year) || 0) + 1);
}

// 月份标签
const monthLabels = [
	i18n(I18nKey.calendarJanuary),
	i18n(I18nKey.calendarFebruary),
	i18n(I18nKey.calendarMarch),
	i18n(I18nKey.calendarApril),
	i18n(I18nKey.calendarMay),
	i18n(I18nKey.calendarJune),
	i18n(I18nKey.calendarJuly),
	i18n(I18nKey.calendarAugust),
	i18n(I18nKey.calendarSeptember),
	i18n(I18nKey.calendarOctober),
	i18n(I18nKey.calendarNovember),
	i18n(I18nKey.calendarDecember),
];

// 周标签
const weekLabels = ["W1", "W2", "W3", "W4"];

// 为每个年份构建网格数据
interface MonthWeekCell {
	month: number;
	week: number;
	count: number;
	level: number;
}

function buildGridForYear(year: number): MonthWeekCell[][] {
	const yearCounts = new Map<string, number>();
	for (const [key, count] of postCountByYearMonthWeek) {
		if (key.startsWith(`${year}-`)) {
			yearCounts.set(key, count);
		}
	}
	const maxCount = Math.max(1, ...Array.from(yearCounts.values()));

	function getLevel(count: number): number {
		if (count === 0) return 0;
		if (maxCount <= 1) return 1;
		const ratio = count / maxCount;
		if (ratio <= 0.25) return 1;
		if (ratio <= 0.5) return 2;
		if (ratio <= 0.75) return 3;
		return 4;
	}

	const grid: MonthWeekCell[][] = [];
	for (let w = 0; w < 4; w++) {
		const row: MonthWeekCell[] = [];
		for (let m = 0; m < 12; m++) {
			const key = `${year}-${m}-${w}`;
			const count = yearCounts.get(key) || 0;
			row.push({ month: m, week: w, count, level: getLevel(count) });
		}
		grid.push(row);
	}
	return grid;
}

// 序列化年份网格数据供客户端使用
const yearGridsData: Record<
	number,
	{ grid: MonthWeekCell[][]; monthTotals: number[]; total: number }
> = {};
for (const year of years) {
	const grid = buildGridForYear(year);
	const monthTotals: number[] = [];
	for (let m = 0; m < 12; m++) {
		monthTotals.push(monthTotalsByYear.get(`${year}-${m}`) || 0);
	}
	yearGridsData[year] = {
		grid,
		monthTotals,
		total: totalPostsByYear.get(year) || 0,
	};
}

// 当前年份的网格（用于初始渲染）
const initialYear = currentYear;
const initialData = yearGridsData[initialYear] ||
	yearGridsData[years[0]] || { grid: [], monthTotals: [], total: 0 };
---

<div class="post-heatmap" id="post-heatmap"
	data-grids={JSON.stringify(yearGridsData)}
	data-month-labels={JSON.stringify(monthLabels)}
	data-initial-year={initialYear}
>
	<div class="heatmap-section-title">
		<span class="iconify" data-icon="mdi:file-document-outline" data-width="16"></span>
		<span>{i18n(I18nKey.postHeatmap)}</span>
		<span class="heatmap-stats" id="post-heatmap-stats" data-suffix={i18n(I18nKey.postsCount)}>{initialYear} | {initialData.total} {i18n(I18nKey.postsCount)}</span>
	</div>

	<div class="heatmap-body" id="post-heatmap-body">
		<div class="post-heatmap-grid-wrap">
			<div class="post-heatmap-weeks">
				{weekLabels.map((label) => (
					<span class="post-heatmap-week-label">{label}</span>
				))}
			</div>
			<div class="post-heatmap-grid" id="post-heatmap-grid">
				{initialData.grid.map((row) => (
					<div class="post-heatmap-row">
						{row.map((cell) => (
							<div
								class={`heatmap-cell post-cell level-${cell.level}`}
								data-month={cell.month}
								title={`${monthLabels[cell.month]} 第${cell.week + 1}周：${cell.count} 篇`}
							></div>
						))}
					</div>
				))}
			</div>
			<div class="post-heatmap-year-vert" id="heatmap-year-nav-vert">
				<button class="heatmap-year-btn" id="heatmap-year-prev" aria-label="上一年">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</button>
				<span class="heatmap-year-label-vert" id="heatmap-year-label">{initialYear}</span>
				<button class="heatmap-year-btn" id="heatmap-year-next" aria-label="下一年">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
				</button>
			</div>
		</div>
	</div>

</div>

<script>
const container = document.getElementById("post-heatmap");
if (container) {
	const gridsData = JSON.parse(container.getAttribute("data-grids") || "{}");
	const monthLabels = JSON.parse(container.getAttribute("data-month-labels") || "[]");
	const years = Object.keys(gridsData).map(Number).sort((a, b) => b - a);
	let currentYearIdx = years.indexOf(Number(container.getAttribute("data-initial-year")));
	if (currentYearIdx === -1) currentYearIdx = 0;

	const yearLabel = document.getElementById("heatmap-year-label");
	const prevBtn = document.getElementById("heatmap-year-prev");
	const nextBtn = document.getElementById("heatmap-year-next");
	const gridEl = document.getElementById("post-heatmap-grid");
	const statsEl = document.getElementById("post-heatmap-stats");

	// 初始按钮状态
	const initIdx = currentYearIdx;
	prevBtn?.classList.toggle("is-disabled", initIdx >= years.length - 1);
	nextBtn?.classList.toggle("is-disabled", initIdx <= 0);

	function renderYear(year: number) {
		if (!gridEl || !yearLabel) return;
		const data = gridsData[year];
		if (!data) return;

		yearLabel.textContent = String(year);

		if (statsEl) {
			const suffix = statsEl.getAttribute("data-suffix") || "";
			statsEl.textContent = `${year} | ${data.total} ${suffix}`;
		}

		// 更新按钮状态
		const idx = years.indexOf(year);
		prevBtn?.classList.toggle("is-disabled", idx >= years.length - 1);
		nextBtn?.classList.toggle("is-disabled", idx <= 0);

		// 重建网格
		gridEl.innerHTML = "";
		for (let w = 0; w < 4; w++) {
			const row = document.createElement("div");
			row.className = "post-heatmap-row";
			for (let m = 0; m < 12; m++) {
				const cell = data.grid[w][m];
				const div = document.createElement("div");
				div.className = `heatmap-cell post-cell level-${cell.level}`;
				div.setAttribute("data-month", String(cell.month));
				div.title = `${monthLabels[cell.month]} 第${cell.week + 1}周：${cell.count} 篇`;
				row.appendChild(div);
			}
			gridEl.appendChild(row);
		}
	}

	prevBtn?.addEventListener("click", () => {
		if (currentYearIdx < years.length - 1) {
			currentYearIdx++;
			renderYear(years[currentYearIdx]);
		}
	});

	nextBtn?.addEventListener("click", () => {
		if (currentYearIdx > 0) {
			currentYearIdx--;
			renderYear(years[currentYearIdx]);
		}
	});

	// 月份高亮点击
	container.addEventListener("click", (e) => {
		const cell = (e.target as HTMLElement).closest(".post-cell") as HTMLElement | null;
		if (!cell) return;
		const month = cell.getAttribute("data-month");
		if (month === null) return;

		const cells = container.querySelectorAll(`.post-cell[data-month="${month}"]`);
		const isActive = cell.classList.contains("is-month-active");

		container.querySelectorAll(".post-cell.is-month-active").forEach((c) => {
			c.classList.remove("is-month-active");
		});

		if (!isActive) {
			cells.forEach((c) => c.classList.add("is-month-active"));
		}
	});
}
</script>
