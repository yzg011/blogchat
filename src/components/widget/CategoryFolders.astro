---
import Icon from "@/components/common/Icon.astro";
import type { CategoryTagGroup } from "@/utils/content-utils";

interface Props {
	groups: CategoryTagGroup[];
}

const { groups } = Astro.props;
---

<div class="category-folders">
	{groups.map((group, index) => {
		const panelId = `category-folder-panel-${index}`;
		return (
			<details class="category-folder">
				<summary class="category-folder__summary" aria-controls={panelId}>
					<span class="category-folder__icon" aria-hidden="true">
						<Icon
							name="material-symbols:folder-rounded"
							class="category-folder__icon-closed"
						/>
						<Icon
							name="material-symbols:folder-open-rounded"
							class="category-folder__icon-open"
						/>
					</span>
					<span class="category-folder__heading">
						<strong class="category-folder__name">{group.name}</strong>
						<span class="category-folder__meta">
							{group.count} 篇文章 · {group.tags.length} 个标签
						</span>
					</span>
					<Icon
						name="material-symbols:keyboard-arrow-down-rounded"
						class="category-folder__chevron"
						aria-hidden="true"
					/>
				</summary>

				<div id={panelId} class="category-folder__content">
					{group.tags.length > 0 ? (
						<div class="category-folder__tags" aria-label={`${group.name}分类下的标签`}>
							{group.tags.map((tag) => (
								<a
									href={tag.url}
									class="category-folder__tag"
									aria-label={`查看${group.name}分类中带有${tag.name}标签的文章`}
								>
									<span class="category-folder__tag-name">#{tag.name}</span>
									<span class="category-folder__tag-count">{tag.count}</span>
								</a>
							))}
						</div>
					) : (
						<p class="category-folder__empty">暂无标签</p>
					)}
				</div>
			</details>
		);
	})}
</div>
