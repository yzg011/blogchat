---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

interface Props {
	username: string;
	token?: string;
	proxyUrl?: string;
}

const { username } = Astro.props;

const now = new Date();
const currentYear = now.getFullYear();

// 使用第三方 API 获取 GitHub 贡献数据（无需 token，数据与 GitHub 贡献图一致）
// API: https://github-contributions-api.jogruber.de/v4/{username}?y=last
interface ContributionDay {
	date: string;
	count: number;
	level: number;
}

let contributionData: ContributionDay[] = [];
let fetchError = false;
let errorMessage = "";

async function fetchContributions(
	username: string,
): Promise<ContributionDay[]> {
	const controller = new AbortController();
	const timer = setTimeout(() => controller.abort(), 15000);
	try {
		const response = await fetch(
			`https://github-contributions-api.jogruber.de/v4/${username}?y=last`,
			{
				headers: { "User-Agent": "Mozilla/5.0" },
				signal: controller.signal,
			},
		);
		clearTimeout(timer);
		if (!response.ok) throw new Error(`API: ${response.status}`);
		const data = await response.json();
		const days = data.contributions || [];
		return days.map((d: { date: string; count: number; level: number }) => ({
			date: d.date,
			count: d.count,
			level: d.level,
		}));
	} finally {
		clearTimeout(timer);
	}
}

try {
	contributionData = await fetchContributions(username);
} catch (e) {
	fetchError = true;
	if (e instanceof Error && e.name === "AbortError") {
		errorMessage = "网络连接超时，无法访问 GitHub 贡献数据";
	} else {
		errorMessage = "GitHub 数据获取失败，请检查用户名或网络连接";
	}
}

// 构建贡献数据映射
const countByDate = new Map<string, number>();
const levelByDate = new Map<string, number>();
let maxCount = 0;
for (const d of contributionData) {
	countByDate.set(d.date, d.count);
	levelByDate.set(d.date, d.level);
	if (d.count > maxCount) maxCount = d.count;
}

function getLevel(count: number): number {
	if (count === 0) return 0;
	if (maxCount <= 1) return 1;
	const ratio = count / maxCount;
	if (ratio <= 0.25) return 1;
	if (ratio <= 0.5) return 2;
	if (ratio <= 0.75) return 3;
	return 4;
}

// 构建网格：7行 × N列（周），从当年1/1到今日
interface Cell {
	date: string;
	count: number;
	level: number;
	visible: boolean;
}

function buildYearGrid(): Cell[][] {
	const startDate = new Date(currentYear, 0, 1);
	const endDate = now;
	const startDay = startDate.getDay();
	const startOffset = startDay === 0 ? -6 : 1 - startDay;
	startDate.setDate(startDate.getDate() + startOffset);

	const weeks: Cell[][] = [];
	const current = new Date(startDate);

	while (current <= endDate || current.getDay() !== 1) {
		const week: Cell[] = [];
		for (let i = 0; i < 7; i++) {
			const dateStr = `${current.getFullYear()}-${String(current.getMonth() + 1).padStart(2, "0")}-${String(current.getDate()).padStart(2, "0")}`;
			const count = countByDate.get(dateStr) || 0;
			// 优先使用 API 返回的 level，回退到本地计算
			const level = levelByDate.get(dateStr) ?? getLevel(count);
			const inYear = current.getFullYear() === currentYear;
			const afterToday = current > endDate;
			week.push({
				date: dateStr,
				count,
				level: inYear && !afterToday ? level : 0,
				visible: inYear && !afterToday,
			});
			current.setDate(current.getDate() + 1);
		}
		weeks.push(week);
		if (current > endDate && current.getFullYear() > currentYear) break;
	}
	return weeks;
}

const weeks = buildYearGrid();

// 统计
const totalContributions = contributionData.reduce(
	(sum, d) => sum + d.count,
	0,
);
const activeDays = contributionData.filter((d) => d.count > 0).length;

// 星期标签（周一到周日）
const dayLabels = [
	i18n(I18nKey.calendarMonday),
	i18n(I18nKey.calendarTuesday),
	i18n(I18nKey.calendarWednesday),
	i18n(I18nKey.calendarThursday),
	i18n(I18nKey.calendarFriday),
	i18n(I18nKey.calendarSaturday),
	i18n(I18nKey.calendarSunday),
];
---

<div class="github-heatmap">
	<div class="heatmap-section-title">
		<span class="iconify" data-icon="mdi:github" data-width="16"></span>
		<span>{i18n(I18nKey.githubHeatmap)}</span>
		{!fetchError && contributionData.length > 0 && (
			<span class="heatmap-stats">{currentYear} | {activeDays}d · {totalContributions} {i18n(I18nKey.githubContributions)}</span>
		)}
	</div>

	{fetchError && (
		<div class="heatmap-error">{errorMessage || "GitHub 数据获取失败"}</div>
	)}

	{!fetchError && contributionData.length === 0 && (
		<div class="heatmap-error">暂无 GitHub 贡献数据</div>
	)}

	{!fetchError && contributionData.length > 0 && (
		<div class="heatmap-body">
			<div class="heatmap-grid-wrap">
				<div class="heatmap-days">
					{dayLabels.map((label) => (
						<span class="heatmap-day-label">{label}</span>
					))}
				</div>
				<div class="heatmap-grid">
					{weeks.map((week) => (
						<div class="heatmap-week">
							{week.map((cell) => (
								<div
									class={`heatmap-cell github-cell level-${cell.level}`}
									title={cell.visible ? `${cell.date} · ${cell.count} ${i18n(I18nKey.githubCommits)}` : ""}
									style={cell.visible ? "" : "visibility:hidden"}
								></div>
							))}
						</div>
					))}
				</div>
			</div>
		</div>
	)}

</div>
