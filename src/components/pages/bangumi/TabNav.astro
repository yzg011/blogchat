---
interface Tab {
	id: string;
	name: string;
	count?: number;
}

interface Props {
	tabs: Tab[];
	activeTab: string;
}

const { tabs, activeTab } = Astro.props;
---

<div class="border-b border-(--line-divider) mb-3 relative">
  <div class="overflow-x-auto" data-tab-scroll-container>
    <nav class="flex min-w-max space-x-8" aria-label="Tabs" data-tab-nav>
      <!-- 滑动下划线指示器 -->
      <div class="tab-underline-indicator" data-tab-indicator></div>
      
      {tabs.map((tab) => (
        <button
          class:list={[
            "tab-nav-btn whitespace-nowrap py-4 px-1 font-medium text-sm transition-colors duration-200",
            {
              "tab-nav-btn-active": tab.id === activeTab,
              "tab-nav-btn-inactive": tab.id !== activeTab
            }
          ]}
          data-tab={tab.id}
          type="button"
        >
          {tab.name}
          {tab.count !== undefined && (
            <span class="ml-2 tab-count">
              {tab.count}
            </span>
          )}
        </button>
      ))}
    </nav>
  </div>
</div>

<style>
  [data-tab-nav] {
    position: relative;
  }

  .tab-underline-indicator {
    position: absolute;
    bottom: 0;
    height: 2px;
    background: black;
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
    pointer-events: none;
  }

  :root.dark .tab-underline-indicator {
    background: white;
  }

  .tab-nav-btn {
    position: relative;
    z-index: 2;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #6b7280;
    border-bottom: 2px solid transparent;
  }

  :root.dark .tab-nav-btn {
    color: #9ca3af;
  }

  .tab-nav-btn:hover {
    color: #374151;
  }

  :root.dark .tab-nav-btn:hover {
    color: #d1d5db;
  }

  .tab-nav-btn-active {
    color: black;
  }

  :root.dark .tab-nav-btn-active {
    color: white;
  }

  .tab-count {
    color: #6b7280;
    font-size: 0.75rem;
  }

  :root.dark .tab-count {
    color: #9ca3af;
  }

  .tab-nav-btn-active .tab-count {
    color: inherit;
  }
</style>

<script>
  function initTabNavigation() {
    const tabButtons = document.querySelectorAll('[data-tab]');
    const sections = document.querySelectorAll('[data-section]');
    const indicator = document.querySelector('[data-tab-indicator]') as HTMLElement | null;

    function updateIndicator(targetBtn: HTMLElement) {
      if (!indicator) return;
      const nav = targetBtn.closest('[data-tab-nav]') as HTMLElement | null;
      if (!nav) return;
      const navRect = nav.getBoundingClientRect();
      const btnRect = targetBtn.getBoundingClientRect();
      indicator.style.left = (btnRect.left - navRect.left) + 'px';
      indicator.style.width = btnRect.width + 'px';
      indicator.style.opacity = '1';
    }

    function hydrateVisibleImages(targetTab: string) {
      const visibleItems = document.querySelectorAll(
        `[data-section="${targetTab}"] [data-item-section="${targetTab}"]:not(.hidden)`
      );

      visibleItems.forEach((item) => {
        const htmlItem = item as HTMLElement;
        if (htmlItem.style.display === 'none') {
          return;
        }

        const image = htmlItem.querySelector('img[data-src]');
        if (image) {
          const deferredSrc = image.getAttribute('data-src');
          if (deferredSrc) {
            image.setAttribute('src', deferredSrc);
            image.removeAttribute('data-src');
          }
        }
      });
    }

    function activateTab(targetTab: string, shouldSyncHash = true) {
      if (!targetTab) {
        return;
      }

      const targetButton = Array.from(tabButtons).find(
        (button) => (button as HTMLButtonElement).dataset.tab === targetTab
      ) as HTMLButtonElement | undefined;

      if (!targetButton) {
        return;
      }

      // Update active tab
      tabButtons.forEach(btn => {
        btn.classList.remove('tab-nav-btn-active');
        btn.classList.add('tab-nav-btn-inactive');
      });

      targetButton.classList.remove('tab-nav-btn-inactive');
      targetButton.classList.add('tab-nav-btn-active');

      // Update indicator position
      updateIndicator(targetButton);

      // Show/hide sections
      sections.forEach(section => {
        const htmlSection = section as HTMLElement;
        if (htmlSection.dataset.section === targetTab) {
          htmlSection.classList.remove('hidden');
        } else {
          htmlSection.classList.add('hidden');
        }
      });

      // Trigger event for FilterControls to re-initialize
      window.dispatchEvent(new CustomEvent('tabSwitched', { detail: { sectionId: targetTab } }));

      hydrateVisibleImages(targetTab);

      if (shouldSyncHash) {
        const nextHash = `#${encodeURIComponent(targetTab)}`;
        if (window.location.hash !== nextHash) {
          window.history.replaceState(null, '', nextHash);
        }
      }
    }

    function getTabFromHash() {
      const hash = window.location.hash.replace(/^#/, '');
      if (!hash) {
        return '';
      }
      try {
        return decodeURIComponent(hash);
      } catch {
        return '';
      }
    }

    tabButtons.forEach(button => {
      button.addEventListener('click', (event) => {
        const currentButton = event.currentTarget as HTMLButtonElement;
        const targetTab = currentButton.dataset.tab;
        if (targetTab) {
          activateTab(targetTab, true);
        }
      });
    });

    const initialTab = getTabFromHash();
    if (initialTab) {
      activateTab(initialTab, false);
    } else {
      // Initialize indicator for the default active tab
      const activeBtn = document.querySelector('.tab-nav-btn-active') as HTMLElement | null;
      if (activeBtn) {
        requestAnimationFrame(() => {
          updateIndicator(activeBtn);
        });
      }
    }

    window.addEventListener('hashchange', () => {
      const tabFromHash = getTabFromHash();
      if (tabFromHash) {
        activateTab(tabFromHash, false);
      }
    });

    // Update indicator on resize
    window.addEventListener('resize', () => {
      const activeBtn = document.querySelector('.tab-nav-btn-active') as HTMLElement | null;
      if (activeBtn) {
        updateIndicator(activeBtn);
      }
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTabNavigation);
  } else {
    initTabNavigation();
  }
</script>
