---
import Live2DWidget from "@components/features/Live2DWidget.astro";
import PrivacyModal from "@components/features/PrivacyModal.astro";
import SpineModel from "@components/features/SpineModel.astro";
import Footer from "@components/layout/Footer.astro";
import HomeHero from "@components/layout/HomeHero.astro";
import HomePortal from "@components/layout/HomePortal.astro";
import Navbar from "@components/layout/Navbar.astro";
import NavMenuPanel from "@components/layout/NavMenuPanel.astro";
import type { MarkdownHeading } from "astro";
import AISearch from "@/components/controls/AISearch.svelte";
import FloatingDock from "@/components/controls/FloatingDock.astro";
import CategoryBar from "@/components/layout/CategoryBar.astro";
import CategoryFollowBar from "@/components/layout/CategoryFollowBar.astro";
import { live2dModelConfig, navBarConfig, siteConfig } from "@/config";
import { LinkPresets } from "@/constants/link-presets";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { isHomePage } from "@/utils/layout-utils";
import Layout from "./Layout.astro";

import "@/styles/markdown.css";
import "@/styles/expressive-code.css";
import "@/styles/toc.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	postCategory?: string;
	headings?: MarkdownHeading[];
	bannerPostMeta?: {
		title: string;
		published: Date;
		updated?: Date;
		words?: number;
		minutes?: number;
	};
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	postCategory,
	headings = [],
	bannerPostMeta: _bannerPostMeta,
} = Astro.props;

const isHomePageCheck = isHomePage(Astro.url.pathname);
const isPostPage = !!postSlug;
const isArchive = Astro.url.pathname.replace(/\/$/, "").endsWith("/archive");
const shouldRenderCategoryBar = !!siteConfig.categoryBar;
const navbarWidthFull = siteConfig.navbar.widthFull ?? false;

const navLinks = navBarConfig.links.map((item) => {
	if (typeof item === "number") return LinkPresets[item];
	return item;
});
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle} postSlug={postSlug}>

<slot slot="head" name="head"></slot>

{/* Navbar — 极简 sticky 顶栏 */}
<div
	id="top-row"
	class="z-50 pointer-events-none relative mx-auto"
	class:list={[
		"sticky top-0 left-0 right-0 z-80",
		navbarWidthFull ? "w-full" : "w-full max-w-(--page-width) px-0 md:px-4",
	]}
>
	<div id="navbar-wrapper" class="pointer-events-auto bg-(--page-bg)">
		<Navbar></Navbar>
	</div>
</div>

<NavMenuPanel links={navLinks} />

{/* 主内容容器 — 单列居中，无壁纸/三栏 */}
<div class="relative w-full" id="main-grid-wrapper">
	<div class="mx-auto max-w-5xl px-4 md:px-6" data-sidebar-position="none" id="main-grid">
		{/* Swup 占位：保留 left/right sidebar 容器以满足 swup containers 协议 */}
		<div id="left-sidebar-dynamic" class="hidden"></div>
		<div id="right-sidebar-dynamic" class="hidden"></div>

		<main id="swup-container" class="transition-swup-main" data-current-post-category={postCategory || ""}>
			{isPostPage && (
				<div id="article-toc-wrapper" class="article-toc-wrapper hidden xl:block">
					<div id="article-toc-container" class="article-toc-container">
						<div class="article-toc-header">
							<span class="article-toc-title">{i18n(I18nKey.tableOfContents)}</span>
						</div>
						<div class="toc-scroll-container custom-scrollbar article-toc-body">
							<div class="toc-content" id="article-toc-content"></div>
						</div>
					</div>
				</div>
			)}
			{shouldRenderCategoryBar && <div id="category-bar-wrapper"><CategoryBar title={title} postSlug={postSlug} postCategory={postCategory} /></div>}
			{(isArchive || isPostPage) && <CategoryFollowBar />}

			{/* 首页：顶部 Hero + 门户信息层（profile / 公告 / 站点统计 / 分类 / 标签） */}
			{isHomePageCheck && (
				<>
					<HomeHero />
					<HomePortal />
				</>
			)}

			<h1 class="sr-only">{title}</h1>





			<div id="content-wrapper" class="onload-animation transition-swup-leaving">
				<slot></slot>
			</div>
			<div class="footer onload-animation mt-16 pt-8 border-t">
				<Footer></Footer>
			</div>
		</main>

		{/* Live2D / Spine — 由悬浮坞控制显隐 */}
		<SpineModel></SpineModel>
		{live2dModelConfig.enable && <Live2DWidget config={live2dModelConfig} />}
	</div>
</div>

<FloatingDock headings={headings} />

<AISearch client:load />

<PrivacyModal />

</Layout>

<style is:global>
	#main-grid {
		--page-width: 64rem;
	}
	/* 极简 onload 淡入 */
	.onload-animation {
		animation: fadeUp 0.5s ease both;
	}
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(0.5rem); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* 文章页外部浮动目录 - 独立于主内容区域 */
	.article-toc-wrapper {
		position: absolute;
		left: calc(50% + 32rem);
		top: 0;
		width: 15rem;
		max-width: 15rem;
		pointer-events: none;
		z-index: 10;
		transition: left 0.3s ease;
	}

	.article-toc-wrapper:has(.article-toc-container:hover) {
		left: calc(50% + 31.5rem);
	}

	.article-toc-container {
		position: sticky;
		top: 6rem;
		pointer-events: auto;
		max-height: calc(100vh - 7rem);
		display: flex;
		flex-direction: column;
		border-radius: 1rem;
		overflow: hidden;
		transition: transform 0.25s ease;
	}

	.article-toc-container:hover {
		transform: translateX(-6px);
	}

	.article-toc-header {
		padding: 0.75rem 1rem;
		border-bottom: 1px solid color-mix(in oklab, var(--line-divider) 50%, transparent);
		flex-shrink: 0;
	}

	.article-toc-title {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--primary);
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.article-toc-body {
		flex: 1;
		overflow-y: auto;
		max-height: calc(100vh - 11rem);
		padding: 0.5rem;
	}

	@media (max-width: 1280px) {
		.article-toc-wrapper {
			display: none !important;
		}
	}

	/* 文章页显示外部浮动目录时，隐藏侧边栏中的目录组件避免重复 */
	:global(#sidebar-toc:has(~ #main-grid-wrapper #article-toc-wrapper)),
	:global(#article-toc-wrapper ~ * #sidebar-toc) {
		display: none !important;
	}
</style>

<script>
	import { TOCManager } from "@/utils/toc-utils";
	import { isPostPage } from "@/utils/navigation-utils";

	let articleTocManager: TOCManager | null = null;

	function alignTOCCoverImage() {
		const wrapper = document.getElementById("article-toc-wrapper");
		if (!wrapper) return;

		const mainGrid = document.getElementById("main-grid");
		if (!mainGrid) return;

		const contentWrapper = document.getElementById("content-wrapper");
		if (!contentWrapper) return;

		let offsetTop = 0;
		const mainGridRect = mainGrid.getBoundingClientRect();

		// 对齐到文章卡片顶部
		const postCard = document.getElementById("post-container");
		if (postCard) {
			offsetTop = postCard.getBoundingClientRect().top - mainGridRect.top;
		} else {
			offsetTop = contentWrapper.getBoundingClientRect().top - mainGridRect.top;
		}

		wrapper.style.top = `${offsetTop}px`;
		// 让 wrapper 高度撑满剩余内容区域，sticky 才能全程跟随
		wrapper.style.height = `${mainGrid.offsetHeight - offsetTop}px`;
	}

	function initArticleTOC() {
		cleanupArticleTOC();
		if (!isPostPage()) return;

		const tocContent = document.getElementById("article-toc-content");
		const wrapper = document.getElementById("article-toc-wrapper");
		if (!tocContent || !wrapper) return;

		try {
			if (articleTocManager) {
				articleTocManager.cleanup();
			}

			articleTocManager = new TOCManager({
				contentId: "article-toc-content",
				indicatorId: "article-active-indicator",
				maxLevel: 3,
				scrollOffset: 80,
			});

			articleTocManager.init();

			tocContent.addEventListener("click", (e) => {
				const target = e.target as Element | null;
				const anchor = target?.closest('a[href^="#"]');
				if (anchor) {
					window.tocInternalNavigation = true;
				}
			}, { capture: true });

			alignTOCCoverImage();
		} catch (error) {
			console.error("Failed to init ArticleTOC:", error);
		}
	}

	function cleanupArticleTOC() {
		if (articleTocManager) {
			articleTocManager.cleanup();
			articleTocManager = null;
		}
	}

	initArticleTOC();

	document.addEventListener("swup:contentReplaced", () => setTimeout(initArticleTOC, 100));
	document.addEventListener("astro:page-load", () => setTimeout(initArticleTOC, 100));
	window.addEventListener("popstate", () => setTimeout(initArticleTOC, 200));
	document.addEventListener("password:decrypted", () => setTimeout(initArticleTOC, 200));

	let resizeTimer: ReturnType<typeof setTimeout>;
	window.addEventListener("resize", () => {
		clearTimeout(resizeTimer);
		resizeTimer = setTimeout(alignTOCCoverImage, 150);
	});

	// 监听 main-grid 高度变化（图片加载、内容展开等），实时更新 wrapper 高度
	const mainGridEl = document.getElementById("main-grid");
	if (mainGridEl) {
		const ro = new ResizeObserver(() => alignTOCCoverImage());
		ro.observe(mainGridEl);
	}

	// TOC 边框样式：亮色纯黑边框，暗色纯白边框，无背景
	function updateTOCBorder() {
		const el = document.getElementById("article-toc-container");
		if (!el) return;
		el.style.setProperty("background-color", "transparent");
		el.style.setProperty("box-shadow", "none");
		const isDark = document.documentElement.classList.contains("dark");
		el.style.setProperty("border", `1px solid ${isDark ? "#fff" : "#000"}`);
	}
	updateTOCBorder();
	new MutationObserver(updateTOCBorder).observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
</script>
