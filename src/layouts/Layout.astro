---
import GoogleAnalytics from "@components/analytics/GoogleAnalytics.astro";
import La51Analytics from "@components/analytics/La51Analytics.astro";
import MicrosoftClarity from "@components/analytics/MicrosoftClarity.astro";
import UmamiAnalytics from "@components/analytics/UmamiAnalytics.astro";
import FancyboxManager from "@components/features/FancyboxManager.astro";
import FloatingLyrics from "@components/features/FloatingLyrics.astro";
import FontManager from "@components/features/FontManager.astro";
import MusicManager from "@components/features/MusicManager.astro";
import PageLoader from "@components/features/PageLoader.astro";
import PrivacyModal from "@components/features/PrivacyModal.astro";
import ConfigCarrier from "@components/layout/ConfigCarrier.astro";
import MobileDock from "@components/layout/MobileDock.astro";
import AISearch from "@/components/controls/AISearch.svelte";
import FloatingDock from "@/components/controls/FloatingDock.astro";
import SearchModal from "@/components/controls/SearchModal.svelte";

import { expressiveCodeConfig, homeConfig, siteConfig } from "@/config";
import { PAGE_WIDTH } from "@/constants/constants";
import { defaultFavicons } from "@/constants/icon";
import type { Favicon } from "@/types/config";
import { url } from "@/utils/url-utils";

import "@/styles/main.css";
import "@/styles/variables.styl";
import "@/styles/markdown-extend.styl";
import "@rehype-callouts-theme";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
}

const { title, description, setOGTypeArticle, postSlug } = Astro.props;
let { lang } = Astro.props;

const configHue = siteConfig.themeColor.hue;

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = siteConfig.subtitle
		? `${siteConfig.title} - ${siteConfig.subtitle}`
		: siteConfig.title;
}

let ogImageUrl: string | undefined;
if (siteConfig.generateOgImages && postSlug) {
	ogImageUrl = new URL(`/og/${postSlug}.png`, Astro.site).toString();
} else if (siteConfig.defaultOgImage) {
	ogImageUrl = new URL(siteConfig.defaultOgImage, Astro.site).toString();
}

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");
---

<!doctype html>
<html lang={siteLang} class="bg-(--page-bg) text-[14px] md:text-[16px]">
  <head>
    <meta charset="UTF-8" />
    {siteConfig.analytics?.googleAnalyticsId && (
      <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    )}
    {siteConfig.font.enable && siteConfig.font.selected?.includes("aazongyiyuan") && (
      <link rel="preload" href="/fonts/AaZongYiYuan/AaZongYiYuan-2.woff2" as="font" type="font/woff2" crossorigin />
    )}
    {siteConfig.analytics?.microsoftClarityId && (
      <link rel="preconnect" href="https://www.clarity.ms" crossorigin />
    )}
    {siteConfig.analytics?.umamiAnalytics?.websiteId && siteConfig.analytics.umamiAnalytics.scriptUrl && (
      <link rel="preconnect" href={new URL(siteConfig.analytics.umamiAnalytics.scriptUrl).origin} crossorigin />
    )}
    {siteConfig.analytics?.googleAnalyticsId && (
      <GoogleAnalytics analyticsId={siteConfig.analytics.googleAnalyticsId} />
    )}
    {siteConfig.analytics?.microsoftClarityId && (
      <MicrosoftClarity clarityId={siteConfig.analytics.microsoftClarityId} />
    )}
    {siteConfig.analytics?.umamiAnalytics?.websiteId && (
      <UmamiAnalytics
        websiteId={siteConfig.analytics.umamiAnalytics.websiteId}
        scriptUrl={siteConfig.analytics.umamiAnalytics.scriptUrl}
        trackOutboundLinks={siteConfig.analytics.umamiAnalytics.trackOutboundLinks}
        collectWebVitals={siteConfig.analytics.umamiAnalytics.collectWebVitals}
        relpays={siteConfig.analytics.umamiAnalytics.relpays}
      />
    )}
    {siteConfig.analytics?.la51Analytics?.Id && (
      <La51Analytics
        analyticsId={siteConfig.analytics.la51Analytics.Id}
        sdkUrl={siteConfig.analytics.la51Analytics?.sdkUrl}
        ck={siteConfig.analytics.la51Analytics?.ck}
        autoTrack={siteConfig.analytics.la51Analytics?.autoTrack}
        hashMode={siteConfig.analytics.la51Analytics?.hashMode}
        screenRecord={siteConfig.analytics.la51Analytics?.screenRecord}
      />
    )}

    <title>{pageTitle}</title>
    <meta name="description" content={description || siteConfig.description || pageTitle} />
    {siteConfig.keywords && siteConfig.keywords.length > 0 && (
      <meta name="keywords" content={siteConfig.keywords.join(", ")} />
    )}
    <meta name="author" content={homeConfig.name} />

    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description || siteConfig.description || pageTitle} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {setOGTypeArticle ? (
      <meta property="og:type" content="article" />
    ) : (
      <meta property="og:type" content="website" />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description || siteConfig.description || pageTitle} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <meta property="og:locale" content={siteLang} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {favicons.map((favicon) => (
      <link
        rel={favicon.src.includes("apple-touch-icon") ? "apple-touch-icon" : "icon"}
        href={favicon.src.startsWith("/") ? url(favicon.src) : favicon.src}
        sizes={favicon.sizes}
        media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
      />
    ))}

    {/* 主题初始化（极简：仅 light/dark） */}
    <script
      is:inline
      define:vars={{
        configHue,
        defaultMode: siteConfig.themeColor.defaultMode ?? "light",
        darkTheme: expressiveCodeConfig.darkTheme,
        lightTheme: expressiveCodeConfig.lightTheme,
      }}
    >
      const stored = localStorage.getItem("theme");
      // 如果没有存储过主题，使用配置的默认值（不写入 localStorage，让用户后续切换才持久化）
      const theme = stored === "system"
        ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
        : (stored || defaultMode);
      const isDark = theme === "dark";
      if (isDark) document.documentElement.classList.add("dark");
      else document.documentElement.classList.remove("dark");
      document.documentElement.setAttribute("data-theme", isDark ? darkTheme : lightTheme);
      // Persist resolved value if it was "system"
      if (stored === "system") localStorage.setItem("theme", theme);

      const hue = localStorage.getItem("hue") || configHue;
      document.documentElement.style.setProperty("--hue", hue);
    </script>
    <style
      define:vars={{
        configHue,
        "page-width": `${siteConfig.pageWidth ?? PAGE_WIDTH}rem`,
      }}
    ></style>

    <slot name="head" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={homeConfig.name}
      href={`${Astro.site}rss.xml`}
    />

    <FontManager />
  </head>
  <body
    class="min-h-screen bg-(--page-bg) text-(--deep-text)"
    class:list={[
      ...(siteConfig.font.enable && siteConfig.font.selected
        ? (Array.isArray(siteConfig.font.selected)
            ? siteConfig.font.selected
            : [siteConfig.font.selected]
          ).map((fontId) => `font-${fontId}-enabled`)
        : []),
    ]}
  >
    <div id="progress-bar"></div>
    <PageLoader />
    <ConfigCarrier />
    <MusicManager />
    <FloatingLyrics />
    <slot />
    {/* 全局持久化组件 — Swup 容器外，所有页面共享（CLAUDE.md 4.2） */}
    <FloatingDock />
    <MobileDock />
    <AISearch client:idle />
    <SearchModal
      client:idle
      placeholders={[
        "搜索文章、标签、分类...",
        "输入关键词开始搜索",
        "试试搜索「Astro」或「Svelte」",
        "按 ESC 关闭搜索面板",
        "Ctrl+K 快速切换AI搜索/普通搜索",
      ]}
    />
    <PrivacyModal />
    <FancyboxManager />
  </body>
</html>

<script>
  import { navigateToPage } from "@/utils/navigation-utils";
  window.navigateToPage = navigateToPage;
</script>

<script>
  import { initPageLoader } from "@/utils/page-loader-controller.js";

  initPageLoader();
</script>

<script>
  import { pathsEqual } from "@/utils/url-utils";
  import { expressiveCodeConfig, siteConfig } from "@/config";

  function initCustomScrollbar() {
    const katexElements = document.querySelectorAll(
      ".katex-display:not([data-scrollbar-initialized])"
    ) as NodeListOf<HTMLElement>;
    katexElements.forEach((element) => {
      if (!element.parentNode) return;
      const container = document.createElement("div");
      container.className = "katex-display-container";
      element.parentNode.insertBefore(container, element);
      container.appendChild(element);
      container.style.cssText = "overflow-x: auto;";
      element.setAttribute("data-scrollbar-initialized", "true");
    });
  }

  function initHorizontalOverflowContainers() {
    const tables = document.querySelectorAll(
      ".custom-md table:not([data-horizontal-scroll-ready])"
    ) as NodeListOf<HTMLElement>;
    tables.forEach((table) => {
      if (table.parentElement?.classList.contains("horizontal-scroll-container")) {
        table.dataset.horizontalScrollReady = "true";
        return;
      }
      const container = document.createElement("div");
      container.className = "horizontal-scroll-container";
      table.parentNode?.insertBefore(container, table);
      container.appendChild(table);
      table.dataset.horizontalScrollReady = "true";
    });
  }

  // 模块作用域存储 timeout ID，避免快速导航时竞态
  let progressTimeout1: ReturnType<typeof setTimeout> | null = null;
  let progressTimeout2: ReturnType<typeof setTimeout> | null = null;
  let transitionTimeout: ReturnType<typeof setTimeout> | null = null;
  let commentTimeout: ReturnType<typeof setTimeout> | null = null;

  function clearAllTransitionTimeouts() {
    if (progressTimeout1) { clearTimeout(progressTimeout1); progressTimeout1 = null; }
    if (progressTimeout2) { clearTimeout(progressTimeout2); progressTimeout2 = null; }
    if (transitionTimeout) { clearTimeout(transitionTimeout); transitionTimeout = null; }
    if (commentTimeout) { clearTimeout(commentTimeout); commentTimeout = null; }
  }

  function scheduleContentOverflowEnhancements() {
    requestAnimationFrame(() => {
      initCustomScrollbar();
      initHorizontalOverflowContainers();
    });
  }

  const setup = async () => {
    window.swup.hooks.on("link:click", (_visit: any, { el }: { el: HTMLAnchorElement }) => {
      document.documentElement.style.setProperty("--content-delay", "0ms");
      const targetHref = el.getAttribute("href") || "";
      const targetPathname = (() => {
        try {
          return new URL(targetHref, window.location.href).pathname;
        } catch {
          return targetHref;
        }
      })();
      const isSamePage = pathsEqual(targetPathname, window.location.pathname);
      if (isSamePage) {
        document.documentElement.classList.remove("is-page-transitioning");
      } else {
        document.documentElement.classList.add("is-page-transitioning");
      }
    });

    window.swup.hooks.on("content:replace", () => {
      scheduleContentOverflowEnhancements();
      import("@/utils/icon-loader").then(({ initIconLoader }) => initIconLoader());
    });

    // 侧边栏组件在 Swup 容器之外，页面切换后需要手动更新显隐状态
    function updateSidebarWidgetVisibility() {
      const isPost = window.location.pathname.includes("/posts/");
      document.querySelectorAll(".widget-hide-on-post").forEach((el) => {
        el.classList.toggle("hidden", isPost);
      });
      document.querySelectorAll(".widget-hide-on-non-post").forEach((el) => {
        el.classList.toggle("hidden", !isPost);
      });
    }

    // content:replace 时 URL 已更新，立即同步侧边栏显隐
    window.swup.hooks.on("content:replace", () => {
      updateSidebarWidgetVisibility();
    });

    window.swup.hooks.on("visit:start", (visit: any) => {
      clearAllTransitionTimeouts();
      const targetUrl = visit?.to?.url || "";
      const targetPathname = (() => {
        try { return new URL(targetUrl, window.location.href).pathname; } catch { return targetUrl; }
      })();
      const isSamePage = pathsEqual(targetPathname, window.location.pathname);
      if (!isSamePage) {
        document.documentElement.classList.add("is-page-transitioning");
      }

      const progressBar = document.getElementById("progress-bar");
      if (progressBar) {
        progressBar.classList.remove("finishing", "done");
        void progressBar.offsetWidth;
        progressBar.classList.add("loading");
      }
      const shouldUseSmoothScroll = window.innerWidth >= 768;
      if (shouldUseSmoothScroll) window.scrollTo({ top: 0, behavior: "auto" });
    });

    window.swup.hooks.on("page:view", () => {
      const storedTheme = localStorage.getItem("theme") || siteConfig.themeColor.defaultMode || "light";
      const isDark = storedTheme === "dark";
      const expectedTheme = isDark ? expressiveCodeConfig.darkTheme : expressiveCodeConfig.lightTheme;
      const currentTheme = document.documentElement.getAttribute("data-theme");
      if (currentTheme !== expectedTheme) {
        document.documentElement.setAttribute("data-theme", expectedTheme);
      }
      updateSidebarWidgetVisibility();
      commentTimeout = setTimeout(() => {
        if (document.getElementById("tcomment")) {
          document.dispatchEvent(new CustomEvent("firefly:page:loaded", {
            detail: { path: window.location.pathname, timestamp: Date.now() },
          }));
        }
      }, 300);
    });

    window.swup.hooks.on("visit:end", () => {
      const progressBar = document.getElementById("progress-bar");
      if (progressBar) {
        progressBar.classList.remove("loading");
        progressBar.classList.add("finishing");
        progressTimeout1 = setTimeout(() => {
          progressBar.classList.remove("finishing");
          progressBar.classList.add("done");
          progressTimeout2 = setTimeout(() => progressBar.classList.remove("done"), 300);
        }, 200);
      }

      transitionTimeout = setTimeout(() => {
        document.documentElement.classList.remove("is-page-transitioning");
        // 重置 TOC 内部导航标记
        (window as any).tocInternalNavigation = false;
      }, 400);
    });
  };

  if (window?.swup?.hooks) setup();
  else document.addEventListener("swup:enable", setup);

  document.addEventListener("astro:page-load", scheduleContentOverflowEnhancements);
  document.addEventListener("password:decrypted", () => {
    setTimeout(scheduleContentOverflowEnhancements, 200);
  });

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      scheduleContentOverflowEnhancements();
      import("@/utils/icon-loader").then(({ initIconLoader }) => initIconLoader());
    });
  } else {
    scheduleContentOverflowEnhancements();
    import("@/utils/icon-loader").then(({ initIconLoader }) => initIconLoader());
  }
</script>
